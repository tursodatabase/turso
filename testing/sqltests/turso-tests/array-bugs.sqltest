@database :memory:
@requires-file custom_types "array tests require custom types support"

test array-trailing-comma-rejected {
    CREATE TABLE tc1 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO tc1 VALUES (1, '{1,2,}');
}
expect error {
    cannot store non-array value in INTEGER column tc1.vals
}

test array-infinity-rejected {
    CREATE TABLE inf1 (id INTEGER PRIMARY KEY, vals real[]) STRICT;
    INSERT INTO inf1 VALUES (1, '{1e309}');
}
expect error {
    cannot store non-array value in REAL column inf1.vals
}

test array-neg-infinity-rejected {
    CREATE TABLE inf2 (id INTEGER PRIMARY KEY, vals real[]) STRICT;
    INSERT INTO inf2 VALUES (1, '{-1e309}');
}
expect error {
    cannot store non-array value in REAL column inf2.vals
}

test array-infinity-insert-select {
    CREATE TABLE inf3 (id INTEGER PRIMARY KEY, vals real[]) STRICT;
    INSERT INTO inf3 VALUES (1, '{1.0, 2.0, 3.0}');
    INSERT INTO inf3 SELECT id + 1, vals FROM inf3;
    SELECT id, vals FROM inf3 ORDER BY id;
}
expect {
    1|{1.0,2.0,3.0}
    2|{1.0,2.0,3.0}
}

test array-case-display {
    CREATE TABLE cd1 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO cd1 VALUES (1, '{1,2,3}');
    SELECT CASE WHEN 1 THEN vals END FROM cd1;
}
expect {
    {1,2,3}
}

test array-coalesce-display {
    CREATE TABLE cd2 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO cd2 VALUES (1, '{4,5,6}');
    SELECT COALESCE(vals, vals) FROM cd2;
}
expect {
    {4,5,6}
}

test array-iif-display {
    CREATE TABLE cd3 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO cd3 VALUES (1, '{7,8,9}');
    SELECT IIF(1, vals, vals) FROM cd3;
}
expect {
    {7,8,9}
}

test array-nullif-display {
    CREATE TABLE cd4 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO cd4 VALUES (1, '{10,11}');
    SELECT NULLIF(vals, NULL) FROM cd4;
}
expect {
    {10,11}
}

test array-case-literal-display {
    SELECT CASE WHEN 1 THEN ARRAY[1, 2] END;
}
expect {
    {1,2}
}

test array-coalesce-literal-display {
    SELECT COALESCE(NULL, ARRAY[3, 4]);
}
expect {
    {3,4}
}

test array-order-by {
    CREATE TABLE ob1 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO ob1 VALUES (1, '{3,2,1}');
    INSERT INTO ob1 VALUES (2, '{1,2,3}');
    INSERT INTO ob1 VALUES (3, '{1,2}');
    INSERT INTO ob1 VALUES (4, '{1,2,4}');
    SELECT id, vals FROM ob1 ORDER BY vals;
}
expect {
    3|{1,2}
    2|{1,2,3}
    4|{1,2,4}
    1|{3,2,1}
}

test array-order-by-desc {
    CREATE TABLE ob2 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO ob2 VALUES (1, '{3,2,1}');
    INSERT INTO ob2 VALUES (2, '{1,2,3}');
    INSERT INTO ob2 VALUES (3, '{1,2}');
    INSERT INTO ob2 VALUES (4, '{1,2,4}');
    SELECT id, vals FROM ob2 ORDER BY vals DESC;
}
expect {
    1|{3,2,1}
    4|{1,2,4}
    2|{1,2,3}
    3|{1,2}
}

test array-order-by-text {
    CREATE TABLE ob3 (id INTEGER PRIMARY KEY, vals text[]) STRICT;
    INSERT INTO ob3 VALUES (1, '{"cherry","apple"}');
    INSERT INTO ob3 VALUES (2, '{"apple","banana"}');
    INSERT INTO ob3 VALUES (3, '{"apple"}');
    SELECT id, vals FROM ob3 ORDER BY vals;
}
expect {
    3|{apple}
    2|{apple,banana}
    1|{cherry,apple}
}

test array-order-by-with-other-columns {
    CREATE TABLE ob4 (id INTEGER PRIMARY KEY, name TEXT, vals integer[]) STRICT;
    INSERT INTO ob4 VALUES (1, 'a', '{2,1}');
    INSERT INTO ob4 VALUES (2, 'b', '{1,2}');
    SELECT id, name, vals FROM ob4 ORDER BY vals;
}
expect {
    2|b|{1,2}
    1|a|{2,1}
}

test array-trailing-comma-spaces {
    CREATE TABLE tc2 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO tc2 VALUES (1, '{1, 2, }');
}
expect error {
    cannot store non-array value in INTEGER column tc2.vals
}

test array-coalesce-null-then-array {
    CREATE TABLE cn1 (id INTEGER PRIMARY KEY, a integer[], b integer[]) STRICT;
    INSERT INTO cn1 VALUES (1, NULL, '{1,2,3}');
    SELECT COALESCE(a, b) FROM cn1;
}
expect {
    {1,2,3}
}

test array-ifnull-display {
    CREATE TABLE ifn1 (id INTEGER PRIMARY KEY, a integer[], b integer[]) STRICT;
    INSERT INTO ifn1 VALUES (1, NULL, '{5,6}');
    SELECT IFNULL(a, b) FROM ifn1;
}
expect {
    {5,6}
}

test array-nested-case-display {
    CREATE TABLE nc1 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO nc1 VALUES (1, '{1,2}');
    SELECT COALESCE(CASE WHEN 1 THEN vals END, ARRAY[0]) FROM nc1;
}
expect {
    {1,2}
}
