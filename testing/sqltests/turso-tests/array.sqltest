}
expect {
    0
}

test array-compare-ne-operator {
    SELECT ARRAY[1,2] != ARRAY[1,3];
}
expect {
    1
}

test array-compare-less-than {
    SELECT ARRAY[1,2] < ARRAY[1,3];
}
expect {
    1
}

test array-compare-shorter-is-less {
    SELECT ARRAY[1,2] < ARRAY[1,2,3];
}
expect {
    1
}

test array-compare-greater-than {
    SELECT ARRAY[1,2,3] > ARRAY[1,2];
}
expect {
    1
}

test array-compare-le {
    SELECT ARRAY[1,2] <= ARRAY[1,2];
}
expect {
    1
}

test array-compare-ge {
    SELECT ARRAY[1,2] >= ARRAY[1,2];
}
expect {
    1
}

test array-compare-where-clause {
    CREATE TABLE cmp_t (id INTEGER PRIMARY KEY, vals INTEGER[]) STRICT;
    INSERT INTO cmp_t VALUES (1, ARRAY[1,2,3]);
    INSERT INTO cmp_t VALUES (2, ARRAY[4,5,6]);
    INSERT INTO cmp_t VALUES (3, ARRAY[1,2,3]);
    SELECT id FROM cmp_t WHERE vals = ARRAY[1,2,3] ORDER BY id;
}
expect {
    1
    3
}

test array-contains-operator-basic {
