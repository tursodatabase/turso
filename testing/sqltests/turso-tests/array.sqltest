# ============================================================
# @> / && operator edge cases
# ============================================================

# NOT should invert the boolean result
test array-contains-operator-not {
    CREATE TABLE not_t (id INTEGER PRIMARY KEY, vals INTEGER[]) STRICT;
    INSERT INTO not_t VALUES (1, ARRAY[1,2,3]);
    INSERT INTO not_t VALUES (2, ARRAY[4,5,6]);
    INSERT INTO not_t VALUES (3, ARRAY[1,2,7]);
    SELECT id FROM not_t WHERE NOT (vals @> ARRAY[1,2]) ORDER BY id;
}
expect {
    2
}

test array-overlap-operator-not {
    CREATE TABLE not_t2 (id INTEGER PRIMARY KEY, vals INTEGER[]) STRICT;
    INSERT INTO not_t2 VALUES (1, ARRAY[1,2]);
    INSERT INTO not_t2 VALUES (2, ARRAY[3,4]);
    INSERT INTO not_t2 VALUES (3, ARRAY[5,6]);
    SELECT id FROM not_t2 WHERE NOT (vals && ARRAY[1,3]) ORDER BY id;
}
expect {
    3
}

# Non-array operands should return NULL (not crash)
test array-contains-operator-non-array-integer {
    SELECT 5 @> 3;
}
expect {
}

test array-overlap-operator-non-array-integer {
    SELECT 5 && 3;
}
expect {
}

# Text literal arrays (JSON text, not ARRAY[] syntax) through operators
test array-contains-operator-text-literals {
    SELECT '{1,2,3}' @> '{1,2}';
}
expect {
    1
}

test array-overlap-operator-text-literals {
    SELECT '{1,2,3}' && '{4,5,3}';
}
expect {
    1
}

# CASE WHEN with array operators
test array-contains-operator-case-when {
    CREATE TABLE case_t (id INTEGER PRIMARY KEY, vals INTEGER[]) STRICT;
    INSERT INTO case_t VALUES (1, ARRAY[1,2,3]);
    INSERT INTO case_t VALUES (2, ARRAY[4,5,6]);
    SELECT id, CASE WHEN vals @> ARRAY[1,2] THEN 'yes' ELSE 'no' END FROM case_t ORDER BY id;
}
expect {
    1|yes
    2|no
}

test array-overlap-operator-case-when {
    CREATE TABLE case_t2 (id INTEGER PRIMARY KEY, vals INTEGER[]) STRICT;
    INSERT INTO case_t2 VALUES (1, ARRAY[1,2]);
    INSERT INTO case_t2 VALUES (2, ARRAY[3,4]);
    SELECT id, CASE WHEN vals && ARRAY[2,5] THEN 'overlap' ELSE 'none' END FROM case_t2 ORDER BY id;
}
expect {
    1|overlap
    2|none
}

# Subquery with array operators
test array-contains-operator-subquery {
    CREATE TABLE sub_t (id INTEGER PRIMARY KEY, vals INTEGER[]) STRICT;
    INSERT INTO sub_t VALUES (1, ARRAY[10,20,30]);
    INSERT INTO sub_t VALUES (2, ARRAY[40,50]);
    SELECT id FROM sub_t WHERE id IN (SELECT id FROM sub_t WHERE vals @> ARRAY[10,20]);
}
expect {
    1
}

# Self-referencing column: arr @> arr should always be true (contains itself)
test array-contains-operator-self-column {
    CREATE TABLE self_t (id INTEGER PRIMARY KEY, vals INTEGER[]) STRICT;
    INSERT INTO self_t VALUES (1, ARRAY[1,2,3]);
    INSERT INTO self_t VALUES (2, ARRAY[4,5]);
    SELECT id, vals @> vals FROM self_t ORDER BY id;
}
expect {
    1|1
    2|1
}

# Self-referencing column: arr && arr should always be true (overlaps itself)
# unless array is empty
test array-overlap-operator-self-column {
    CREATE TABLE self_t2 (id INTEGER PRIMARY KEY, vals INTEGER[]) STRICT;
    INSERT INTO self_t2 VALUES (1, ARRAY[1,2,3]);
    INSERT INTO self_t2 VALUES (2, ARRAY[4]);
    SELECT id, vals && vals FROM self_t2 ORDER BY id;
}
expect {
    1|1
    2|1
}

# Operator in ORDER BY expression
test array-contains-operator-order-by {
    CREATE TABLE ord_t (id INTEGER PRIMARY KEY, vals INTEGER[]) STRICT;
    INSERT INTO ord_t VALUES (1, ARRAY[10,20]);
    INSERT INTO ord_t VALUES (2, ARRAY[1,2,3]);
    INSERT INTO ord_t VALUES (3, ARRAY[5,6]);
    SELECT id FROM ord_t ORDER BY vals @> ARRAY[1,2] DESC, id;
}
expect {
    2
    1
    3
}

# Mixed operators in the same WHERE clause
test array-operators-mixed-where {
    CREATE TABLE mix_t (id INTEGER PRIMARY KEY, a INTEGER[], b INTEGER[]) STRICT;
    INSERT INTO mix_t VALUES (1, ARRAY[1,2,3], ARRAY[10,20]);
    INSERT INTO mix_t VALUES (2, ARRAY[4,5], ARRAY[10,30]);
    INSERT INTO mix_t VALUES (3, ARRAY[1,6], ARRAY[40,50]);
    SELECT id FROM mix_t WHERE a @> ARRAY[1] AND b && ARRAY[10] ORDER BY id;
}
expect {
    1
}

# Operators combined with regular comparison (test collation doesn't leak)
test array-operator-with-string-comparison {
    CREATE TABLE coll_t (id INTEGER PRIMARY KEY, vals TEXT[], name TEXT) STRICT;
    INSERT INTO coll_t VALUES (1, ARRAY['a','b'], 'Alice');
    INSERT INTO coll_t VALUES (2, ARRAY['c','d'], 'Bob');
    INSERT INTO coll_t VALUES (3, ARRAY['a','c'], 'alice');
    SELECT id FROM coll_t WHERE vals @> ARRAY['a'] AND name = 'Alice' ORDER BY id;
}
expect {
    1
}

# COALESCE wrapping operator result (NULL input → fallback)
test array-contains-operator-coalesce {
    SELECT COALESCE(NULL @> ARRAY[1], 0);
}
expect {
    0
}

test array-overlap-operator-coalesce {
    SELECT COALESCE(ARRAY[1] && NULL, 0);
}
expect {
    0
}

# --- ORDER BY element-wise comparison (not lexicographic) ---

test array-order-by-elementwise-from-subquery {
    SELECT * FROM (SELECT ARRAY[1,10] AS a UNION ALL SELECT ARRAY[1,2]) ORDER BY a;
}
expect {
    {1,2}
    {1,10}
}

test array-order-by-elementwise-desc {
    SELECT * FROM (SELECT ARRAY[1,2] AS a UNION ALL SELECT ARRAY[1,10]) ORDER BY a DESC;
}
expect {
    {1,10}
    {1,2}
}

test array-order-by-prefix-shorter-first {
    SELECT * FROM (
        SELECT ARRAY[1,2,3] AS a
        UNION ALL SELECT ARRAY[1,2]
        UNION ALL SELECT ARRAY[1]
    ) ORDER BY a;
}
expect {
    {1}
    {1,2}
    {1,2,3}
}

test array-order-by-column-reference {
    CREATE TABLE t_order(id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO t_order VALUES (1, '{3,1}');
    INSERT INTO t_order VALUES (2, '{1,10}');
    INSERT INTO t_order VALUES (3, '{1,2}');
    SELECT vals FROM t_order ORDER BY vals;
}
expect {
    {1,2}
    {1,10}
    {3,1}
}

test array-order-by-with-nulls {
    SELECT * FROM (
        SELECT ARRAY[2] AS a
        UNION ALL SELECT NULL
        UNION ALL SELECT ARRAY[1]
    ) ORDER BY a;
}
expect {

    {1}
    {2}
}

test array-order-by-mixed-types {
    SELECT * FROM (
        SELECT ARRAY['b','a'] AS a
        UNION ALL SELECT ARRAY['a','z']
    ) ORDER BY a;
}
expect {
    {a,z}
    {b,a}
}
