@database :memory:
@requires-file custom_types "array tests require custom types support"

test array-basic-insert-json {
    CREATE TABLE t1 (id INTEGER PRIMARY KEY, tags text[]) STRICT;
    INSERT INTO t1 VALUES (1, '{"a","b","c"}');
    SELECT id, tags FROM t1;
}
expect {
    1|{a,b,c}
}

test array-integer-insert {
    CREATE TABLE t2 (id INTEGER PRIMARY KEY, scores integer[]) STRICT;
    INSERT INTO t2 VALUES (1, '{10, 20, 30}');
    SELECT id, scores FROM t2;
}
expect {
    1|{10,20,30}
}

test array-multiple-rows {
    CREATE TABLE t3 (id INTEGER PRIMARY KEY, vals text[]) STRICT;
    INSERT INTO t3 VALUES (1, '{"x","y"}');
    INSERT INTO t3 VALUES (2, '{"a","b","c"}');
    SELECT id, vals FROM t3 ORDER BY id;
}
expect {
    1|{x,y}
    2|{a,b,c}
}

test array-empty {
    CREATE TABLE t4 (id INTEGER PRIMARY KEY, items text[]) STRICT;
    INSERT INTO t4 VALUES (1, '{}');
    SELECT id, items FROM t4;
}
expect {
    1|{}
}

test array-literal-syntax {
    CREATE TABLE t5 (id INTEGER PRIMARY KEY, tags text[]) STRICT;
    INSERT INTO t5 VALUES (1, ARRAY['hello', 'world']);
    SELECT id, tags FROM t5;
}
expect {
    1|{hello,world}
}

test array-subscript-access {
    CREATE TABLE t6 (id INTEGER PRIMARY KEY, items text[]) STRICT;
    INSERT INTO t6 VALUES (1, '{"first","second","third"}');
    SELECT items[1], items[2], items[3] FROM t6;
}
expect {
    first|second|third
}

test array-length {
    CREATE TABLE t7 (id INTEGER PRIMARY KEY, items text[]) STRICT;
    INSERT INTO t7 VALUES (1, '{"a","b","c"}');
    INSERT INTO t7 VALUES (2, '{}');
    INSERT INTO t7 VALUES (3, '{"x"}');
    SELECT id, array_length(items) FROM t7 ORDER BY id;
}
expect {
    1|3
    2|0
    3|1
}

test array-append {
    SELECT array_append('{"a","b"}', 'c');
}
expect {
    {a,b,c}
}

test array-prepend {
    SELECT array_prepend('z', '{"a","b"}');
}
expect {
    {z,a,b}
}

test array-cat {
    SELECT array_cat('{1,2}', '{3,4}');
}
expect {
    {1,2,3,4}
}

test array-contains-found {
    SELECT array_contains('{1,2,3}', 2);
}
expect {
    1
}

test array-contains-not-found {
    SELECT array_contains('{1,2,3}', 5);
}
expect {
    0
}

test array-position-found {
    SELECT array_position('{10,20,30}', 20);
}
expect {
    2
}

test array-position-not-found {
    SELECT array_position('{10,20,30}', 99);
}
expect {
}

test array-remove {
    SELECT array_remove('{1,2,3,2,1}', 2);
}
expect {
    {1,3,1}
}

test array-boolean-elements {
    CREATE TABLE t8 (id INTEGER PRIMARY KEY, flags boolean[]) STRICT;
    INSERT INTO t8 VALUES (1, '{true, false, true}');
    SELECT id, flags FROM t8;
}
expect {
    1|{1,0,1}
}

test array-schema-persistence {
    CREATE TABLE t9 (id INTEGER PRIMARY KEY, data text[]) STRICT;
    SELECT sql FROM sqlite_master WHERE name = 't9';
}
expect {
    CREATE TABLE t9 (id INTEGER PRIMARY KEY, data text[]) STRICT
}

test array-null-value {
    CREATE TABLE t10 (id INTEGER PRIMARY KEY, items text[]) STRICT;
    INSERT INTO t10 VALUES (1, NULL);
    SELECT id, items FROM t10;
}
expect {
    1|
}

test array-subscript-out-of-bounds {
    CREATE TABLE t11 (id INTEGER PRIMARY KEY, items text[]) STRICT;
    INSERT INTO t11 VALUES (1, '{"a","b","c"}');
    SELECT items[100] FROM t11;
}
expect {
}

test array-subscript-negative {
    CREATE TABLE t12 (id INTEGER PRIMARY KEY, items text[]) STRICT;
    INSERT INTO t12 VALUES (1, '{"a","b","c"}');
    SELECT items[-1] FROM t12;
}
expect {
}

test array-update {
    CREATE TABLE t13 (id INTEGER PRIMARY KEY, tags text[]) STRICT;
    INSERT INTO t13 VALUES (1, '{"old"}');
    UPDATE t13 SET tags = '{"new","updated"}' WHERE id = 1;
    SELECT id, tags FROM t13;
}
expect {
    1|{new,updated}
}

test array-update-with-literal {
    CREATE TABLE t14 (id INTEGER PRIMARY KEY, tags text[]) STRICT;
    INSERT INTO t14 VALUES (1, '{"old"}');
    UPDATE t14 SET tags = ARRAY['new', 'updated'] WHERE id = 1;
    SELECT id, tags FROM t14;
}
expect {
    1|{new,updated}
}

test array-delete-with-subscript {
    CREATE TABLE t15 (id INTEGER PRIMARY KEY, items text[]) STRICT;
    INSERT INTO t15 VALUES (1, '{"keep"}');
    INSERT INTO t15 VALUES (2, '{"remove"}');
    DELETE FROM t15 WHERE items[1] = 'remove';
    SELECT id, items FROM t15;
}
expect {
    1|{keep}
}

test array-where-subscript {
    CREATE TABLE t16 (id INTEGER PRIMARY KEY, items text[]) STRICT;
    INSERT INTO t16 VALUES (1, '{"alpha","beta"}');
    INSERT INTO t16 VALUES (2, '{"gamma","delta"}');
    INSERT INTO t16 VALUES (3, '{"alpha","omega"}');
    SELECT id FROM t16 WHERE items[1] = 'alpha' ORDER BY id;
}
expect {
    1
    3
}

test array-non-strict-rejected {
    CREATE TABLE t17 (id INTEGER PRIMARY KEY, items text[]);
}
expect error {
    array type columns require STRICT tables: t17.items
}

test array-invalid-json-input {
    CREATE TABLE t18 (id INTEGER PRIMARY KEY, items text[]) STRICT;
    INSERT INTO t18 VALUES (1, 'not json at all');
}
expect error {
    cannot store non-array value in TEXT column t18.items
}

test array-empty-literal {
    CREATE TABLE t19 (id INTEGER PRIMARY KEY, tags text[]) STRICT;
    INSERT INTO t19 VALUES (1, ARRAY[]);
    SELECT id, tags FROM t19;
}
expect {
    1|{}
}

test array-contains-null-target {
    SELECT array_contains('{1,2,3}', NULL);
}
expect {
    0
}

test array-position-null-target {
    SELECT array_position('{1,2,3}', NULL);
}
expect {
}

test array-cat-empty-left {
    SELECT array_cat('{}', '{1,2}');
}
expect {
    {1,2}
}

test array-cat-empty-right {
    SELECT array_cat('{1,2}', '{}');
}
expect {
    {1,2}
}

test array-cat-both-empty {
    SELECT array_cat('{}', '{}');
}
expect {
    {}
}

test array-append-to-empty {
    SELECT array_append('{}', 'x');
}
expect {
    {x}
}

test array-remove-not-found {
    SELECT array_remove('{1,2,3}', 99);
}
expect {
    {1,2,3}
}

test array-remove-from-empty {
    SELECT array_remove('{}', 1);
}
expect {
    {}
}

test array-order-by-subscript {
    CREATE TABLE t20 (id INTEGER PRIMARY KEY, items integer[]) STRICT;
    INSERT INTO t20 VALUES (1, '{30}');
    INSERT INTO t20 VALUES (2, '{10}');
    INSERT INTO t20 VALUES (3, '{20}');
    SELECT id FROM t20 ORDER BY items[1];
}
expect {
    2
    3
    1
}

test array-integer-subscript {
    CREATE TABLE t21 (id INTEGER PRIMARY KEY, scores integer[]) STRICT;
    INSERT INTO t21 VALUES (1, '{100, 200, 300}');
    SELECT scores[1], scores[2], scores[3] FROM t21;
}
expect {
    100|200|300
}

test array-real-type {
    CREATE TABLE t22 (id INTEGER PRIMARY KEY, vals real[]) STRICT;
    INSERT INTO t22 VALUES (1, '{1.5, 2.5, 3.5}');
    SELECT id, vals FROM t22;
}
expect {
    1|{1.5,2.5,3.5}
}

test array-multiple-array-columns {
    CREATE TABLE t23 (id INTEGER PRIMARY KEY, names text[], scores integer[]) STRICT;
    INSERT INTO t23 VALUES (1, '{"alice","bob"}', '{90,85}');
    SELECT id, names, scores FROM t23;
}
expect {
    1|{alice,bob}|{90,85}
}

test array-length-null-input {
    SELECT array_length(NULL);
}
expect {
}

test array-append-null-array {
    SELECT array_append(NULL, 'x');
}
expect {
    {x}
}

test array-contains-null-array {
    SELECT array_contains(NULL, 1);
}
expect {
}

test array-boolean-decode-roundtrip {
    CREATE TABLE t24 (id INTEGER PRIMARY KEY, flags boolean[]) STRICT;
    INSERT INTO t24 VALUES (1, '{true, false}');
    INSERT INTO t24 VALUES (2, '{false, false, true}');
    SELECT id, flags, array_length(flags) FROM t24 ORDER BY id;
}
expect {
    1|{1,0}|2
    2|{0,0,1}|3
}

test array-subscript-on-null {
    CREATE TABLE t25 (id INTEGER PRIMARY KEY, items text[]) STRICT;
    INSERT INTO t25 VALUES (1, NULL);
    SELECT items[1] FROM t25;
}
expect {
}

test array-insert-multiple-then-count {
    CREATE TABLE t26 (id INTEGER PRIMARY KEY, tags text[]) STRICT;
    INSERT INTO t26 VALUES (1, '{"a"}');
    INSERT INTO t26 VALUES (2, '{"b","c"}');
    INSERT INTO t26 VALUES (3, '{"d","e","f"}');
    SELECT COUNT(*), SUM(array_length(tags)) FROM t26;
}
expect {
    3|6
}

test array-type-check-string-in-integer-array {
    CREATE TABLE t27 (id INTEGER PRIMARY KEY, scores integer[]) STRICT;
    INSERT INTO t27 VALUES (1, '{"hello"}');
}
expect error {
    cannot store TEXT value in INTEGER
}

test array-type-check-inexact-float-in-integer-array {
    CREATE TABLE t28 (id INTEGER PRIMARY KEY, scores integer[]) STRICT;
    INSERT INTO t28 VALUES (1, '{1.5}');
}
expect error {
    cannot store REAL value in INTEGER
}

test array-type-check-exact-float-coerced-to-integer {
    CREATE TABLE t29 (id INTEGER PRIMARY KEY, scores integer[]) STRICT;
    INSERT INTO t29 VALUES (1, '{1.0, 2.0, 3}');
    SELECT scores FROM t29;
}
expect {
    {1,2,3}
}

test array-type-check-numbers-coerced-to-text {
    CREATE TABLE t30 (id INTEGER PRIMARY KEY, items text[]) STRICT;
    INSERT INTO t30 VALUES (1, '{1, 2, 3.14}');
    SELECT items FROM t30;
}
expect {
    {1,2,3.14}
}

test array-type-check-string-in-real-array {
    CREATE TABLE t31 (id INTEGER PRIMARY KEY, vals real[]) STRICT;
    INSERT INTO t31 VALUES (1, '{"not_a_number"}');
}
expect error {
    cannot store TEXT value in REAL
}

test array-type-check-integer-coerced-to-real {
    CREATE TABLE t32 (id INTEGER PRIMARY KEY, vals real[]) STRICT;
    INSERT INTO t32 VALUES (1, '{1, 2, 3}');
    SELECT vals FROM t32;
}
expect {
    {1.0,2.0,3.0}
}

test array-type-check-any-accepts-mixed {
    CREATE TABLE t33 (id INTEGER PRIMARY KEY, items ANY[]) STRICT;
    INSERT INTO t33 VALUES (1, '{1, "hello", 3.14, true, null}');
    SELECT items FROM t33;
}
expect {
    {1,hello,3.14,true,NULL}
}

test array-type-check-invalid-json {
    CREATE TABLE t34 (id INTEGER PRIMARY KEY, items text[]) STRICT;
    INSERT INTO t34 VALUES (1, 'not json at all');
}
expect error {
    cannot store non-array value in TEXT column t34.items
}

test array-type-check-json-object-not-array {
    CREATE TABLE t35 (id INTEGER PRIMARY KEY, items text[]) STRICT;
    INSERT INTO t35 VALUES (1, '{"key": "value"}');
}
expect error {
    cannot store non-array value in TEXT column t35.items
}

test array-type-check-null-element-allowed {
    CREATE TABLE t36 (id INTEGER PRIMARY KEY, scores integer[]) STRICT;
    INSERT INTO t36 VALUES (1, '{1, null, 3}');
    SELECT scores FROM t36;
}
expect {
    {1,NULL,3}
}

test array-type-check-update-validates {
    CREATE TABLE t37 (id INTEGER PRIMARY KEY, scores integer[]) STRICT;
    INSERT INTO t37 VALUES (1, '{1, 2, 3}');
    UPDATE t37 SET scores = '{"bad"}' WHERE id = 1;
}
expect error {
    cannot store TEXT value in INTEGER
}

test array-type-check-numeric-string-coerced-to-integer {
    CREATE TABLE t38 (id INTEGER PRIMARY KEY, scores integer[]) STRICT;
    INSERT INTO t38 VALUES (1, '{"42", "100"}');
    SELECT scores FROM t38;
}
expect {
    {42,100}
}

test array-blob-type {
    CREATE TABLE t_blob_arr (id INTEGER PRIMARY KEY, data BLOB[]) STRICT;
    INSERT INTO t_blob_arr VALUES (1, '{null}');
    SELECT id, data FROM t_blob_arr;
}
expect {
    1|{NULL}
}

test array-concat-append {
    CREATE TABLE t_concat (id INTEGER PRIMARY KEY, tags text[]) STRICT;
    INSERT INTO t_concat VALUES (1, ARRAY['a','b']);
    SELECT tags || 'c' FROM t_concat;
}
expect {
    {a,b,c}
}

test array-concat-prepend {
    CREATE TABLE t_prepend (id INTEGER PRIMARY KEY, tags text[]) STRICT;
    INSERT INTO t_prepend VALUES (1, ARRAY['a','b']);
    SELECT 'z' || tags FROM t_prepend;
}
expect {
    {z,a,b}
}

test array-concat-cat {
    CREATE TABLE t_cat (id INTEGER PRIMARY KEY, tags text[]) STRICT;
    INSERT INTO t_cat VALUES (1, ARRAY['a','b']);
    SELECT tags || ARRAY['x','y'] FROM t_cat;
}
expect {
    {a,b,x,y}
}

test array-concat-integer {
    CREATE TABLE t_concat_int (id INTEGER PRIMARY KEY, nums integer[]) STRICT;
    INSERT INTO t_concat_int VALUES (1, '{10, 20}');
    SELECT nums || 30 FROM t_concat_int;
}
expect {
    {10,20,30}
}

test array-in-containment {
    CREATE TABLE t_in (id INTEGER PRIMARY KEY, tags text[]) STRICT;
    INSERT INTO t_in VALUES (1, ARRAY['a','b','c']);
    INSERT INTO t_in VALUES (2, ARRAY['x','y','z']);
    SELECT id FROM t_in WHERE array_contains(tags, 'a') ORDER BY id;
}
expect {
    1
}

test array-in-not-found {
    CREATE TABLE t_in2 (id INTEGER PRIMARY KEY, tags text[]) STRICT;
    INSERT INTO t_in2 VALUES (1, ARRAY['a','b','c']);
    SELECT id FROM t_in2 WHERE array_contains(tags, 'z');
}
expect {
}

test array-set-element {
    CREATE TABLE t_set (id INTEGER PRIMARY KEY, tags text[]) STRICT;
    INSERT INTO t_set VALUES (1, ARRAY['a','b','c']);
    UPDATE t_set SET tags[1] = 'NEW' WHERE id = 1;
    SELECT tags FROM t_set;
}
expect {
    {NEW,b,c}
}

test array-slice {
    CREATE TABLE t_slice (id INTEGER PRIMARY KEY, tags text[]) STRICT;
    INSERT INTO t_slice VALUES (1, ARRAY['a','b','c','d']);
    SELECT tags[2:3] FROM t_slice;
}
expect {
    {b,c}
}

test array-concat-null-lhs {
    CREATE TABLE t_cn1 (id INTEGER PRIMARY KEY, tags text[]) STRICT;
    INSERT INTO t_cn1 VALUES (1, ARRAY['a','b']);
    SELECT NULL || tags FROM t_cn1;
}
expect {
    {a,b}
}

test array-concat-null-rhs {
    CREATE TABLE t_cn2 (id INTEGER PRIMARY KEY, tags text[]) STRICT;
    INSERT INTO t_cn2 VALUES (1, ARRAY['a','b']);
    SELECT tags || NULL FROM t_cn2;
}
expect {
    {a,b}
}

test array-set-element-out-of-bounds {
    CREATE TABLE t_oob (id INTEGER PRIMARY KEY, tags text[]) STRICT;
    INSERT INTO t_oob VALUES (1, ARRAY['a','b','c']);
    UPDATE t_oob SET tags[100] = 'x' WHERE id = 1;
    SELECT tags FROM t_oob;
}
expect {
    {a,b,c}
}

test array-set-multiple-subscripts {
    CREATE TABLE t_multi (id INTEGER PRIMARY KEY, tags text[]) STRICT;
    INSERT INTO t_multi VALUES (1, ARRAY['a','b','c']);
    UPDATE t_multi SET tags[1] = 'X', tags[3] = 'Z' WHERE id = 1;
    SELECT tags FROM t_multi;
}
expect {
    {X,b,Z}
}

test array-slice-null-start {
    SELECT array_slice('{1,2,3,4}', NULL, 2);
}
expect {
    {1,2}
}

test array-slice-null-end {
    SELECT array_slice('{1,2,3,4}', 2, NULL);
}
expect {
    {}
}

test array-slice-negative-start {
    SELECT array_slice('{1,2,3,4}', -1, 3);
}
expect {
    {1,2,3}
}

test array-position-one-based {
    SELECT array_position('{10,20,30}', 10);
}
expect {
    1
}

test array-position-one-based-middle {
    SELECT array_position('{10,20,30}', 30);
}
expect {
    3
}

test array-unicode-escape-input {
    CREATE TABLE t_ue (id INTEGER PRIMARY KEY, tags text[]) STRICT;
    INSERT INTO t_ue VALUES (1, '{"hello world"}');
    SELECT tags FROM t_ue;
}
expect {
    {"hello world"}
}

# ============================================================
# string_to_array tests
# ============================================================

test string-to-array-basic {
    SELECT string_to_array('one,two,three', ',');
}
expect {
    {one,two,three}
}

test string-to-array-space-delimiter {
    SELECT string_to_array('hello world foo', ' ');
}
expect {
    {hello,world,foo}
}

test string-to-array-single-element {
    SELECT string_to_array('hello', ',');
}
expect {
    {hello}
}

test string-to-array-empty-string {
    SELECT string_to_array('', ',');
}
expect {
    {""}
}

test string-to-array-null-text {
    SELECT string_to_array(NULL, ',');
}
expect {
}

test string-to-array-null-delimiter {
    SELECT string_to_array('hello', NULL);
}
expect {
    {h,e,l,l,o}
}

test string-to-array-multi-char-delimiter {
    SELECT string_to_array('a::b::c', '::');
}
expect {
    {a,b,c}
}

test string-to-array-null-string-replacement {
    SELECT string_to_array('a,NULL,b', ',', 'NULL');
}
expect {
    {a,NULL,b}
}

test string-to-array-null-string-no-match {
    SELECT string_to_array('a,b,c', ',', 'NONE');
}
expect {
    {a,b,c}
}

test string-to-array-consecutive-delimiters {
    SELECT string_to_array('a,,b,,c', ',');
}
expect {
    {a,"",b,"",c}
}

test string-to-array-empty-delimiter {
    SELECT string_to_array('hello', '');
}
expect {
    {hello}
}

test string-to-array-roundtrip-with-table {
    CREATE TABLE t_s2a (id INTEGER PRIMARY KEY, tags text[]) STRICT;
    INSERT INTO t_s2a VALUES (1, string_to_array('red,green,blue', ','));
    SELECT tags FROM t_s2a;
}
expect {
    {red,green,blue}
}

test string-to-array-with-array-length {
    SELECT array_length(string_to_array('a,b,c,d,e', ','));
}
expect {
    5
}

# ============================================================
# array_to_string tests
# ============================================================

test array-to-string-basic {
    SELECT array_to_string('{1,2,3}', ',');
}
expect {
    1,2,3
}

test array-to-string-text-array {
    SELECT array_to_string('{"hello","world"}', ' ');
}
expect {
    hello world
}

test array-to-string-single-element {
    SELECT array_to_string('{42}', ',');
}
expect {
    42
}

test array-to-string-empty-array {
    SELECT array_to_string('{}', ',');
}
expect {
}

test array-to-string-null-input {
    SELECT array_to_string(NULL, ',');
}
expect {
}

test array-to-string-null-delimiter {
    SELECT array_to_string('{1,2,3}', NULL);
}
expect {
}

test array-to-string-null-elements-skipped {
    SELECT array_to_string('{1,null,3}', ',');
}
expect {
    1,3
}

test array-to-string-null-replacement {
    SELECT array_to_string('{1,null,3}', ',', 'N/A');
}
expect {
    1,N/A,3
}

test array-to-string-multi-char-delimiter {
    SELECT array_to_string('{"a","b","c"}', ' - ');
}
expect {
    a - b - c
}

test array-to-string-from-table {
    CREATE TABLE t_a2s (id INTEGER PRIMARY KEY, tags text[]) STRICT;
    INSERT INTO t_a2s VALUES (1, ARRAY['red','green','blue']);
    SELECT array_to_string(tags, ', ') FROM t_a2s;
}
expect {
    red, green, blue
}

test string-to-array-to-string-roundtrip {
    SELECT array_to_string(string_to_array('x|y|z', '|'), '|');
}
expect {
    x|y|z
}

# ============================================================
# array_agg tests
# ============================================================

test array-agg-basic {
    CREATE TABLE t_agg1 (id INTEGER PRIMARY KEY, val TEXT);
    INSERT INTO t_agg1 VALUES (1, 'a');
    INSERT INTO t_agg1 VALUES (2, 'b');
    INSERT INTO t_agg1 VALUES (3, 'c');
    SELECT array_agg(val) FROM t_agg1;
}
expect {
    {a,b,c}
}

test array-agg-integers {
    CREATE TABLE t_agg2 (id INTEGER PRIMARY KEY, val INTEGER);
    INSERT INTO t_agg2 VALUES (1, 10);
    INSERT INTO t_agg2 VALUES (2, 20);
    INSERT INTO t_agg2 VALUES (3, 30);
    SELECT array_agg(val) FROM t_agg2;
}
expect {
    {10,20,30}
}

test array-agg-with-null {
    CREATE TABLE t_agg3 (id INTEGER PRIMARY KEY, val TEXT);
    INSERT INTO t_agg3 VALUES (1, 'a');
    INSERT INTO t_agg3 VALUES (2, NULL);
    INSERT INTO t_agg3 VALUES (3, 'c');
    SELECT array_agg(val) FROM t_agg3;
}
expect {
    {a,NULL,c}
}

test array-agg-single-row {
    CREATE TABLE t_agg4 (id INTEGER PRIMARY KEY, val TEXT);
    INSERT INTO t_agg4 VALUES (1, 'only');
    SELECT array_agg(val) FROM t_agg4;
}
expect {
    {only}
}

test array-agg-empty-table {
    CREATE TABLE t_agg5 (id INTEGER PRIMARY KEY, val TEXT);
    SELECT array_agg(val) FROM t_agg5;
}
expect {
}

test array-agg-group-by {
    CREATE TABLE t_agg6 (grp TEXT, val TEXT);
    INSERT INTO t_agg6 VALUES ('x', 'a');
    INSERT INTO t_agg6 VALUES ('x', 'b');
    INSERT INTO t_agg6 VALUES ('y', 'c');
    INSERT INTO t_agg6 VALUES ('y', 'd');
    INSERT INTO t_agg6 VALUES ('y', 'e');
    SELECT grp, array_agg(val) FROM t_agg6 GROUP BY grp ORDER BY grp;
}
expect {
    x|{a,b}
    y|{c,d,e}
}

test array-agg-with-order-by {
    CREATE TABLE t_agg7 (id INTEGER PRIMARY KEY, val TEXT);
    INSERT INTO t_agg7 VALUES (3, 'c');
    INSERT INTO t_agg7 VALUES (1, 'a');
    INSERT INTO t_agg7 VALUES (2, 'b');
    SELECT array_agg(val) FROM (SELECT val FROM t_agg7 ORDER BY id);
}
expect {
    {a,b,c}
}

test array-agg-with-array-length {
    CREATE TABLE t_agg8 (id INTEGER PRIMARY KEY, val TEXT);
    INSERT INTO t_agg8 VALUES (1, 'a');
    INSERT INTO t_agg8 VALUES (2, 'b');
    INSERT INTO t_agg8 VALUES (3, 'c');
    SELECT array_length(array_agg(val)) FROM t_agg8;
}
expect {
    3
}

# ============================================================
# array_overlap tests
# ============================================================

test array-overlap-found {
    SELECT array_overlap('{1,2,3}', '{3,4,5}');
}
expect {
    1
}

test array-overlap-not-found {
    SELECT array_overlap('{1,2,3}', '{4,5,6}');
}
expect {
    0
}

test array-overlap-empty-left {
    SELECT array_overlap('{}', '{1,2,3}');
}
expect {
    0
}

test array-overlap-empty-right {
    SELECT array_overlap('{1,2,3}', '{}');
}
expect {
    0
}

test array-overlap-both-empty {
    SELECT array_overlap('{}', '{}');
}
expect {
    0
}

test array-overlap-identical {
    SELECT array_overlap('{1,2,3}', '{1,2,3}');
}
expect {
    1
}

