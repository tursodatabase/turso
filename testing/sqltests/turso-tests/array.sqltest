test dc1-set-element-negative-index-preserves-array {
    CREATE TABLE t_dc1 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO t_dc1 VALUES (1, '{10,20,30}');
    UPDATE t_dc1 SET vals[-1] = 99 WHERE id = 1;
    SELECT vals FROM t_dc1;
}
expect {
    {10,20,30}
}

test dc2-empty-blob-rejected-for-any-array {
    CREATE TABLE t_dc2 (id INTEGER PRIMARY KEY, data any[]) STRICT;
    INSERT INTO t_dc2 VALUES (1, X'');
}
expect error {
    cannot store non-array value
}

test dc4-array-remove-null-returns-null {
    SELECT array_remove(NULL, 1);
}
expect {
}

test dc4-array-slice-null-returns-null {
    SELECT array_slice(NULL, 1, 2);
}
expect {
}

test dc4-array-cat-null-returns-null {
    SELECT array_cat(NULL, NULL);
}
expect {
}

test multidim-integer-2d-basic {
    CREATE TABLE md1 (id INTEGER PRIMARY KEY, matrix INTEGER[][]) STRICT;
    INSERT INTO md1 VALUES (1, ARRAY[ARRAY[1,2], ARRAY[3,4]]);
    SELECT array_length(matrix) FROM md1 WHERE id = 1;
    SELECT matrix[1] FROM md1 WHERE id = 1;
    SELECT matrix[1][2] FROM md1 WHERE id = 1;
    SELECT matrix[2][1] FROM md1 WHERE id = 1;
    SELECT array_length(matrix[1]) FROM md1 WHERE id = 1;
}
expect {
    2
    {1,2}
    2
    3
    2
}

test multidim-3d-create-and-access {
    CREATE TABLE md3 (id INTEGER PRIMARY KEY, cube INTEGER[][][]) STRICT;
    INSERT INTO md3 VALUES (1, ARRAY[ARRAY[ARRAY[1,2], ARRAY[3,4]], ARRAY[ARRAY[5,6], ARRAY[7,8]]]);
    SELECT cube[2][1][2] FROM md3 WHERE id = 1;
}
expect {
    6
}

test multidim-text-2d {
    CREATE TABLE md_text (id INTEGER PRIMARY KEY, grid TEXT[][]) STRICT;
    INSERT INTO md_text VALUES (1, ARRAY[ARRAY['a','b'], ARRAY['c','d']]);
    SELECT grid[1][2] FROM md_text WHERE id = 1;
    SELECT grid[2][1] FROM md_text WHERE id = 1;
}
expect {
    b
    c
}

test array-compare-equal {
