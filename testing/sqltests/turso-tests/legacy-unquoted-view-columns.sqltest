@database database/testing_legacy_unquoted_view_columns.db readonly

# Backwards compatibility for databases written by older Turso versions.
#
# Before view column lists were re-serialized with proper identifier quoting,
# `CREATE VIEW v([col one]) AS SELECT a FROM t` stored
# `CREATE VIEW v (col one) AS SELECT a FROM t` (unquoted) in sqlite_master.
# The fixture was generated by running exactly that CREATE VIEW on a pre-fix
# tursodb build. Real SQLite refuses to open such a
# database at all ("malformed database schema"), which is also why this test
# is Turso-only. Turso must keep tolerating the row: the database opens, the
# rest of the schema works, and only the broken view itself is unavailable.
# The cleanup path (DROP VIEW removes the orphaned row) is exercised in
# tests/integration/query_processing/test_views.rs since it needs a writable
# copy of the fixture.

test legacy-broken-view-table-still-readable {
    SELECT a FROM t;
}
expect {
    42
}

test legacy-broken-view-is-unavailable {
    SELECT * FROM v;
}
expect error {
    could not be loaded
}

test legacy-broken-view-row-still-listed-in-schema {
    SELECT name, type FROM sqlite_master ORDER BY name;
}
expect {
    t|table
    v|view
}
