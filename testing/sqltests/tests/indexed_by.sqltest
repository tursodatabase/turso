@database :memory:

# INDEXED BY basic test: SELECT with matching WHERE clause
test indexed-by-select-basic {
    CREATE TABLE t1(a, b, c);
    CREATE INDEX i1 ON t1(a);
    CREATE INDEX i2 ON t1(b);
    INSERT INTO t1 VALUES(1, 2, 3);
    INSERT INTO t1 VALUES(4, 5, 6);
    SELECT * FROM t1 INDEXED BY i1 WHERE a = 1;
}
expect {
    1|2|3
}

# INDEXED BY with no WHERE clause (index scan, not seek)
test indexed-by-no-where {
    CREATE TABLE t2(a, b);
    CREATE INDEX i2a ON t2(a);
    INSERT INTO t2 VALUES(1, 2);
    INSERT INTO t2 VALUES(3, 4);
    SELECT * FROM t2 INDEXED BY i2a;
}
expect {
    1|2
    3|4
}

# NOT INDEXED forces table scan
test not-indexed-select {
    CREATE TABLE t3(a, b);
    CREATE INDEX i3a ON t3(a);
    INSERT INTO t3 VALUES(1, 2);
    INSERT INTO t3 VALUES(3, 4);
    SELECT * FROM t3 NOT INDEXED WHERE a = 1;
}
expect {
    1|2
}

# INDEXED BY with nonexistent index
test indexed-by-nonexistent {
    CREATE TABLE t4(a);
    SELECT * FROM t4 INDEXED BY i_nonexistent WHERE a = 1;
}
expect error {
    no such index: i_nonexistent
}

# INDEXED BY with index from wrong table
test indexed-by-wrong-table {
    CREATE TABLE t5(a);
    CREATE TABLE t6(b);
    CREATE INDEX i6 ON t6(b);
    SELECT * FROM t5 INDEXED BY i6 WHERE a = 1;
}
expect error {
    no such index: i6
}

# INDEXED BY in DELETE
test indexed-by-delete {
    CREATE TABLE t7(a, b);
    CREATE INDEX i7 ON t7(a);
    INSERT INTO t7 VALUES(1, 2);
    INSERT INTO t7 VALUES(3, 4);
    DELETE FROM t7 INDEXED BY i7 WHERE a = 1;
    SELECT * FROM t7;
}
expect {
    3|4
}

# INDEXED BY in UPDATE
test indexed-by-update {
    CREATE TABLE t8(a, b);
    CREATE INDEX i8 ON t8(a);
    INSERT INTO t8 VALUES(1, 2);
    INSERT INTO t8 VALUES(3, 4);
    UPDATE t8 INDEXED BY i8 SET b = 99 WHERE a = 1;
    SELECT * FROM t8;
}
expect {
    1|99
    3|4
}

# INDEXED BY in JOIN
test indexed-by-join {
    CREATE TABLE t9(a, b);
    CREATE TABLE t10(c, d);
    CREATE INDEX i9 ON t9(a);
    CREATE INDEX i10 ON t10(c);
    INSERT INTO t9 VALUES(1, 2);
    INSERT INTO t10 VALUES(1, 3);
    SELECT * FROM t9 INDEXED BY i9 JOIN t10 INDEXED BY i10 ON t9.a = t10.c;
}
expect {
    1|2|1|3
}

# NOT INDEXED in DELETE
test not-indexed-delete {
    CREATE TABLE t11(a, b);
    CREATE INDEX i11 ON t11(a);
    INSERT INTO t11 VALUES(1, 2);
    INSERT INTO t11 VALUES(3, 4);
    DELETE FROM t11 NOT INDEXED WHERE a = 1;
    SELECT * FROM t11;
}
expect {
    3|4
}

# NOT INDEXED in UPDATE
test not-indexed-update {
    CREATE TABLE t12(a, b);
    CREATE INDEX i12 ON t12(a);
    INSERT INTO t12 VALUES(1, 2);
    INSERT INTO t12 VALUES(3, 4);
    UPDATE t12 NOT INDEXED SET b = 99 WHERE a = 1;
    SELECT * FROM t12;
}
expect {
    1|99
    3|4
}

# INDEXED BY with alias
test indexed-by-with-alias {
    CREATE TABLE t13(a, b);
    CREATE INDEX i13 ON t13(a);
    INSERT INTO t13 VALUES(1, 2);
    SELECT x.a, x.b FROM t13 AS x INDEXED BY i13 WHERE x.a = 1;
}
expect {
    1|2
}

# INDEXED BY with multiple rows matching
test indexed-by-multiple-rows {
    CREATE TABLE t14(a, b);
    CREATE INDEX i14 ON t14(a);
    INSERT INTO t14 VALUES(1, 10);
    INSERT INTO t14 VALUES(1, 20);
    INSERT INTO t14 VALUES(2, 30);
    SELECT * FROM t14 INDEXED BY i14 WHERE a = 1;
}
expect {
    1|10
    1|20
}
