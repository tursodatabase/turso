@database :temp:

# Adapted from SQLite fkey2.test fkey2-6.1: VACUUM must preserve foreign-key
# schemas whose child table is created before the parent table.
test foreign-keys-vacuum-preserves-schema {
    CREATE TABLE t1(a REFERENCES t2(c), b);
    CREATE TABLE t2(c UNIQUE, b);
    INSERT INTO t2 VALUES(1, 2);
    INSERT INTO t1 VALUES(1, 2);
    VACUUM;
    SELECT * FROM t1;
    SELECT * FROM t2;
    PRAGMA integrity_check;
}
expect {
    1|2
    1|2
    ok
}

# Adapted from SQLite without_rowid3.test: VACUUM must preserve a foreign-key
# schema where the child table is created before the parent table.
test foreign-keys-vacuum-preserves-child-before-parent {
    CREATE TABLE vacuum_fk_child(a REFERENCES vacuum_fk_parent(c), b);
    CREATE TABLE vacuum_fk_parent(c UNIQUE, b);
    INSERT INTO vacuum_fk_parent VALUES(1, 2);
    INSERT INTO vacuum_fk_child VALUES(1, 2);
    VACUUM;
    SELECT * FROM vacuum_fk_child;
    SELECT * FROM vacuum_fk_parent;
    PRAGMA integrity_check;
}
expect {
    1|2
    1|2
    ok
}
