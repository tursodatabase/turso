# Adapted from SQLite pagesize.test: VACUUM after rollback/delete preserves a
# non-default page size while compacting overflow-heavy content.
test pagesize-vacuum-nondefault-page-size-after-rollback-and-delete {
    PRAGMA page_size = 4096;
    CREATE TABLE vacuum_pagesize_workload(x);
    INSERT INTO vacuum_pagesize_workload VALUES(randomblob(9000));
    INSERT INTO vacuum_pagesize_workload SELECT randomblob(9000) FROM vacuum_pagesize_workload;
    INSERT INTO vacuum_pagesize_workload SELECT randomblob(9000) FROM vacuum_pagesize_workload;
    INSERT INTO vacuum_pagesize_workload SELECT randomblob(9000) FROM vacuum_pagesize_workload;
    INSERT INTO vacuum_pagesize_workload SELECT randomblob(9000) FROM vacuum_pagesize_workload;
    INSERT INTO vacuum_pagesize_workload SELECT randomblob(9000) FROM vacuum_pagesize_workload;
    INSERT INTO vacuum_pagesize_workload SELECT randomblob(9000) FROM vacuum_pagesize_workload;
    BEGIN;
    DELETE FROM vacuum_pagesize_workload WHERE rowid % 5 != 0;
    SELECT count(*) FROM vacuum_pagesize_workload;
    ROLLBACK;
    SELECT count(*) FROM vacuum_pagesize_workload;
    DELETE FROM vacuum_pagesize_workload WHERE rowid % 5 != 0;
    VACUUM;
    SELECT count(*) FROM vacuum_pagesize_workload;
    PRAGMA page_size;
    PRAGMA integrity_check;
}
expect {
    12
    64
    12
    4096
    ok
}
