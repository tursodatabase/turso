@database :temp:

# Adapted from SQLite pagesize.test: an initial page size selected before
# database creation is preserved by VACUUM.
test pagesize-vacuum-preserves-initial-page-size {
    PRAGMA page_size = 1024;
    CREATE TABLE vacuum_page_size_keep(x);
    INSERT INTO vacuum_page_size_keep VALUES(randomblob(1500));
    VACUUM;
    PRAGMA page_size;
    SELECT count(*), sum(length(x)) FROM vacuum_page_size_keep;
    PRAGMA integrity_check;
}
expect {
    1024
    1|1500
    ok
}

# Adapted from SQLite pagesize.test: initial page sizes selected before
# database creation are preserved by VACUUM.
test pagesize-vacuum-preserves-initial-page-size-512 {
    PRAGMA page_size = 512;
    CREATE TABLE vacuum_page_size_512(x);
    INSERT INTO vacuum_page_size_512 VALUES(randomblob(700));
    VACUUM;
    PRAGMA page_size;
    SELECT count(*), sum(length(x)) FROM vacuum_page_size_512;
    PRAGMA integrity_check;
}
expect {
    512
    1|700
    ok
}

test pagesize-vacuum-preserves-initial-page-size-2048 {
    PRAGMA page_size = 2048;
    CREATE TABLE vacuum_page_size_2048(x);
