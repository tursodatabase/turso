@database :memory:

@cross-check-integrity
test savepoint-basic-release {
    CREATE TABLE t(x);
    SAVEPOINT sp1;
    INSERT INTO t VALUES (1);
    RELEASE SAVEPOINT sp1;
    SELECT x FROM t;
}
expect {
    1
}

@cross-check-integrity
test savepoint-release-inside-begin-does-not-commit {
    CREATE TABLE t(x);
    BEGIN;
    SAVEPOINT sp1;
    INSERT INTO t VALUES (1);
    RELEASE sp1;
    ROLLBACK;
    SELECT x FROM t;
}
expect {
}

@cross-check-integrity
test savepoint-rollback-reverts-temp-table-changes {
    CREATE TABLE main_t(x INTEGER);
    CREATE TEMP TABLE temp_t(x INTEGER);
    BEGIN;
    INSERT INTO main_t VALUES (1);
    SAVEPOINT sp1;
    INSERT INTO temp.temp_t VALUES (2);
    ROLLBACK TO sp1;
    RELEASE sp1;
    COMMIT;
    SELECT x FROM main_t ORDER BY x;
    SELECT x FROM temp.temp_t ORDER BY x;
}
expect {
    1
}

@cross-check-integrity
test savepoint-nested-release-outer {
    CREATE TABLE t(x);
    SAVEPOINT outer_sp;
    INSERT INTO t VALUES (1);
    SAVEPOINT inner_sp;
    INSERT INTO t VALUES (2);
    RELEASE outer_sp;
    SELECT x FROM t ORDER BY x;
}
expect {
    1
    2
}

@cross-check-integrity
test savepoint-duplicate-name-shadowing {
    CREATE TABLE t(x);
    SAVEPOINT sp;
    INSERT INTO t VALUES (1);
    SAVEPOINT sp;
    INSERT INTO t VALUES (2);
    ROLLBACK TO sp;
    INSERT INTO t VALUES (3);
    RELEASE sp;
    RELEASE sp;
    SELECT x FROM t ORDER BY x;
}
expect {
    1
    3
}

@cross-check-integrity
test savepoint-rollback-to-preserves-savepoint {
    CREATE TABLE t(x);
    SAVEPOINT sp;
    INSERT INTO t VALUES (1);
    ROLLBACK TO SAVEPOINT sp;
    INSERT INTO t VALUES (2);
    RELEASE sp;
    SELECT x FROM t ORDER BY x;
}
expect {
    2
}

test savepoint-release-missing-errors {
    SAVEPOINT sp;
    RELEASE missing;
}
expect error {
}

test savepoint-rollback-missing-errors {
    SAVEPOINT sp;
    ROLLBACK TO missing;
}
expect error {
}

@cross-check-integrity
test savepoint-rollback-to-can-be-repeated {
    CREATE TABLE t(x);
    SAVEPOINT sp;
    INSERT INTO t VALUES (1);
    ROLLBACK TO sp;
    INSERT INTO t VALUES (2);
    ROLLBACK TO sp;
    INSERT INTO t VALUES (3);
    RELEASE sp;
    SELECT x FROM t;
}
expect {
    3
}

@cross-check-integrity
test savepoint-case-insensitive-name-resolution {
    CREATE TABLE t(x);
    SAVEPOINT SpCase;
    INSERT INTO t VALUES (1);
    ROLLBACK TO spcase;
    INSERT INTO t VALUES (2);
    RELEASE SPCASE;
    SELECT x FROM t;
}
expect {
    2
}

@cross-check-integrity
test savepoint-rollback-restores-uncommitted-schema {
    BEGIN;
    CREATE TABLE keep_t(x);
    SAVEPOINT sp;
    CREATE TABLE rolled_back_t(y);
    ROLLBACK TO sp;
    SELECT name FROM sqlite_schema WHERE type = 'table' ORDER BY name;
    INSERT INTO keep_t VALUES (1);
    SELECT x FROM keep_t;
    ROLLBACK;
}
expect {
    keep_t
    1
}

@cross-check-integrity
test savepoint-release-outer-removes-inner {
    CREATE TABLE t(x);
    SAVEPOINT outer;
    INSERT INTO t VALUES (1);
    SAVEPOINT inner;
    INSERT INTO t VALUES (2);
    RELEASE outer;
    ROLLBACK TO inner;
}
expect error {
    no such savepoint
}

@cross-check-integrity
test savepoint-rollback-to-top-level-then-release {
    CREATE TABLE t(x);
    SAVEPOINT root;
    INSERT INTO t VALUES (1);
    ROLLBACK TO root;
    RELEASE root;
    SELECT x FROM t;
}
expect {
}

@cross-check-integrity
test savepoint-rollback-undoes-mixed-dml {
    CREATE TABLE t(id INTEGER PRIMARY KEY, v, tag);
    INSERT INTO t VALUES (1, 10, 'a');
    INSERT INTO t VALUES (2, 20, 'b');
    INSERT INTO t VALUES (3, 30, 'c');
    SAVEPOINT sp;
    UPDATE t SET v = v + 1 WHERE id IN (1, 2);
    DELETE FROM t WHERE id = 3;
    INSERT INTO t VALUES (4, 40, 'd');
    ROLLBACK TO sp;
    RELEASE sp;
    SELECT id, v, tag FROM t ORDER BY id;
}
expect {
    1|10|a
    2|20|b
    3|30|c
}

@cross-check-integrity
test savepoint-interleaved-duplicate-names {
    CREATE TABLE t(x);
    SAVEPOINT a;
    INSERT INTO t VALUES (1);
    SAVEPOINT b;
    INSERT INTO t VALUES (2);
    SAVEPOINT a;
    INSERT INTO t VALUES (3);
    RELEASE a;
    ROLLBACK TO b;
    RELEASE b;
    RELEASE a;
    SELECT x FROM t ORDER BY x;
}
expect {
    1
}

test savepoint-release-without-active-savepoint-errors {
    RELEASE SAVEPOINT missing;
}
expect error {
    no such savepoint
}

test savepoint-rollback-to-without-active-savepoint-errors {
    ROLLBACK TO SAVEPOINT missing;
}
expect error {
    no such savepoint
}

test savepoint-cleared-after-commit {
    SAVEPOINT s;
    COMMIT;
    RELEASE s;
}
expect error {
    no such savepoint
}

test savepoint-cleared-after-rollback {
    SAVEPOINT s;
    ROLLBACK;
    RELEASE s;
}
expect error {
    no such savepoint
}

@cross-check-integrity
test savepoint-rollback-to-restores-deferred-fk-counter {
    PRAGMA foreign_keys = ON;
    CREATE TABLE p(id INTEGER PRIMARY KEY);
    CREATE TABLE c(pid INTEGER REFERENCES p(id) DEFERRABLE INITIALLY DEFERRED);
    SAVEPOINT s;
    INSERT INTO c VALUES (1);
    ROLLBACK TO s;
    RELEASE s;
    SELECT count(*) FROM c;
}
expect {
    0
}

@cross-check-integrity
test savepoint-rollback-discards-post-savepoint-pages-without-losing-outer-row {
    CREATE TABLE t(id INTEGER PRIMARY KEY, v BLOB);
    BEGIN;
    INSERT INTO t VALUES (1, 'outer');
    SAVEPOINT s;
    INSERT INTO t VALUES (2, zeroblob(8000));
    ROLLBACK TO s;
    RELEASE s;
    COMMIT;
    SELECT id, v FROM t ORDER BY id;
}
expect {
    1|outer
}

@cross-check-integrity
test savepoint-release-root-with-deferred-fk-fails {
    PRAGMA foreign_keys = ON;
    CREATE TABLE p(id INTEGER PRIMARY KEY);
    CREATE TABLE c(pid INTEGER REFERENCES p(id) DEFERRABLE INITIALLY DEFERRED);
    SAVEPOINT s;
    INSERT INTO c VALUES (1);
    RELEASE s;
}
expect error {
    constraint failed
}

@cross-check-integrity
test savepoint-not-reusable-after-transaction-boundary {
    CREATE TABLE t(x);
    SAVEPOINT s;
    INSERT INTO t VALUES (1);
    COMMIT;
    BEGIN;
    INSERT INTO t VALUES (2);
    ROLLBACK TO s;
}
expect error {
    no such savepoint
}

# regression: ROLLBACK TO must restore the in-memory TEMP schema
# after the on-disk pages are rolled back. Previously the mirror call would
# undo the temp pages but the in-memory temp schema kept the DDL that no
# longer existed on disk.
@cross-check-integrity
test savepoint-rollback-to-removes-temp-ddl {
    CREATE TEMP TABLE sp_temp_sentinel(x);
    SAVEPOINT a;
    CREATE TEMP TABLE sp_temp_t(x);
    ROLLBACK TO a;
    SELECT name FROM temp.sqlite_schema WHERE type='table' ORDER BY name;
}
expect {
    sp_temp_sentinel
}

@cross-check-integrity
test savepoint-rollback-to-removes-temp-ddl-with-dml {
    CREATE TEMP TABLE sp_temp_keep(x);
    INSERT INTO sp_temp_keep VALUES(99);
    SAVEPOINT b;
    CREATE TEMP TABLE sp_temp_u(y);
    INSERT INTO sp_temp_u VALUES(1);
    ROLLBACK TO b;
    SELECT name FROM temp.sqlite_schema WHERE type='table' ORDER BY name;
    SELECT x FROM temp.sp_temp_keep;
}
expect {
    sp_temp_keep
    99
}

# Temp DDL created inside a savepoint must be unreachable after ROLLBACK TO
# (the whole point of the fix: in-memory schema must match on-disk state).
@cross-check-integrity
test savepoint-rollback-to-temp-table-unreachable {
    SAVEPOINT c;
    CREATE TEMP TABLE sp_temp_gone(z);
    ROLLBACK TO c;
    SELECT * FROM temp.sp_temp_gone;
}
expect error {
    no such table
}

# Regression: AUTOINCREMENT inserts inside a savepoint, rolled back, then
# followed by more inserts must not leave a stale page-cache entry that the
# next allocate_page would collide with (see issue #6354). The original
# panic was "Attempted to insert different page with same key" in
# core/storage/page_cache.rs after `cache.truncate(db_size)` failed to
# evict pinned/dirty pages allocated within the savepoint.
@cross-check-integrity
test savepoint-rollback-autoinc-then-insert {
    PRAGMA page_size = 512;
    PRAGMA cache_size = 2;
    PRAGMA cache_spill = ON;
    CREATE TABLE t(
        a INTEGER PRIMARY KEY AUTOINCREMENT,
        g INT  NOT NULL DEFAULT 0,
        v TEXT NOT NULL DEFAULT 'x'
    );
    CREATE INDEX t_g_v ON t(g, v);
    INSERT INTO t(g, v)
    SELECT value % 5, printf('%07d:', 0 + value) || hex(zeroblob(46))
    FROM generate_series(1, 833);
    SAVEPOINT s1;
    INSERT INTO t(g, v)
    SELECT value % 5, printf('%07d:', 833 + value) || hex(zeroblob(62))
    FROM generate_series(1, 200);
    ROLLBACK TO s1;
    RELEASE s1;
    INSERT INTO t(g, v)
    SELECT value % 5, printf('%07d:', 1033 + value) || hex(zeroblob(70))
    FROM generate_series(1, 92);
    SELECT max(a), count(*) FROM t;
}
expect {
    925|925
}

# Variant: nested savepoints with rollback at the inner level. Pages
# allocated by the inner savepoint must be evicted from cache so the
# outer savepoint can keep extending the table.
@cross-check-integrity
test savepoint-rollback-nested-inner-then-extend {
    PRAGMA cache_size = 2;
    PRAGMA cache_spill = ON;
    CREATE TABLE t(id INTEGER PRIMARY KEY AUTOINCREMENT, v TEXT);
    INSERT INTO t(v) SELECT hex(zeroblob(80)) FROM generate_series(1, 200);
    SAVEPOINT outer_sp;
    INSERT INTO t(v) SELECT hex(zeroblob(80)) FROM generate_series(1, 100);
    SAVEPOINT inner_sp;
    INSERT INTO t(v) SELECT hex(zeroblob(80)) FROM generate_series(1, 100);
    ROLLBACK TO inner_sp;
    RELEASE inner_sp;
    INSERT INTO t(v) SELECT hex(zeroblob(80)) FROM generate_series(1, 50);
    RELEASE outer_sp;
    SELECT max(id), count(*) FROM t;
}
expect {
    350|350
}

# Variant: multiple ROLLBACK TO/RELEASE cycles on the same savepoint
# exercise the truncate path repeatedly.
@cross-check-integrity
test savepoint-rollback-repeated-cycles {
    PRAGMA cache_size = 2;
    PRAGMA cache_spill = ON;
    CREATE TABLE t(id INTEGER PRIMARY KEY AUTOINCREMENT, v TEXT);
    INSERT INTO t(v) SELECT hex(zeroblob(80)) FROM generate_series(1, 100);
    SAVEPOINT s;
    INSERT INTO t(v) SELECT hex(zeroblob(80)) FROM generate_series(1, 50);
    ROLLBACK TO s;
    INSERT INTO t(v) SELECT hex(zeroblob(80)) FROM generate_series(1, 50);
    ROLLBACK TO s;
    INSERT INTO t(v) SELECT hex(zeroblob(80)) FROM generate_series(1, 30);
    RELEASE s;
    SELECT max(id), count(*) FROM t;
}
expect {
    130|130
}

# Variant: rollback an UPDATE that touched many pages (modifying existing
# rows, not allocating new ones). The pre-savepoint images must be restored
# from the subjournal without leaving a mismatched Arc<Page> in the cache.
@cross-check-integrity
test savepoint-rollback-update-then-reinsert {
    PRAGMA cache_size = 2;
    PRAGMA cache_spill = ON;
    CREATE TABLE t(id INTEGER PRIMARY KEY, v TEXT);
    INSERT INTO t(id, v)
    SELECT value, hex(zeroblob(60)) FROM generate_series(1, 400);
    SAVEPOINT s;
    UPDATE t SET v = hex(zeroblob(120));
    ROLLBACK TO s;
    RELEASE s;
    INSERT INTO t(id, v)
    SELECT 400 + value, hex(zeroblob(60)) FROM generate_series(1, 50);
    SELECT count(*) FROM t;
    SELECT length(v) FROM t WHERE id = 1;
}
expect {
    450
    120
}
