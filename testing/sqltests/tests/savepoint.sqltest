@database :memory:

@cross-check-integrity
test savepoint-basic-release {
    CREATE TABLE t(x);
    SAVEPOINT sp1;
    INSERT INTO t VALUES (1);
    RELEASE SAVEPOINT sp1;
    SELECT x FROM t;
}
expect {
    1
}

@cross-check-integrity
test savepoint-release-inside-begin-does-not-commit {
    CREATE TABLE t(x);
    BEGIN;
    SAVEPOINT sp1;
    INSERT INTO t VALUES (1);
    RELEASE sp1;
    ROLLBACK;
    SELECT x FROM t;
}
expect {
}

@cross-check-integrity
test savepoint-rollback-reverts-temp-table-changes {
    CREATE TABLE main_t(x INTEGER);
    CREATE TEMP TABLE temp_t(x INTEGER);
    BEGIN;
    INSERT INTO main_t VALUES (1);
    SAVEPOINT sp1;
    INSERT INTO temp.temp_t VALUES (2);
    ROLLBACK TO sp1;
    RELEASE sp1;
    COMMIT;
    SELECT x FROM main_t ORDER BY x;
    SELECT x FROM temp.temp_t ORDER BY x;
}
expect {
    1
}

@cross-check-integrity
test savepoint-nested-release-outer {
    CREATE TABLE t(x);
    SAVEPOINT outer_sp;
    INSERT INTO t VALUES (1);
    SAVEPOINT inner_sp;
    INSERT INTO t VALUES (2);
    RELEASE outer_sp;
    SELECT x FROM t ORDER BY x;
}
expect {
    1
    2
}

@cross-check-integrity
test savepoint-duplicate-name-shadowing {
    CREATE TABLE t(x);
    SAVEPOINT sp;
    INSERT INTO t VALUES (1);
    SAVEPOINT sp;
    INSERT INTO t VALUES (2);
    ROLLBACK TO sp;
    INSERT INTO t VALUES (3);
    RELEASE sp;
    RELEASE sp;
    SELECT x FROM t ORDER BY x;
}
expect {
    1
    3
}

@cross-check-integrity
test savepoint-rollback-to-preserves-savepoint {
    CREATE TABLE t(x);
    SAVEPOINT sp;
    INSERT INTO t VALUES (1);
    ROLLBACK TO SAVEPOINT sp;
    INSERT INTO t VALUES (2);
    RELEASE sp;
    SELECT x FROM t ORDER BY x;
}
expect {
    2
}

test savepoint-release-missing-errors {
    SAVEPOINT sp;
    RELEASE missing;
}
expect error {
}

test savepoint-rollback-missing-errors {
    SAVEPOINT sp;
    ROLLBACK TO missing;
}
expect error {
}

@cross-check-integrity
test savepoint-rollback-to-can-be-repeated {
    CREATE TABLE t(x);
    SAVEPOINT sp;
    INSERT INTO t VALUES (1);
    ROLLBACK TO sp;
    INSERT INTO t VALUES (2);
    ROLLBACK TO sp;
    INSERT INTO t VALUES (3);
    RELEASE sp;
    SELECT x FROM t;
}
expect {
    3
}

@cross-check-integrity
test savepoint-case-insensitive-name-resolution {
    CREATE TABLE t(x);
    SAVEPOINT SpCase;
    INSERT INTO t VALUES (1);
    ROLLBACK TO spcase;
    INSERT INTO t VALUES (2);
    RELEASE SPCASE;
    SELECT x FROM t;
}
expect {
    2
}

@cross-check-integrity
test savepoint-rollback-restores-uncommitted-schema {
    BEGIN;
    CREATE TABLE keep_t(x);
    SAVEPOINT sp;
    CREATE TABLE rolled_back_t(y);
    ROLLBACK TO sp;
    SELECT name FROM sqlite_schema WHERE type = 'table' ORDER BY name;
    INSERT INTO keep_t VALUES (1);
    SELECT x FROM keep_t;
    ROLLBACK;
}
expect {
    keep_t
    1
}

@cross-check-integrity
test savepoint-release-outer-removes-inner {
    CREATE TABLE t(x);
    SAVEPOINT outer;
    INSERT INTO t VALUES (1);
    SAVEPOINT inner;
    INSERT INTO t VALUES (2);
    RELEASE outer;
    ROLLBACK TO inner;
}
expect error {
    no such savepoint
}

@cross-check-integrity
test savepoint-rollback-to-top-level-then-release {
    CREATE TABLE t(x);
    SAVEPOINT root;
    INSERT INTO t VALUES (1);
    ROLLBACK TO root;
    RELEASE root;
    SELECT x FROM t;
}
expect {
}

@cross-check-integrity
test savepoint-rollback-undoes-mixed-dml {
    CREATE TABLE t(id INTEGER PRIMARY KEY, v, tag);
    INSERT INTO t VALUES (1, 10, 'a');
    INSERT INTO t VALUES (2, 20, 'b');
    INSERT INTO t VALUES (3, 30, 'c');
    SAVEPOINT sp;
    UPDATE t SET v = v + 1 WHERE id IN (1, 2);
    DELETE FROM t WHERE id = 3;
    INSERT INTO t VALUES (4, 40, 'd');
    ROLLBACK TO sp;
    RELEASE sp;
    SELECT id, v, tag FROM t ORDER BY id;
}
expect {
    1|10|a
    2|20|b
    3|30|c
}

@cross-check-integrity
test savepoint-interleaved-duplicate-names {
    CREATE TABLE t(x);
    SAVEPOINT a;
    INSERT INTO t VALUES (1);
    SAVEPOINT b;
    INSERT INTO t VALUES (2);
    SAVEPOINT a;
    INSERT INTO t VALUES (3);
    RELEASE a;
    ROLLBACK TO b;
    RELEASE b;
    RELEASE a;
    SELECT x FROM t ORDER BY x;
}
expect {
    1
}

test savepoint-release-without-active-savepoint-errors {
    RELEASE SAVEPOINT missing;
}
expect error {
    no such savepoint
}

test savepoint-rollback-to-without-active-savepoint-errors {
    ROLLBACK TO SAVEPOINT missing;
}
expect error {
    no such savepoint
}

test savepoint-cleared-after-commit {
    SAVEPOINT s;
    COMMIT;
    RELEASE s;
}
expect error {
    no such savepoint
}

test savepoint-cleared-after-rollback {
    SAVEPOINT s;
    ROLLBACK;
    RELEASE s;
}
expect error {
    no such savepoint
}

@cross-check-integrity
test savepoint-rollback-to-restores-deferred-fk-counter {
    PRAGMA foreign_keys = ON;
    CREATE TABLE p(id INTEGER PRIMARY KEY);
    CREATE TABLE c(pid INTEGER REFERENCES p(id) DEFERRABLE INITIALLY DEFERRED);
    SAVEPOINT s;
    INSERT INTO c VALUES (1);
    ROLLBACK TO s;
    RELEASE s;
    SELECT count(*) FROM c;
}
expect {
    0
}

@cross-check-integrity
test savepoint-rollback-discards-post-savepoint-pages-without-losing-outer-row {
    CREATE TABLE t(id INTEGER PRIMARY KEY, v BLOB);
    BEGIN;
    INSERT INTO t VALUES (1, 'outer');
    SAVEPOINT s;
    INSERT INTO t VALUES (2, zeroblob(8000));
    ROLLBACK TO s;
    RELEASE s;
    COMMIT;
    SELECT id, v FROM t ORDER BY id;
}
expect {
    1|outer
}

@cross-check-integrity
test savepoint-release-root-with-deferred-fk-fails {
    PRAGMA foreign_keys = ON;
    CREATE TABLE p(id INTEGER PRIMARY KEY);
    CREATE TABLE c(pid INTEGER REFERENCES p(id) DEFERRABLE INITIALLY DEFERRED);
    SAVEPOINT s;
    INSERT INTO c VALUES (1);
    RELEASE s;
}
expect error {
    constraint failed
}

@cross-check-integrity
test savepoint-not-reusable-after-transaction-boundary {
    CREATE TABLE t(x);
    SAVEPOINT s;
    INSERT INTO t VALUES (1);
    COMMIT;
    BEGIN;
    INSERT INTO t VALUES (2);
    ROLLBACK TO s;
}
expect error {
    no such savepoint
}

# regression: ROLLBACK TO must restore the in-memory TEMP schema
# after the on-disk pages are rolled back. Previously the mirror call would
# undo the temp pages but the in-memory temp schema kept the DDL that no
# longer existed on disk.
@cross-check-integrity
test savepoint-rollback-to-removes-temp-ddl {
    CREATE TEMP TABLE sp_temp_sentinel(x);
    SAVEPOINT a;
    CREATE TEMP TABLE sp_temp_t(x);
    ROLLBACK TO a;
    SELECT name FROM temp.sqlite_schema WHERE type='table' ORDER BY name;
}
expect {
    sp_temp_sentinel
}

@cross-check-integrity
test savepoint-rollback-to-removes-temp-ddl-with-dml {
    CREATE TEMP TABLE sp_temp_keep(x);
    INSERT INTO sp_temp_keep VALUES(99);
    SAVEPOINT b;
    CREATE TEMP TABLE sp_temp_u(y);
    INSERT INTO sp_temp_u VALUES(1);
    ROLLBACK TO b;
    SELECT name FROM temp.sqlite_schema WHERE type='table' ORDER BY name;
    SELECT x FROM temp.sp_temp_keep;
}
expect {
    sp_temp_keep
    99
}

# Temp DDL created inside a savepoint must be unreachable after ROLLBACK TO
# (the whole point of the fix: in-memory schema must match on-disk state).
@cross-check-integrity
test savepoint-rollback-to-temp-table-unreachable {
    SAVEPOINT c;
    CREATE TEMP TABLE sp_temp_gone(z);
    ROLLBACK TO c;
    SELECT * FROM temp.sp_temp_gone;
}
expect error {
    no such table
}

# Regression test for #6357: indexed lookups after rolling back a savepoint that
# performed a mass DELETE/INSERT against an indexed table previously panicked in
# the b-tree seek path (cell pointer index OOB). The post-rollback seek must
# return the pre-savepoint contents unchanged.
@cross-check-integrity
test savepoint-rollback-mass-dml-indexed-seek-issue-6357 {
    CREATE TABLE t6357(a INTEGER PRIMARY KEY, b TEXT UNIQUE, c TEXT);
    CREATE INDEX i6357_c_b ON t6357(c, b);
    INSERT INTO t6357
        SELECT value,
               printf('sv_%05d', value),
               printf('sc_%05d', value)
        FROM generate_series(1, 200);
    SAVEPOINT s;
    DELETE FROM t6357 WHERE a BETWEEN 50 AND 150;
    INSERT INTO t6357
        SELECT value + 9000,
               printf('sv_new_%05d', value),
               printf('sc_new_%05d', value)
        FROM generate_series(1, 60);
    ROLLBACK TO s;
    RELEASE s;
    SELECT count(*) FROM t6357 INDEXED BY i6357_c_b WHERE c >= 'sc_';
    SELECT a, b FROM t6357 INDEXED BY i6357_c_b
        WHERE c >= 'sc_00099' AND c < 'sc_00102'
        ORDER BY c, b;
}
expect {
    200
    99|sv_00099
    100|sv_00100
    101|sv_00101
}

# Repeat the mass DML / rollback cycle multiple times to make sure the index
# b-tree state stays consistent across savepoints.
@cross-check-integrity
test savepoint-rollback-mass-dml-indexed-seek-repeated {
    CREATE TABLE t_rep(a INTEGER PRIMARY KEY, b TEXT UNIQUE);
    CREATE INDEX i_rep_b ON t_rep(b);
    INSERT INTO t_rep
        SELECT value, printf('row_%05d', value) FROM generate_series(1, 100);

    SAVEPOINT one;
    DELETE FROM t_rep WHERE a > 25;
    ROLLBACK TO one;
    RELEASE one;

    SAVEPOINT two;
    DELETE FROM t_rep WHERE a > 25;
    ROLLBACK TO two;
    RELEASE two;

    SELECT count(*) FROM t_rep INDEXED BY i_rep_b WHERE b >= 'row_';
    SELECT a FROM t_rep INDEXED BY i_rep_b WHERE b = 'row_00050';
}
expect {
    100
    50
}

# Nested savepoints: rolling back the inner savepoint must leave the outer
# savepoint's modifications intact and the index in a consistent state.
@cross-check-integrity
test savepoint-nested-rollback-inner-indexed-seek {
    CREATE TABLE t_nested(a INTEGER PRIMARY KEY, b TEXT);
    CREATE INDEX i_nested_b ON t_nested(b);
    INSERT INTO t_nested VALUES (1, 'one'), (2, 'two'), (3, 'three');

    SAVEPOINT outer_sp;
    INSERT INTO t_nested VALUES (4, 'four');

    SAVEPOINT inner_sp;
    DELETE FROM t_nested WHERE a >= 2;
    INSERT INTO t_nested VALUES (10, 'ten'), (11, 'eleven');
    ROLLBACK TO inner_sp;
    RELEASE inner_sp;

    SELECT a, b FROM t_nested INDEXED BY i_nested_b ORDER BY b;
}
expect {
    4|four
    1|one
    3|three
    2|two
}
