@database :temp:

# Adapted from SQLite alter3.test alter3-7.*: VACUUM works after ALTER TABLE
# ADD COLUMN updates the schema format.
test alter-table-vacuum-after-add-column {
    CREATE TABLE vacuum_alter_add(a, b, c);
    INSERT INTO vacuum_alter_add VALUES(1, 2, 3);
    ALTER TABLE vacuum_alter_add ADD d DEFAULT NULL;
    ALTER TABLE vacuum_alter_add ADD e DEFAULT 10;
    ALTER TABLE vacuum_alter_add ADD f DEFAULT NULL;
    INSERT INTO vacuum_alter_add(a, b, c) VALUES(4, 5, 6);
    VACUUM;
    SELECT * FROM vacuum_alter_add ORDER BY a;
    PRAGMA integrity_check;
}
expect {
    1|2|3||10|
    4|5|6||10|
    ok
}
