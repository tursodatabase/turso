---
source: parenthesized_from.sqltest
expression: |-
  SELECT a.x, b.y, c.z
      FROM (a INNER JOIN b ON a.x = b.ax)
      INNER JOIN c ON c.by_ = b.y;
info:
  statement_type: SELECT
  tables:
  - a.x
  - b
  - c
  - c.by_
  setup_blocks:
  - schema
  database: ':memory:'
---
