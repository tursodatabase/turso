---
source: aggregation.sqltest
expression: |-
  SELECT
          category,
          region,
          SUM(amount) as total_sales,
          COUNT(*) as num_transactions
      FROM
          sales
      GROUP BY
          category,
          region
      ORDER BY
          category,
          region;
info:
  statement_type: SELECT
  tables:
  - sales
  setup_blocks:
  - schema
  database: ':memory:'
---
