---
source: aggregation.sqltest
expression: |-
  SELECT
          category,
          COUNT(DISTINCT salesperson_id) as unique_salespeople,
          COUNT(DISTINCT region) as unique_regions
      FROM
          sales
      GROUP BY
          category
      ORDER BY
          unique_salespeople DESC;
info:
  statement_type: SELECT
  tables:
  - sales
  setup_blocks:
  - schema
  database: ':memory:'
