---
source: modifications.sqltest
expression: |-
  UPDATE products
      SET quantity = quantity + 1
      WHERE EXISTS (
          SELECT 1
          FROM products AS p2
          WHERE p2.id = products.id - 1
            AND p2.quantity < 5
      );
info:
  statement_type: UPDATE
  tables:
  - products
  setup_blocks:
  - schema
  database: ':memory:'
