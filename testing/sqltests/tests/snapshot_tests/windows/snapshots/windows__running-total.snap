---
source: windows.sqltest
expression: |-
  SELECT
          sale_id,
          emp_id,
          sale_date,
          amount,
          SUM(amount) OVER (ORDER BY sale_date) AS running_total,
          SUM(amount) OVER (
              PARTITION BY emp_id
              ORDER BY sale_date
          ) AS emp_running_total
      FROM sales;
info:
  statement_type: SELECT
  tables:
  - sales
  setup_blocks:
  - schema
  database: ':memory:'
