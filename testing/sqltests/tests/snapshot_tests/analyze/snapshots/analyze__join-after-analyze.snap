---
source: analyze.sqltest
expression: |-
  SELECT c.name, p.amount
      FROM customers c
      JOIN purchases p ON c.id = p.customer_id
      WHERE c.id = 2;
info:
  statement_type: SELECT
  tables:
  - c.id
  - customers
  - purchases
  setup_blocks:
  - join_tables
  database: ':memory:'
---
QUERY PLAN
|--SEARCH c USING INTEGER PRIMARY KEY (rowid=?)
`--SEARCH p USING INDEX ephemeral_purchases_t2 (customer_id=?)

