---
source: joins.sqltest
expression: |-
  SELECT h.order_id, i.product, r.reason
      FROM h_orders h
      JOIN h_items i ON h.customer_name = i.order_name
      JOIN h_returns r ON h.customer_name = r.order_name;
info:
  statement_type: SELECT
  tables:
  - h.customer_name
  - h_items
  - h_orders
  - h_returns
  setup_blocks:
  - hash_schema
  database: ':memory:'
---
