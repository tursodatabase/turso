---
source: joins.sqltest
expression: |-
  SELECT h.customer_name, count(i.item_id) as item_count
      FROM h_orders h
      LEFT JOIN h_items i ON h.customer_name = i.order_name
      GROUP BY h.customer_name
      ORDER BY h.customer_name;
info:
  statement_type: SELECT
  tables:
  - h.customer_name
  - h_items
  - h_orders
  setup_blocks:
  - hash_schema
  database: ':memory:'
---
