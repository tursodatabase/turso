@database :memory:

# SIMPLE SMOKE TESTS THAT DO NOT DEPEND ON SPECIFIC DATABASE ROWS
test collate_nocase {
    SELECT 'hat' == 'hAt' COLLATE NOCASE;
}
expect {
    1
}

test collate_binary_1 {
    SELECT 'hat' == 'hAt' COLLATE BINARY;
}
expect {
    0
}

test collate_binary_2 {
    SELECT 'hat' == 'hat' COLLATE BINARY;
}
expect {
    1
}

test collate_rtrim_1 {
    SELECT 'hat' == 'hAt ' COLLATE RTRIM;
}
expect {
    0
}

test collate_rtrim_2 {
    SELECT 'hat' == 'hat ' COLLATE RTRIM;
}
expect {
    1
}

test collate_rtrim_3 {
    SELECT 'hat' == ' hAt ' COLLATE RTRIM;
}
expect {
    0
}

test collate_rtrim_4 {
    SELECT 'hat' == ' hat ' COLLATE RTRIM;
}
expect {
    0
}

test collate_left_precedence {
    SELECT 'hat' COLLATE BINARY == 'hAt' COLLATE NOCASE;
}
expect {
    0
}

test collate_left_precedence_2 {
    SELECT 'hat' COLLATE NOCASE == 'hAt' COLLATE BINARY;
}
expect {
    1
}



@cross-check-integrity
test collate_unique_constraint {
    CREATE TABLE t (a TEXT COLLATE NOCASE PRIMARY KEY);
    INSERT INTO t VALUES ('lol'), ('LOL'), ('lOl');
}
expect error {
}

@cross-check-integrity
test collate_unique_constraint-2 {
    CREATE TABLE t (a TEXT COLLATE NOCASE PRIMARY KEY);
    INSERT INTO t VALUES ('lol'), ('LOL'), ('lOl');
}
expect error {
}

@cross-check-integrity
test collate_aggregation_default_binary {
    create table fruits(name collate binary);
    insert into fruits(name) values ('Apple') ,('banana') ,('CHERRY');
    select max(name) from fruits;
}
expect {
    banana
}

@cross-check-integrity
test collate_aggregation_default_nocase {
    create table fruits(name collate nocase);
    insert into fruits(name) values ('Apple') ,('banana') ,('CHERRY');
    select max(name) from fruits;
}
expect {
    CHERRY
}

@cross-check-integrity
test collate_aggregation_explicit_binary {
    create table fruits(name collate nocase);
    insert into fruits(name) values ('Apple') ,('banana') ,('CHERRY');
    select max(name collate binary) from fruits;
}
expect {
    banana
}

@cross-check-integrity
test collate_aggregation_explicit_nocase {
    create table fruits(name collate binary);
    insert into fruits(name) values ('Apple') ,('banana') ,('CHERRY');
    select max(name collate nocase) from fruits;
}
expect {
    CHERRY
}

@cross-check-integrity
test collate_grouped_aggregation_default_binary {
    create table fruits(name collate binary, category text);
    insert into fruits(name, category) values ('Apple', 'A'), ('banana', 'A'), ('CHERRY', 'B'), ('blueberry', 'B');
    select max(name) from fruits group by category;
}
expect {
    banana
    blueberry
}

@cross-check-integrity
test collate_grouped_aggregation_default_nocase {
    create table fruits(name collate nocase, category text);
    insert into fruits(name, category) values ('Apple', 'A'), ('banana', 'A'), ('CHERRY', 'B'), ('blueberry', 'B');
    select max(name) from fruits group by category;
}
expect {
    banana
    CHERRY
}

@cross-check-integrity
test collate_grouped_aggregation_explicit_binary {
    create table fruits(name collate nocase, category text);
    insert into fruits(name, category) values ('Apple', 'A'), ('banana', 'A'), ('CHERRY', 'B'), ('blueberry', 'B');
    select max(name collate binary) from fruits group by category;
}
expect {
    banana
    blueberry
}

@cross-check-integrity
test collate_groupped_aggregation_explicit_nocase {
    create table fruits(name collate binary, category text);
    insert into fruits(name, category) values ('Apple', 'A'), ('banana', 'A'), ('CHERRY', 'B'), ('blueberry', 'B');
    select max(name collate nocase) from fruits group by category;
}
expect {
    banana
    CHERRY
}

@cross-check-integrity
test collate_join_nocase {
    CREATE TABLE a(s TEXT);
    CREATE TABLE b(s TEXT);
    INSERT INTO a VALUES ('A');
    INSERT INTO b VALUES ('a');
    SELECT a.s, b.s FROM a JOIN b ON a.s COLLATE NOCASE = b.s;
}
expect {
    A|a
}

# Hash join with COLLATE NOCASE column: ORDER BY can change which table is used
# as the hash build table. The collation must be determined from both sides of
# the comparison, not just the build side, to avoid case-sensitive hashing when
# the join semantics require case-insensitive matching.
@cross-check-integrity
test collate_hash_join_nocase_column_with_order_by {
    CREATE TABLE t1(id INTEGER PRIMARY KEY, name TEXT COLLATE NOCASE);
    CREATE TABLE t2(id INTEGER PRIMARY KEY, ref_name TEXT, data TEXT);
    INSERT INTO t1 VALUES (1, 'Alice'), (2, 'Bob');
    INSERT INTO t2 VALUES (1, 'alice', 'x'), (2, 'BOB', 'y');
    SELECT t1.name, t2.data FROM t1 JOIN t2 ON t1.name = t2.ref_name ORDER BY t1.id;
}
expect {
    Alice|x
    Bob|y
}

@cross-check-integrity
test collate_hash_join_nocase_column_without_order_by {
    CREATE TABLE t1(id INTEGER PRIMARY KEY, name TEXT COLLATE NOCASE);
    CREATE TABLE t2(id INTEGER PRIMARY KEY, ref_name TEXT, data TEXT);
    INSERT INTO t1 VALUES (1, 'Alice'), (2, 'Bob');
    INSERT INTO t2 VALUES (1, 'alice', 'x'), (2, 'BOB', 'y');
    SELECT t1.name, t2.data FROM t1 JOIN t2 ON t1.name = t2.ref_name;
}
expect {
    Alice|x
    Bob|y
}

@cross-check-integrity
test collate_select_comparison_survives_unrelated_hash_join_keys {
    CREATE TABLE t1(a INTEGER, b TEXT COLLATE NOCASE);
    CREATE TABLE t2(c INTEGER, d TEXT COLLATE BINARY);
    INSERT INTO t1 VALUES (1, 'Apple'), (2, 'banana'), (3, 'CHERRY');
    INSERT INTO t2 VALUES (1, 'apple'), (2, 'BANANA'), (3, 'cherry');

    -- The join predicate is on integer columns, so the SELECT-list comparison
    -- must still use t1.b's NOCASE collation.
    SELECT t1.b, t2.d, t1.b = t2.d AS eq
    FROM t1 JOIN t2 ON t1.a = t2.c
    ORDER BY t1.a;

    SELECT t1.b, t2.d, t1.b = t2.d AS eq
    FROM t1, t2
    WHERE t1.a = t2.c
    ORDER BY t1.a;
}
expect {
    Apple|apple|1
    banana|BANANA|1
    CHERRY|cherry|1
    Apple|apple|1
    banana|BANANA|1
    CHERRY|cherry|1
}

@cross-check-integrity
test collate_cached_aggregate_result_does_not_inherit_argument_collation {
    CREATE TABLE t(a TEXT COLLATE NOCASE);
    INSERT INTO t VALUES ('Apple'), ('banana');
    SELECT MIN(a) = 'apple', MAX(a) = 'BANANA' FROM t;
}
expect {
    0|0
}

@cross-check-integrity
test collate_cached_window_result_does_not_inherit_argument_collation {
    CREATE TABLE t(a TEXT COLLATE NOCASE);
    INSERT INTO t VALUES ('Apple'), ('banana');
    SELECT MIN(a) OVER () = 'apple' FROM t LIMIT 1;
}
expect {
    0
}

@cross-check-integrity
test collate_aggregate_step_does_not_leak_to_following_scalar_result {
    CREATE TABLE t(a TEXT COLLATE NOCASE);
    INSERT INTO t VALUES ('Apple'), ('banana');
    SELECT MIN(a), 'Apple' = 'apple' FROM t;
    SELECT MIN(a) OVER (), 'Apple' = 'apple' FROM t LIMIT 1;
}
expect {
    Apple|0
    Apple|0
}

# =====================================================================
# --- Hash join with NOCASE on build-side column, comparison in SELECT ---
# The NOCASE column ends up in the hash payload; the cached register must
# carry NOCASE so the equality comparison in the SELECT list is correct.
@cross-check-integrity
test collate_hash_join_nocase_build_side_select_eq {
    CREATE TABLE ht1(id INTEGER PRIMARY KEY, val TEXT COLLATE NOCASE);
    CREATE TABLE ht2(id INTEGER PRIMARY KEY, probe TEXT);
    INSERT INTO ht1 VALUES (1, 'Hello'), (2, 'WORLD');
    INSERT INTO ht2 VALUES (1, 'hello'), (2, 'world');
    -- join on id (integer), but compare val (NOCASE) with probe (BINARY) in SELECT
    SELECT ht1.val = ht2.probe AS eq FROM ht1 JOIN ht2 ON ht1.id = ht2.id ORDER BY ht1.id;
}
expect {
    1
    1
}

# --- Hash join: NOCASE column on probe side (not build side) ---
# Ensure collation propagates correctly even when the NOCASE column is on
# the probe table (the one that scans) rather than the one materialized
# in the hash table payload.
@cross-check-integrity
test collate_hash_join_nocase_probe_side {
    CREATE TABLE hp1(id INTEGER PRIMARY KEY, x TEXT);
    CREATE TABLE hp2(id INTEGER PRIMARY KEY, y TEXT COLLATE NOCASE);
    INSERT INTO hp1 VALUES (1, 'FOO'), (2, 'bar');
    INSERT INTO hp2 VALUES (1, 'foo'), (2, 'BAR');
    SELECT hp2.y = hp1.x AS eq FROM hp1 JOIN hp2 ON hp1.id = hp2.id ORDER BY hp1.id;
}
expect {
    1
    1
}

# --- Three-way join: each table has different collation ---
# Validates that per-column collation is tracked independently even when
# three tables are joined (potentially two hash joins in the plan).
@cross-check-integrity
test collate_three_way_join_different_collations {
    CREATE TABLE tw1(id INTEGER PRIMARY KEY, a TEXT COLLATE NOCASE);
    CREATE TABLE tw2(id INTEGER PRIMARY KEY, b TEXT COLLATE BINARY);
    CREATE TABLE tw3(id INTEGER PRIMARY KEY, c TEXT COLLATE RTRIM);
    INSERT INTO tw1 VALUES (1, 'Alpha');
    INSERT INTO tw2 VALUES (1, 'alpha');
    INSERT INTO tw3 VALUES (1, 'Alpha  ');
    SELECT
        tw1.a = tw2.b AS nocase_eq,
        tw2.b = tw3.c AS binary_eq,
        tw3.c = 'Alpha' AS rtrim_eq
    FROM tw1
    JOIN tw2 ON tw1.id = tw2.id
    JOIN tw3 ON tw2.id = tw3.id;
}
expect {
    1|0|1
}

# --- Self-join with NOCASE: both sides reference same table ---
@cross-check-integrity
test collate_self_join_nocase {
    CREATE TABLE sj(id INTEGER PRIMARY KEY, name TEXT COLLATE NOCASE);
    INSERT INTO sj VALUES (1, 'Alice'), (2, 'alice'), (3, 'BOB');
    SELECT a.name, b.name, a.name = b.name AS eq
    FROM sj a JOIN sj b ON a.id < b.id
    WHERE a.name = b.name
    ORDER BY a.id, b.id;
}
expect {
    Alice|alice|1
}

# --- Multiple NOCASE comparisons in SELECT across a hash join ---
# Each comparison must independently carry the correct collation.
@cross-check-integrity
test collate_multiple_nocase_comparisons_in_select {
    CREATE TABLE mc1(id INTEGER, a TEXT COLLATE NOCASE, b TEXT COLLATE NOCASE);
    CREATE TABLE mc2(id INTEGER, c TEXT, d TEXT);
    INSERT INTO mc1 VALUES (1, 'Foo', 'Bar');
    INSERT INTO mc2 VALUES (1, 'FOO', 'bar');
    SELECT mc1.a = mc2.c AS eq1, mc1.b = mc2.d AS eq2
    FROM mc1 JOIN mc2 ON mc1.id = mc2.id;
}
expect {
    1|1
}

# --- NOCASE column compared against literal after hash join ---
@cross-check-integrity
test collate_nocase_col_vs_literal_after_hash_join {
    CREATE TABLE lj1(id INTEGER PRIMARY KEY, val TEXT COLLATE NOCASE);
    CREATE TABLE lj2(id INTEGER PRIMARY KEY, other TEXT);
    INSERT INTO lj1 VALUES (1, 'Apple'), (2, 'BANANA');
    INSERT INTO lj2 VALUES (1, 'x'), (2, 'y');
    SELECT lj1.val = 'apple' AS eq1, lj1.val = 'banana' AS eq2
    FROM lj1 JOIN lj2 ON lj1.id = lj2.id
    ORDER BY lj1.id;
}
expect {
    1|0
    0|1
}

# --- Aggregate over NOCASE column mixed with scalar NOCASE comparison ---
# The aggregate result should NOT inherit NOCASE (binary comparison),
# but the scalar column comparison in the same SELECT should still use NOCASE.
@cross-check-integrity
test collate_aggregate_and_scalar_nocase_in_same_select {
    CREATE TABLE as1(grp INTEGER, val TEXT COLLATE NOCASE);
    INSERT INTO as1 VALUES (1, 'Apple'), (1, 'banana'), (2, 'CHERRY');
    SELECT grp, MAX(val) = 'banana' AS agg_eq, val = 'apple' AS scalar_eq
    FROM as1
    WHERE grp = 1
    GROUP BY grp, val
    ORDER BY val;
}
expect {
    1|0|1
    1|1|0
}

# --- Multiple aggregates: ensure collation doesn't leak between them ---
# First agg has NOCASE arg, second has BINARY arg; the second comparison
# must not be contaminated by the first aggregate's argument collation.
@cross-check-integrity
test collate_multiple_aggs_no_cross_leak {
    CREATE TABLE ml(a TEXT COLLATE NOCASE, b TEXT COLLATE BINARY);
    INSERT INTO ml VALUES ('Apple', 'Apple'), ('banana', 'banana');
    SELECT MIN(a) = 'apple' AS agg1, MIN(b) = 'Apple' AS agg2 FROM ml;
}
expect {
    0|1
}

# --- Window function result compared, then scalar NOCASE comparison ---
# The window result must not inherit NOCASE, but the next column in the
# SELECT list that references the NOCASE column directly should.
@cross-check-integrity
test collate_window_then_scalar_nocase {
    CREATE TABLE ws(a TEXT COLLATE NOCASE, b INTEGER);
    INSERT INTO ws VALUES ('Hello', 1), ('HELLO', 2), ('world', 3);
    SELECT
        MIN(a) OVER () = 'hello' AS win_eq,
        a = 'hello' AS scalar_eq
    FROM ws
    ORDER BY b
    LIMIT 1;
}
expect {
    0|1
}

# --- Aggregate in HAVING with NOCASE, plus scalar comparison in SELECT ---
@cross-check-integrity
test collate_having_aggregate_nocase_select_scalar {
    CREATE TABLE hv(grp TEXT, val TEXT COLLATE NOCASE);
    INSERT INTO hv VALUES ('A', 'apple'), ('A', 'BANANA'), ('B', 'cherry');
    SELECT grp, MIN(val), val = 'apple' AS eq
    FROM hv
    GROUP BY grp, val
    HAVING MIN(val) = val
    ORDER BY grp, val;
}
expect {
    A|apple|1
    A|BANANA|0
    B|cherry|0
}

# --- Explicit COLLATE BINARY override on NOCASE column in hash join SELECT ---
# The explicit override should win even though the column is NOCASE.
@cross-check-integrity
test collate_explicit_override_in_hash_join_select {
    CREATE TABLE eo1(id INTEGER PRIMARY KEY, val TEXT COLLATE NOCASE);
    CREATE TABLE eo2(id INTEGER PRIMARY KEY, other TEXT);
    INSERT INTO eo1 VALUES (1, 'Apple');
    INSERT INTO eo2 VALUES (1, 'apple');
    SELECT
        eo1.val = eo2.other AS nocase_eq,
        eo1.val COLLATE BINARY = eo2.other AS binary_eq
    FROM eo1 JOIN eo2 ON eo1.id = eo2.id;
}
expect {
    1|0
}

# --- LEFT JOIN: NOCASE column on the nullable (right) side ---
# When there's a match the NOCASE should apply; NULL rows shouldn't crash.
@cross-check-integrity
test collate_left_join_nocase_nullable_side {
    CREATE TABLE lf1(id INTEGER PRIMARY KEY, x TEXT);
    CREATE TABLE lf2(id INTEGER, y TEXT COLLATE NOCASE);
    INSERT INTO lf1 VALUES (1, 'hello'), (2, 'world');
    INSERT INTO lf2 VALUES (1, 'HELLO');
    SELECT lf1.x, lf2.y, lf2.y = lf1.x AS eq
    FROM lf1 LEFT JOIN lf2 ON lf1.id = lf2.id
    ORDER BY lf1.id;
}
expect {
    hello|HELLO|1
    world||
}

# --- Subquery in FROM with NOCASE column, compared in outer query ---
@cross-check-integrity
test collate_subquery_from_nocase_outer_comparison {
    CREATE TABLE sq(a TEXT COLLATE NOCASE);
    INSERT INTO sq VALUES ('Fox'), ('fox'), ('FOX');
    SELECT sub.a = 'fox' AS eq FROM (SELECT a FROM sq ORDER BY rowid LIMIT 1) sub;
}
expect {
    1
}

# --- UNION ALL preserving collation from each branch ---
@cross-check-integrity
test collate_union_all_nocase_branch {
    CREATE TABLE u1(a TEXT COLLATE NOCASE);
    CREATE TABLE u2(a TEXT COLLATE BINARY);
    INSERT INTO u1 VALUES ('Apple');
    INSERT INTO u2 VALUES ('Apple');
    -- In a UNION ALL, the result column collation comes from the first SELECT
    -- per SQLite rules. So the comparison should use NOCASE.
    SELECT a = 'apple' FROM (
        SELECT a FROM u1
        UNION ALL
        SELECT a FROM u2
    );
}
expect {
    1
    1
}

# --- CASE expression: NOCASE column in WHEN clause after hash join ---
@cross-check-integrity
test collate_case_when_nocase_after_join {
    CREATE TABLE cw1(id INTEGER PRIMARY KEY, val TEXT COLLATE NOCASE);
    CREATE TABLE cw2(id INTEGER PRIMARY KEY, data TEXT);
    INSERT INTO cw1 VALUES (1, 'Yes'), (2, 'YES');
    INSERT INTO cw2 VALUES (1, 'a'), (2, 'b');
    SELECT CASE WHEN cw1.val = 'yes' THEN 'match' ELSE 'no-match' END AS result
    FROM cw1 JOIN cw2 ON cw1.id = cw2.id
    ORDER BY cw1.id;
}
expect {
    match
    match
}

# --- IN operator with NOCASE column ---
@cross-check-integrity
test collate_in_operator_nocase {
    CREATE TABLE inp(val TEXT COLLATE NOCASE);
    INSERT INTO inp VALUES ('Apple'), ('BANANA'), ('cherry');
    SELECT val, val IN ('apple', 'banana', 'cherry') AS in_list FROM inp ORDER BY rowid;
}
expect {
    Apple|1
    BANANA|1
    cherry|1
}

# --- BETWEEN with NOCASE column ---
@cross-check-integrity
test collate_between_nocase {
    CREATE TABLE bw(val TEXT COLLATE NOCASE);
    INSERT INTO bw VALUES ('Apple'), ('BANANA'), ('cherry'), ('Date');
    -- 'Date' BETWEEN 'b' AND 'd' is 0 because NOCASE 'date' > 'd' (length matters)
    SELECT val, val BETWEEN 'b' AND 'd' FROM bw ORDER BY rowid;
}
expect {
    Apple|0
    BANANA|1
    cherry|1
    Date|0
}

# --- GROUP BY on NOCASE column + aggregate + scalar comparison ---
# The GROUP BY should group case-insensitively, and the scalar comparison
# in the SELECT must still use the column's NOCASE collation.
@cross-check-integrity
test collate_group_by_nocase_with_scalar_comparison {
    CREATE TABLE gb(name TEXT COLLATE NOCASE, amount INTEGER);
    INSERT INTO gb VALUES ('Alice', 10), ('alice', 20), ('ALICE', 30), ('Bob', 5);
    SELECT name, SUM(amount), name = 'alice' AS eq FROM gb GROUP BY name ORDER BY name;
}
expect {
    Alice|60|1
    Bob|5|0
}

# --- COALESCE with mixed collation columns ---
@cross-check-integrity
test collate_coalesce_nocase {
    CREATE TABLE co(a TEXT COLLATE NOCASE, b TEXT COLLATE BINARY);
    INSERT INTO co VALUES (NULL, 'Hello');
    INSERT INTO co VALUES ('World', 'ignored');
    -- COALESCE returns first non-NULL; collation should come from the winning column.
    -- COALESCE is a function-like expression; it does NOT inherit column collation.
    -- Both comparisons use BINARY, so case matters.
    SELECT COALESCE(a, b) = 'hello' FROM co ORDER BY rowid;
}
expect {
    0
    0
}

# --- COUNT(*) with NOCASE comparison in same SELECT ---
# Specifically tests that COUNT aggregate does not interfere with
# collation of a subsequent scalar comparison.
@cross-check-integrity
test collate_count_star_with_nocase_comparison {
    CREATE TABLE cs(a TEXT COLLATE NOCASE);
    INSERT INTO cs VALUES ('Apple'), ('banana');
    SELECT COUNT(*), 'Apple' = 'apple' FROM cs;
}
expect {
    2|0
}

# --- Hash join with ORDER BY on NOCASE column + inequality comparison ---
@cross-check-integrity
test collate_hash_join_order_by_nocase_inequality {
    CREATE TABLE ho1(id INTEGER PRIMARY KEY, name TEXT COLLATE NOCASE);
    CREATE TABLE ho2(id INTEGER PRIMARY KEY, data TEXT);
    INSERT INTO ho1 VALUES (1, 'alpha'), (2, 'BETA'), (3, 'gamma');
    INSERT INTO ho2 VALUES (1, 'x'), (2, 'y'), (3, 'z');
    SELECT ho1.name, ho1.name > 'ALPHA' AS gt_alpha, ho1.name < 'gamma' AS lt_gamma
    FROM ho1 JOIN ho2 ON ho1.id = ho2.id
    ORDER BY ho1.name;
}
expect {
    alpha|0|1
    BETA|1|1
    gamma|1|0
}

# --- Aggregate SUM (numeric) does not interfere with NOCASE scalar comparison ---
@cross-check-integrity
test collate_numeric_aggregate_no_collation_leak {
    CREATE TABLE na(val TEXT COLLATE NOCASE, num INTEGER);
    INSERT INTO na VALUES ('Apple', 10), ('banana', 20);
    SELECT SUM(num), val = 'apple' FROM na GROUP BY val ORDER BY val;
}
expect {
    10|1
    20|0
}

# --- Deeply nested expression with NOCASE column in hash join ---
@cross-check-integrity
test collate_nested_expr_nocase_hash_join {
    CREATE TABLE ne1(id INTEGER PRIMARY KEY, x TEXT COLLATE NOCASE);
    CREATE TABLE ne2(id INTEGER PRIMARY KEY, y TEXT);
    INSERT INTO ne1 VALUES (1, 'Hello');
    INSERT INTO ne2 VALUES (1, 'HELLO');
    -- Double parenthesization should not lose collation
    SELECT ((ne1.x)) = ((ne2.y)) AS eq
    FROM ne1 JOIN ne2 ON ne1.id = ne2.id;
}
expect {
    1
}

# --- Window function OVER with PARTITION BY, mixed with scalar NOCASE ---
@cross-check-integrity
test collate_window_partition_then_scalar_nocase {
    CREATE TABLE wp(grp TEXT, val TEXT COLLATE NOCASE);
    INSERT INTO wp VALUES ('A', 'apple'), ('A', 'BANANA'), ('B', 'cherry');
    SELECT
        COUNT(*) OVER (PARTITION BY grp),
        val = 'apple' AS eq
    FROM wp
    ORDER BY grp, val;
}
expect {
    2|1
    2|0
    1|0
}

# --- Multiple window functions interleaved with NOCASE comparisons ---
@cross-check-integrity
test collate_multiple_windows_nocase_interleave {
    CREATE TABLE mw(val TEXT COLLATE NOCASE, num INTEGER);
    INSERT INTO mw VALUES ('Alpha', 1), ('BETA', 2), ('gamma', 3);
    SELECT
        MIN(val) OVER () = 'alpha' AS win_min_eq,
        val = 'alpha' AS direct_eq,
        MAX(val) OVER () = 'GAMMA' AS win_max_eq
    FROM mw
    ORDER BY num
    LIMIT 1;
}
expect {
    0|1|0
}

# --- Repeated column reference after aggregate in GROUP BY query ---
# After emitting the aggregate (MIN), the next reference to `val` should
# still carry NOCASE from the column definition.
@cross-check-integrity
test collate_group_by_repeated_col_ref_after_agg {
    CREATE TABLE rp(grp INTEGER, val TEXT COLLATE NOCASE);
    INSERT INTO rp VALUES (1, 'Apple'), (1, 'banana'), (2, 'CHERRY');
    SELECT grp, MIN(val), val = 'apple' AS eq
    FROM rp
    GROUP BY grp, val
    ORDER BY grp, val;
}
expect {
    1|Apple|1
    1|banana|0
    2|CHERRY|0
}

# --- Hash join with NOCASE on the join predicate column AND in SELECT ---
# The NOCASE column is used for BOTH the join condition AND a comparison
# in the SELECT list. This stresses that collation isn't consumed/lost
# after the join uses it.
@cross-check-integrity
test collate_nocase_join_predicate_and_select_comparison {
    CREATE TABLE jp1(name TEXT COLLATE NOCASE, data TEXT);
    CREATE TABLE jp2(name TEXT, extra TEXT);
    INSERT INTO jp1 VALUES ('Alice', 'x'), ('Bob', 'y');
    INSERT INTO jp2 VALUES ('ALICE', 'a'), ('bob', 'b');
    SELECT jp1.name = jp2.name AS eq, jp1.data, jp2.extra
    FROM jp1 JOIN jp2 ON jp1.name = jp2.name
    ORDER BY jp1.data;
}
expect {
    1|x|a
    1|y|b
}

# --- Mixed COLLATE NOCASE and COLLATE RTRIM columns in same hash join ---
@cross-check-integrity
test collate_mixed_nocase_rtrim_hash_join {
    CREATE TABLE mr1(id INTEGER PRIMARY KEY, a TEXT COLLATE NOCASE, b TEXT COLLATE RTRIM);
    CREATE TABLE mr2(id INTEGER PRIMARY KEY, c TEXT, d TEXT);
    INSERT INTO mr1 VALUES (1, 'Hello', 'World');
    INSERT INTO mr2 VALUES (1, 'HELLO', 'World   ');
    SELECT mr1.a = mr2.c AS nocase_eq, mr1.b = mr2.d AS rtrim_eq
    FROM mr1 JOIN mr2 ON mr1.id = mr2.id;
}
expect {
    1|1
}

# --- Aggregate GROUP_CONCAT result should not inherit NOCASE ---
@cross-check-integrity
test collate_group_concat_no_inherit_nocase {
    CREATE TABLE gc(val TEXT COLLATE NOCASE);
    INSERT INTO gc VALUES ('Apple'), ('banana');
    SELECT GROUP_CONCAT(val, ',') = 'apple,banana' FROM gc;
}
expect {
    0
}

# --- Four-column SELECT: agg, NOCASE col, agg, NOCASE col ---
# Validates that collation state is correctly restored after each
# aggregate emission and doesn't bleed into adjacent scalar columns.
@cross-check-integrity
test collate_interleaved_agg_and_nocase_scalars {
    CREATE TABLE ia(val TEXT COLLATE NOCASE, num INTEGER);
    INSERT INTO ia VALUES ('Apple', 10), ('banana', 20);
    SELECT MIN(val), val = 'apple', MAX(num), val = 'BANANA'
    FROM ia
    GROUP BY val
    ORDER BY val;
}
expect {
    Apple|1|10|0
    banana|0|20|1
}

@cross-check-integrity
test collate_columns_where_implicit {
    CREATE TABLE t(
    a TEXT COLLATE NOCASE,
    b TEXT COLLATE BINARY,
    c TEXT COLLATE RTRIM
    );
    INSERT INTO t(a,b,c) VALUES
    ('hat','hat','hat '),
    ('hAt','hAt','hat'),
    ('HAT','HAT','hat    '),
    ('other','other','other');
    SELECT count(*) FROM t WHERE a = 'hAt';
    SELECT count(*) FROM t WHERE b = 'hAt';
    SELECT count(*) FROM t WHERE c = 'hat';
}
expect {
    3
    1
    3
}

@cross-check-integrity
test collate_columns_where_explicit_override {
    CREATE TABLE t(
    a TEXT COLLATE NOCASE,
    b TEXT COLLATE BINARY,
    c TEXT COLLATE RTRIM
    );
    INSERT INTO t(a,b,c) VALUES
    ('hat','hat','hat '),
    ('hAt','hAt','hat'),
    ('HAT','HAT','hat    '),
    ('other','other','other');
    SELECT count(*) FROM t WHERE a COLLATE BINARY = 'hAt';   -- override to binary
    SELECT count(*) FROM t WHERE b COLLATE NOCASE = 'hAt';   -- override to nocase
    SELECT count(*) FROM t WHERE c COLLATE BINARY = 'hat';   -- override to binary
}
expect {
    1
    3
    1
}

