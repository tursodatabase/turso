@database :temp:

# Adapted from SQLite nan.test: real values remain real values across VACUUM.
test affinity-vacuum-preserves-real-value {
    PRAGMA page_size = 1024;
    CREATE TABLE vacuum_real_value(x FLOAT);
    INSERT INTO vacuum_real_value VALUES(0.5);
    VACUUM;
    SELECT x, typeof(x) FROM vacuum_real_value;
    PRAGMA integrity_check;
}
expect {
    0.5|real
    ok
}
