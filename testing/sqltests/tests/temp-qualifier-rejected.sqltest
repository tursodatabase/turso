@database :memory:

test temp-create-table-rejected {
    CREATE TABLE temp.t1(x)
}
expect error {
    TEMPORARY database not supported yet
}

test temp-drop-table-rejected {
    CREATE TABLE t1(x);
    DROP TABLE temp.t1
}
expect error {
    TEMPORARY database not supported yet
}

test temp-insert-rejected {
    CREATE TABLE t2(x);
    INSERT INTO temp.t2 VALUES(1)
}
expect error {
    TEMPORARY database not supported yet
}
