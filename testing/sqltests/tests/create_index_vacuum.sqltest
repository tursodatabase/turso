@database :temp:

# Adapted from SQLite index6.test: VACUUM preserves partial UNIQUE indexes.
test create-index-vacuum-preserves-partial-unique-index {
    CREATE TABLE vacuum_partial_unique(a,b);
    INSERT INTO vacuum_partial_unique VALUES(0,0),(5,5),(10,10),(15,15),(20,20);
    UPDATE vacuum_partial_unique SET a=999 WHERE b%10 != 0;
    CREATE UNIQUE INDEX vacuum_partial_unique_a ON vacuum_partial_unique(a) WHERE a<>999;
    INSERT INTO vacuum_partial_unique(a,b) VALUES(999, 'extra1'), (999, 'extra2');
    SELECT count(*) FROM vacuum_partial_unique WHERE a=999;
    VACUUM;
    SELECT count(*) FROM vacuum_partial_unique WHERE a=999;
    PRAGMA integrity_check;
}
expect {
    4
    4
    ok
}

# Adapted from SQLite descidx1.test: VACUUM preserves DESC index ordering.
test create-index-vacuum-preserves-desc-index {
    CREATE TABLE vacuum_desc_index(a,b,c);
    CREATE INDEX vacuum_desc_index_i ON vacuum_desc_index(a ASC, b DESC, c ASC);
    INSERT INTO vacuum_desc_index VALUES(1,2,3);
    INSERT INTO vacuum_desc_index VALUES(1,1,0);
    INSERT INTO vacuum_desc_index VALUES(1,2,1);
    INSERT INTO vacuum_desc_index VALUES(1,3,4);
    VACUUM;
    SELECT a, b, c FROM vacuum_desc_index ORDER BY a ASC, b DESC, c ASC;
    PRAGMA integrity_check;
}
expect {
    1|3|4
    1|2|1
    1|2|3
    1|1|0
    ok
}
