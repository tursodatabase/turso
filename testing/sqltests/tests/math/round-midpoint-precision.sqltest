@database :memory:

test round-midpoint-away-from-zero-025 {
    SELECT round(0.25, 1)
}
expect {
    0.3
}

test round-midpoint-away-from-zero-125 {
    SELECT round(1.25, 1)
}
expect {
    1.3
}

test round-midpoint-away-from-zero-225 {
    SELECT round(2.25, 1)
}
expect {
    2.3
}

test round-non-midpoint-255 {
    SELECT round(2.55, 1)
}
expect {
    2.5
}

test round-midpoint-negative {
    SELECT round(-2.25, 1)
}
expect {
    -2.3
}

test round-midpoint-precision-2 {
    SELECT round(1.125, 2)
}
expect {
    1.13
}

test round-non-midpoint-345 {
    SELECT round(3.45, 1)
}
expect {
    3.5
}

test round-non-midpoint-455 {
    SELECT round(4.55, 1)
}
expect {
    4.5
}

test round-midpoint-precision-0-positive {
    SELECT CAST(round(0.5, 0) AS INTEGER)
}
expect {
    1
}

test round-midpoint-precision-0-negative {
    SELECT CAST(round(-0.5, 0) AS INTEGER)
}
expect {
    -1
}

test round-midpoint-precision-0-25 {
    SELECT CAST(round(2.5, 0) AS INTEGER)
}
expect {
    3
}
