@database :memory:

test log10-1000-integer-cast {
    SELECT CAST(log10(1000) AS INTEGER)
}
expect {
    3
}

test log10-1000-exact {
    SELECT abs(log10(1000.0) - 3.0) < 1e-10
}
expect {
    1
}

test log10-100-exact {
    SELECT abs(log10(100.0) - 2.0) < 1e-10
}
expect {
    1
}

test log10-10-exact {
    SELECT abs(log10(10.0) - 1.0) < 1e-10
}
expect {
    1
}

test log10-1000000-integer-cast {
    SELECT CAST(log10(1000000) AS INTEGER)
}
expect {
    6
}

test log2-1024-integer-cast {
    SELECT CAST(log2(1024) AS INTEGER)
}
expect {
    10
}

test log2-8-exact {
    SELECT abs(log2(8.0) - 3.0) < 1e-10
}
expect {
    1
}

test log2-256-integer-cast {
    SELECT CAST(log2(256) AS INTEGER)
}
expect {
    8
}
