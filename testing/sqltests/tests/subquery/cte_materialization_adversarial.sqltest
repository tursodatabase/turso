test from-sub-nested {
    CREATE TABLE fn(a INT);
    INSERT INTO fn VALUES(5),(3),(1),(4),(2);
    SELECT * FROM (
      SELECT * FROM (
        SELECT a FROM fn ORDER BY a
      ) inner_sub
    ) outer_sub ORDER BY a;
}
