test join-two-ctes-different-cardinalities {
    CREATE TABLE small(id INT PRIMARY KEY, val TEXT);
    INSERT INTO small VALUES(1,'a'),(2,'b'),(3,'c');
    CREATE TABLE big(id INT PRIMARY KEY, sid INT, data TEXT);
    INSERT INTO big VALUES(1,1,'x1'),(2,1,'x2'),(3,2,'x3'),(4,2,'x4'),(5,3,'x5'),(6,3,'x6');
    WITH s AS (SELECT id, val FROM small),
         b AS (SELECT id, sid, data FROM big)
    SELECT s.val, b.data FROM s JOIN b ON s.id = b.sid ORDER BY b.id;
}
expect {
    a|x1
    a|x2
    b|x3
    b|x4
    c|x5
    c|x6
}

test join-three-way-cte-table-cte {
    CREATE TABLE jt1(id INT PRIMARY KEY, a TEXT);
    INSERT INTO jt1 VALUES(1,'x'),(2,'y'),(3,'z');
    CREATE TABLE jt2(id INT PRIMARY KEY, t1_id INT, t3_id INT);
    INSERT INTO jt2 VALUES(1,1,1),(2,1,2),(3,2,1),(4,3,3);
    CREATE TABLE jt3(id INT PRIMARY KEY, b TEXT);
    INSERT INTO jt3 VALUES(1,'p'),(2,'q'),(3,'r');
    WITH c1 AS (SELECT id, a FROM jt1),
         c3 AS (SELECT id, b FROM jt3)
    SELECT c1.a, jt2.id AS link, c3.b
    FROM c1 JOIN jt2 ON c1.id = jt2.t1_id JOIN c3 ON jt2.t3_id = c3.id
    ORDER BY jt2.id;
}
expect {
    x|1|p
    x|2|q
    y|3|p
    z|4|r
}

test join-anti-join-left-join-is-null {
    CREATE TABLE all_ids(id INT PRIMARY KEY);
    INSERT INTO all_ids VALUES(1),(2),(3),(4),(5);
    CREATE TABLE used_ids(id INT PRIMARY KEY);
    INSERT INTO used_ids VALUES(2),(4);
    WITH cte AS (SELECT id FROM used_ids)
    SELECT a.id FROM all_ids a LEFT JOIN cte ON a.id = cte.id
    WHERE cte.id IS NULL ORDER BY a.id;
}
expect {
    1
    3
    5
}

test join-cte-self-non-equi {
    CREATE TABLE vals(v INT);
    INSERT INTO vals VALUES(1),(2),(3),(4),(5);
    WITH cte AS (SELECT v FROM vals)
    SELECT a.v AS lo, b.v AS hi FROM cte a JOIN cte b ON a.v < b.v
    ORDER BY a.v, b.v;
}
expect {
    1|2
    1|3
    1|4
    1|5
    2|3
    2|4
    2|5
    3|4
    3|5
    4|5
}

test join-cte-self-graph-walk {
    CREATE TABLE edges(src INT, dst INT);
    INSERT INTO edges VALUES(1,2),(2,3),(3,4),(1,3);
    WITH cte AS (SELECT src, dst FROM edges)
    SELECT a.src, a.dst, b.dst AS dst2
    FROM cte a JOIN cte b ON a.dst = b.src
    ORDER BY a.src, a.dst, b.dst;
}
expect {
    1|2|3
    1|3|4
    2|3|4
}

test join-aggregate-cte-to-table {
    CREATE TABLE jsales(id INT, product TEXT, amount REAL);
    INSERT INTO jsales VALUES(1,'a',10),(2,'a',20),(3,'b',30),(4,'b',40),(5,'c',50);
    CREATE TABLE jproducts(name TEXT PRIMARY KEY, category TEXT);
    INSERT INTO jproducts VALUES('a','cat1'),('b','cat1'),('c','cat2');
    WITH totals AS (SELECT product, SUM(amount) AS total FROM jsales GROUP BY product)
    SELECT p.category, t.product, t.total
    FROM totals t JOIN jproducts p ON t.product = p.name
    ORDER BY p.category, t.product;
}
expect {
    cat1|a|30.0
    cat1|b|70.0
    cat2|c|50.0
}
expect @js {
    cat1|a|30
    cat1|b|70
    cat2|c|50
}

test join-correlated-sub-from-cte-in-select {
    CREATE TABLE departments(id INT PRIMARY KEY, name TEXT);
    INSERT INTO departments VALUES(1,'eng'),(2,'sales'),(3,'hr');
    CREATE TABLE employees(id INT PRIMARY KEY, dept_id INT, salary INT);
    INSERT INTO employees VALUES(1,1,100),(2,1,120),(3,2,80),(4,2,90),(5,3,70);
    WITH emp AS (SELECT id, dept_id, salary FROM employees)
    SELECT d.name,
           (SELECT COUNT(*) FROM emp WHERE emp.dept_id = d.id) AS cnt,
           (SELECT MAX(salary) FROM emp WHERE emp.dept_id = d.id) AS max_sal
    FROM departments d ORDER BY d.id;
}
expect {
    eng|2|120
    sales|2|90
    hr|1|70
}

test join-distinct-cte-to-table {
    CREATE TABLE jlog(ts INT, user_id INT, action TEXT);
    INSERT INTO jlog VALUES(1,1,'view'),(2,1,'click'),(3,2,'view'),(4,1,'view'),(5,3,'click');
    CREATE TABLE jusers(id INT PRIMARY KEY, name TEXT);
    INSERT INTO jusers VALUES(1,'alice'),(2,'bob'),(3,'carol');
    WITH active AS (SELECT DISTINCT user_id FROM jlog)
    SELECT u.name FROM active a JOIN jusers u ON a.user_id = u.id ORDER BY u.name;
}
expect {
    alice
    bob
    carol
}

