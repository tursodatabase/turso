    4
    5
}

test from-sub-aggregate-different-order {
    CREATE TABLE fa(grp TEXT, val INT);
    INSERT INTO fa VALUES('a',1),('b',2),('a',3),('b',4),('c',5);
    SELECT * FROM (
      SELECT grp, SUM(val) AS total FROM fa GROUP BY grp ORDER BY grp
    ) sub ORDER BY total DESC;
}
expect {
    b|6
    c|5
    a|4
}

test from-sub-joined {
    CREATE TABLE fj1(a INT, b TEXT);
    INSERT INTO fj1 VALUES(1,'x'),(2,'y'),(3,'z');
    CREATE TABLE fj2(a INT, c TEXT);
    INSERT INTO fj2 VALUES(1,'p'),(2,'q'),(3,'r');
    SELECT sub.a, sub.b, fj2.c
    FROM (SELECT a, b FROM fj1 ORDER BY a) sub
    JOIN fj2 ON sub.a = fj2.a
    ORDER BY sub.a;
}
expect {
    1|x|p
    2|y|q
    3|z|r
}

