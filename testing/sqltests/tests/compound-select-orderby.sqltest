}

@setup schema
test union-order-by-multiple-cols {
    SELECT a, b, c FROM t1
    UNION
    SELECT a, b, c FROM t2
    ORDER BY c DESC, a ASC;
}
expect {
    8|honeydew|80
    7|grape|70
    6|fig|60
    5|elderberry|50
    4|date|40
    3|cherry|30
    2|banana|20
    1|apple|10
}

# ===== INTERSECT + ORDER BY =====

@setup schema
test intersect-order-by {
    SELECT a, b FROM t1
    INTERSECT
    SELECT a, b FROM t2
    ORDER BY 1;
}
expect {
    2|banana
    4|date
}

@setup schema
test intersect-order-by-desc {
    SELECT a, b FROM t1
    INTERSECT
    SELECT a, b FROM t2
    ORDER BY 1 DESC;
}
expect {
    4|date
    2|banana
}

@setup schema
test intersect-order-by-col-name {
    SELECT a, b FROM t1
    INTERSECT
    SELECT a, b FROM t2
    ORDER BY b DESC;
}
expect {
    4|date
    2|banana
}

