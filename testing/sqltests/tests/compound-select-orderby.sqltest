@setup schema
test union-all-expressions-order-by {
    SELECT a * 10 AS val FROM t1
    UNION ALL
    SELECT a * 10 FROM t2
    ORDER BY 1;
}
expect {
    10
    20
    20
    30
    40
    40
    50
    60
    70
    80
}

