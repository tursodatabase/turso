@database :temp:

# Adapted from SQLite tkt-d82e3f3721.test: VACUUM must preserve
# AUTOINCREMENT state when temp tables shadow main tables.
@skip-if mvcc "AUTOINCREMENT is not supported in MVCC mode"
test autoincr-vacuum-preserves-temp-autoincrement-sequence {
    CREATE TABLE t1(a INTEGER PRIMARY KEY AUTOINCREMENT);
    INSERT INTO t1 VALUES(10);
    CREATE TEMP TABLE t1(a INTEGER PRIMARY KEY AUTOINCREMENT);
    INSERT INTO temp.t1 VALUES(20);
    INSERT INTO main.t1 VALUES(NULL);
    INSERT INTO temp.t1 VALUES(NULL);
    VACUUM;
    INSERT INTO main.t1 VALUES(NULL);
    INSERT INTO temp.t1 VALUES(NULL);
    SELECT * FROM main.t1 ORDER BY a;
    SELECT * FROM temp.t1 ORDER BY a;
}
expect {
    10
    11
    12
    20
    21
    22
}

# Adapted from SQLite tkt-d82e3f3721.test: VACUUM must not disturb temp
# tables that shadow main tables.
test autoincr-vacuum-preserves-temp-table-shadowing {
    CREATE TABLE t1(a, b);
    CREATE TEMP TABLE t1(a, b);
    INSERT INTO main.t1 VALUES(1, 'main');
    INSERT INTO temp.t1 VALUES(2, 'temp');
    VACUUM;
    SELECT * FROM main.t1;
    SELECT * FROM temp.t1;
}
expect {
    1|main
    2|temp
}
