@database :temp:
@skip-file-if sqlite "MVCC is not supported in SQLite"

# Regression coverage for https://github.com/tursodatabase/turso/issues/5665:
# a large MVCC transaction used to drive a single pwrite/pwritev call past
# INT_MAX, which Darwin rejects with EINVAL. UnixIO::pwrite/pwritev now cap
# each syscall at INT_MAX bytes, so the checkpoint completes.
#
# 1.5M rows of 1500-byte blobs is just past INT_MAX (2.147 GB), enough to
# force the cap to kick in.

@backend cli
test big-db-mvcc {
    PRAGMA journal_mode='MVCC';
    DROP TABLE IF EXISTS t;
    CREATE TABLE t (x);
    INSERT INTO t SELECT randomblob(1500) FROM generate_series(1, 1500000);
    PRAGMA wal_checkpoint(TRUNCATE);
    SELECT COUNT(*) FROM t;
}
expect {
   mvcc
   0|0|0
   1500000
}
