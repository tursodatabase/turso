@database :temp:

# Adapted from SQLite without_rowid1.test: a supported WITHOUT ROWID table can
# be vacuumed.
test without-rowid-vacuum-basic {
    CREATE TABLE vacuum_wr_basic(a,b,c,d, PRIMARY KEY(c,a)) WITHOUT ROWID;
    INSERT INTO vacuum_wr_basic VALUES('journal','sherman','ammonia','helena');
    INSERT INTO vacuum_wr_basic VALUES('arctic','sleep','ammonia','helena');
    VACUUM;
    SELECT * FROM vacuum_wr_basic ORDER BY b, d;
    PRAGMA integrity_check;
}
expect {
    journal|sherman|ammonia|helena
    arctic|sleep|ammonia|helena
    ok
}

# Adapted from SQLite tableopts.test: VACUUM preserves composite-primary-key
# WITHOUT ROWID tables.
test without-rowid-vacuum-composite-primary-key {
    CREATE TABLE vacuum_wr_composite(a, b, c, PRIMARY KEY(a, b)) WITHOUT ROWID;
    INSERT INTO vacuum_wr_composite VALUES(1, 2, 3), (1, 3, 4);
    VACUUM;
    SELECT c FROM vacuum_wr_composite WHERE a IN (1,2) ORDER BY b;
    PRAGMA integrity_check;
}
expect {
    3
    4
    ok
}

# Adapted from SQLite without_rowid1.test/index6.test/index7.test: SQLite
# vacuums WITHOUT ROWID tables with secondary indexes and secondary UNIQUE
# constraints.
@skip "missing feature: secondary indexes and secondary UNIQUE constraints on WITHOUT ROWID tables are not supported; see missing_feature.txt"
test without-rowid-vacuum-secondary-indexes-from-sqlite {
    CREATE TABLE vacuum_wr_unique(a, b UNIQUE PRIMARY KEY) WITHOUT ROWID;
    CREATE INDEX vacuum_wr_unique_a ON vacuum_wr_unique(a);
    INSERT INTO vacuum_wr_unique VALUES(1, 2), (2, 4);
    VACUUM;
    PRAGMA integrity_check;
}
expect {
    ok
}
