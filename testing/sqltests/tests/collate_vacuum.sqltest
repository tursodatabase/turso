@database :temp:

# Adapted from SQLite collateB.test: VACUUM must preserve an index on a column
# explicitly declared with the built-in binary collation.
test collate-vacuum-preserves-binary-collation-index {
    CREATE TABLE vacuum_collate_binary(a COLLATE binary);
    CREATE INDEX vacuum_collate_binary_idx ON vacuum_collate_binary(a);
    INSERT INTO vacuum_collate_binary VALUES('one'), ('two'), ('three');
    VACUUM;
    SELECT a FROM vacuum_collate_binary ORDER BY a;
    PRAGMA integrity_check;
}
expect {
    one
    three
    two
    ok
}
