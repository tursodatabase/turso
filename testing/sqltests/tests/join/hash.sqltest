    800
}

@cross-check-integrity
test grace-negative-keys-spot-check {
    CREATE TABLE t1(a INTEGER, b TEXT);
    CREATE TABLE t2(c INTEGER, d TEXT);
    INSERT INTO t1 SELECT value - 400, 'L' || value FROM generate_series(1, 800);
    INSERT INTO t2 SELECT value - 400, 'R' || value FROM generate_series(1, 800);
    SELECT t1.a, t1.b, t2.d FROM t1 JOIN t2 ON t1.a = t2.c
    WHERE t1.a IN (-399, 0, 400) ORDER BY t1.a;
}
expect {
    -399|L1|R1
    0|L400|R400
    400|L800|R800
}

# =============================================================================
# 25. Large payload columns through grace spill
# =============================================================================

@cross-check-integrity
test grace-large-payload {
    CREATE TABLE t1(a INTEGER, payload TEXT);
    CREATE TABLE t2(b INTEGER, data TEXT);
    -- Long text payloads to stress serialization
    INSERT INTO t1 SELECT value, printf('%0200d', value) FROM generate_series(1, 600);
    INSERT INTO t2 SELECT value, printf('%0200d', value * 2) FROM generate_series(1, 600);
    SELECT count(*), length(t1.payload), length(t2.data) FROM t1 JOIN t2 ON t1.a = t2.b WHERE t1.a = 1;
}
expect {
    1|200|200
}

# =============================================================================
# 26. FULL OUTER with duplicates on both sides during grace
# =============================================================================

@cross-check-integrity
test grace-full-outer-heavy-duplicates {
    CREATE TABLE t1(a INTEGER, b TEXT);
    CREATE TABLE t2(c INTEGER, d TEXT);
    -- 10 copies of each key on t1, 10 on t2, 50 distinct keys
    INSERT INTO t1 SELECT value % 50, 'L' || value FROM generate_series(1, 500);
    INSERT INTO t2 SELECT value % 50, 'R' || value FROM generate_series(1, 500);
    -- Inner matches: 50 keys * 10 * 10 = 5000
    -- No unmatched on either side
    SELECT count(*) FROM t1 FULL OUTER JOIN t2 ON t1.a = t2.c;
}
expect {
    5000
}

@cross-check-integrity
test grace-full-outer-partial-with-duplicates {
    CREATE TABLE t1(a INTEGER, b TEXT);
    CREATE TABLE t2(c INTEGER, d TEXT);
    -- t1: keys 0-49, 10 copies each (500 rows)
    -- t2: keys 25-74, 10 copies each (500 rows)
    -- Overlap: keys 25-49 (25 keys): 25 * 10 * 10 = 2500 matched
    -- Unmatched t1: keys 0-24 (25 keys * 10 copies = 250)
    -- Unmatched t2: keys 50-74 (25 keys * 10 copies = 250)
    INSERT INTO t1 SELECT value % 50, 'L' || value FROM generate_series(1, 500);
    INSERT INTO t2 SELECT (value % 50) + 25, 'R' || value FROM generate_series(1, 500);
    SELECT count(*) FROM t1 FULL OUTER JOIN t2 ON t1.a = t2.c;
}
expect {
    3000
}

# =============================================================================
# 27. Verify LEFT OUTER unmatched build rows with grace
# =============================================================================

@cross-check-integrity
test grace-left-outer-unmatched-build-rows {
    CREATE TABLE build(id INTEGER, name TEXT);
    CREATE TABLE probe(id INTEGER, fk INTEGER, label TEXT);
    -- build: 800 rows, probe: only matches first 400
    INSERT INTO build SELECT value, 'build_' || value FROM generate_series(1, 800);
    INSERT INTO probe SELECT value, value, 'probe_' || value FROM generate_series(1, 400);
    -- LEFT JOIN on build: all 800 build rows, but only 400 have matches
    -- Wait - this is build LEFT JOIN probe, so build is on the left
    SELECT count(*), count(probe.fk) FROM build LEFT JOIN probe ON build.id = probe.fk;
}
expect {
    800|400
}

# =============================================================================
# 28. Stress test: very large result set through grace
# =============================================================================

@cross-check-integrity
test grace-stress-large-result {
    CREATE TABLE t1(a INTEGER, b TEXT);
    CREATE TABLE t2(c INTEGER, d TEXT);
    -- 20 distinct keys, ~40 rows per key on each side -> 1600 combos per key
    INSERT INTO t1 SELECT value % 20, 'L' || value FROM generate_series(1, 800);
    INSERT INTO t2 SELECT value % 20, 'R' || value FROM generate_series(1, 800);
    SELECT count(*) FROM t1 JOIN t2 ON t1.a = t2.c;
}
expect {
    32000
}

# =============================================================================
# 29. Grace hash join with COALESCE/IFNULL in SELECT
# =============================================================================

@cross-check-integrity
test grace-coalesce-select {
    CREATE TABLE t1(a INTEGER, b INTEGER);
    CREATE TABLE t2(c INTEGER, d INTEGER);
    INSERT INTO t1 SELECT value, value FROM generate_series(1, 600);
    INSERT INTO t2 SELECT value + 300, value FROM generate_series(1, 600);
    SELECT count(*), sum(COALESCE(t2.d, -1))
    FROM t1 LEFT JOIN t2 ON t1.a = t2.c;
}
expect {
    600|44850
}

# =============================================================================
# 30. Grace hash join with complex ON condition and extra WHERE
# =============================================================================

@cross-check-integrity
test grace-complex-on-and-where {
    CREATE TABLE t1(a INTEGER, b INTEGER, c TEXT);
    CREATE TABLE t2(x INTEGER, y INTEGER, z TEXT);
    INSERT INTO t1 SELECT value, value % 10, 'L' || value FROM generate_series(1, 800);
    INSERT INTO t2 SELECT value, value % 10, 'R' || value FROM generate_series(1, 800);
    -- Join on a=x, but also filter with WHERE on both sides
    SELECT count(*) FROM t1 JOIN t2 ON t1.a = t2.x
    WHERE t1.b < 5 AND t2.y < 5;
}
expect {
    400
}
