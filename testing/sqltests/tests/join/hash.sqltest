@database :memory:

# =============================================================================
# Adversarial Grace Hash Join Tests
# =============================================================================
# These tests are designed to trigger grace hash join spilling (32KB budget in
# debug builds) and verify correctness of partition-based processing.
# Tables are created WITHOUT indexes on join columns to force hash join selection.

# =============================================================================
# 1. Basic INNER grace hash join - enough rows to force spilling
# =============================================================================

@cross-check-integrity
test grace-inner-join-basic {
    CREATE TABLE build(id INTEGER PRIMARY KEY, val TEXT);
    CREATE TABLE probe(id INTEGER PRIMARY KEY, fk INTEGER, label TEXT);
    INSERT INTO build SELECT value, 'b' || value FROM generate_series(1, 800);
    INSERT INTO probe SELECT value, value, 'p' || value FROM generate_series(1, 800);
    SELECT count(*) FROM build JOIN probe ON build.id = probe.fk;
}
expect {
    800
}

# =============================================================================
# 2. INNER join with many-to-many duplicates (heavy hash collisions)
# =============================================================================

@cross-check-integrity
test grace-inner-many-to-many {
    CREATE TABLE t1(a INTEGER, b TEXT);
    CREATE TABLE t2(c INTEGER, d TEXT);
    -- 800 rows, but only 40 distinct keys => 20 matches per key on each side
    INSERT INTO t1 SELECT value % 40, 'left' || value FROM generate_series(1, 800);
    INSERT INTO t2 SELECT value % 40, 'right' || value FROM generate_series(1, 800);
    SELECT count(*) FROM t1 JOIN t2 ON t1.a = t2.c;
}
expect {
    16000
}

@cross-check-integrity
test grace-inner-many-to-many-agg {
    CREATE TABLE t1(a INTEGER, b TEXT);
    CREATE TABLE t2(c INTEGER, d TEXT);
    INSERT INTO t1 SELECT value % 40, 'left' || value FROM generate_series(1, 800);
    INSERT INTO t2 SELECT value % 40, 'right' || value FROM generate_series(1, 800);
    SELECT t1.a, count(*) as cnt FROM t1 JOIN t2 ON t1.a = t2.c GROUP BY t1.a ORDER BY t1.a LIMIT 5;
}
expect {
    0|400
    1|400
    2|400
    3|400
    4|400
}

# =============================================================================
# 3. NULL keys in join columns - NULLs must never match
# =============================================================================

@cross-check-integrity
test grace-null-keys-inner {
    CREATE TABLE t1(a INTEGER, b TEXT);
    CREATE TABLE t2(c INTEGER, d TEXT);
    -- Mix NULLs with real values. 400 rows with value, 400 with NULL key
    INSERT INTO t1 SELECT CASE WHEN value <= 400 THEN value ELSE NULL END, 'L' || value FROM generate_series(1, 800);
    INSERT INTO t2 SELECT CASE WHEN value <= 400 THEN value ELSE NULL END, 'R' || value FROM generate_series(1, 800);
    SELECT count(*) FROM t1 JOIN t2 ON t1.a = t2.c;
}
expect {
    400
}

@cross-check-integrity
test grace-null-keys-left-join {
    CREATE TABLE t1(a INTEGER, b TEXT);
    CREATE TABLE t2(c INTEGER, d TEXT);
    INSERT INTO t1 SELECT CASE WHEN value <= 400 THEN value ELSE NULL END, 'L' || value FROM generate_series(1, 800);
    INSERT INTO t2 SELECT CASE WHEN value <= 400 THEN value ELSE NULL END, 'R' || value FROM generate_series(1, 800);
    -- LEFT JOIN: all 800 rows from t1, but NULL keys don't match
    SELECT count(*) FROM t1 LEFT JOIN t2 ON t1.a = t2.c;
}
expect {
    800
}

@cross-check-integrity
test grace-null-keys-left-join-count-matched {
    CREATE TABLE t1(a INTEGER, b TEXT);
    CREATE TABLE t2(c INTEGER, d TEXT);
    INSERT INTO t1 SELECT CASE WHEN value <= 400 THEN value ELSE NULL END, 'L' || value FROM generate_series(1, 800);
    INSERT INTO t2 SELECT CASE WHEN value <= 400 THEN value ELSE NULL END, 'R' || value FROM generate_series(1, 800);
    -- count(t2.c) excludes NULLs from unmatched left rows
    SELECT count(*), count(t2.c) FROM t1 LEFT JOIN t2 ON t1.a = t2.c;
}
expect {
    800|400
}

# =============================================================================
# 4. Mixed INTEGER and REAL types in join keys
# =============================================================================

@cross-check-integrity
test grace-mixed-int-real-join {
    CREATE TABLE t1(a INTEGER, b TEXT);
    CREATE TABLE t2(c REAL, d TEXT);
    INSERT INTO t1 SELECT value, 'int' || value FROM generate_series(1, 600);
    INSERT INTO t2 SELECT CAST(value AS REAL), 'real' || value FROM generate_series(1, 600);
    SELECT count(*) FROM t1 JOIN t2 ON t1.a = t2.c;
}
expect {
    600
}

@cross-check-integrity
test grace-mixed-int-real-spot-check {
    CREATE TABLE t1(a INTEGER, b TEXT);
    CREATE TABLE t2(c REAL, d TEXT);
    INSERT INTO t1 SELECT value, 'int' || value FROM generate_series(1, 600);
    INSERT INTO t2 SELECT CAST(value AS REAL), 'real' || value FROM generate_series(1, 600);
    SELECT t1.a, t1.b, t2.d FROM t1 JOIN t2 ON t1.a = t2.c WHERE t1.a IN (1, 300, 600) ORDER BY t1.a;
}
expect {
    1|int1|real1
    300|int300|real300
    600|int600|real600
}

# =============================================================================
# 5. Multi-column join keys
# =============================================================================

@cross-check-integrity
test grace-multi-column-key {
    CREATE TABLE t1(a INTEGER, b INTEGER, payload TEXT);
    CREATE TABLE t2(x INTEGER, y INTEGER, data TEXT);
    INSERT INTO t1 SELECT value / 30, value % 30, 'L' || value FROM generate_series(1, 900);
    INSERT INTO t2 SELECT value / 30, value % 30, 'R' || value FROM generate_series(1, 900);
    SELECT count(*) FROM t1 JOIN t2 ON t1.a = t2.x AND t1.b = t2.y;
}
expect {
    900
}

@cross-check-integrity
test grace-multi-column-key-partial-overlap {
    CREATE TABLE t1(a INTEGER, b INTEGER, payload TEXT);
    CREATE TABLE t2(x INTEGER, y INTEGER, data TEXT);
    -- t1 has composite keys (a, b) where a in [0..29], b in [0..29]
    INSERT INTO t1 SELECT value / 30, value % 30, 'L' || value FROM generate_series(0, 899);
    -- t2 has shifted range: a in [15..44], b in [0..29] -> overlap on a in [15..29]
    INSERT INTO t2 SELECT (value / 30) + 15, value % 30, 'R' || value FROM generate_series(0, 899);
    SELECT count(*) FROM t1 JOIN t2 ON t1.a = t2.x AND t1.b = t2.y;
}
expect {
    450
}

# =============================================================================
# 6. LEFT OUTER join with grace spilling - unmatched rows
# =============================================================================

@cross-check-integrity
test grace-left-outer-all-unmatched {
    CREATE TABLE t1(a INTEGER, b TEXT);
    CREATE TABLE t2(c INTEGER, d TEXT);
    INSERT INTO t1 SELECT value, 'L' || value FROM generate_series(1, 600);
    INSERT INTO t2 SELECT value + 1000, 'R' || value FROM generate_series(1, 600);
    -- No overlap at all -> every left row is unmatched
    SELECT count(*) FROM t1 LEFT JOIN t2 ON t1.a = t2.c;
}
expect {
    600
}

@cross-check-integrity
test grace-left-outer-all-unmatched-nulls {
    CREATE TABLE t1(a INTEGER, b TEXT);
    CREATE TABLE t2(c INTEGER, d TEXT);
    INSERT INTO t1 SELECT value, 'L' || value FROM generate_series(1, 600);
    INSERT INTO t2 SELECT value + 1000, 'R' || value FROM generate_series(1, 600);
    -- All t2 columns should be NULL
    SELECT count(*), count(t2.c) FROM t1 LEFT JOIN t2 ON t1.a = t2.c;
}
expect {
    600|0
}

@cross-check-integrity
test grace-left-outer-partial-match {
    CREATE TABLE t1(a INTEGER, b TEXT);
    CREATE TABLE t2(c INTEGER, d TEXT);
    -- t1: 1..800, t2: 401..1200 -> overlap on 401..800 (400 matches)
    INSERT INTO t1 SELECT value, 'L' || value FROM generate_series(1, 800);
    INSERT INTO t2 SELECT value + 400, 'R' || value FROM generate_series(1, 800);
    SELECT count(*) as total, count(t2.c) as matched FROM t1 LEFT JOIN t2 ON t1.a = t2.c;
}
expect {
    800|400
}

@cross-check-integrity
test grace-left-outer-with-duplicates {
    CREATE TABLE t1(a INTEGER, b TEXT);
    CREATE TABLE t2(c INTEGER, d TEXT);
    -- t1: 800 rows with 40 distinct keys
    -- t2: 400 rows with 20 distinct keys (subset of t1's keys)
    INSERT INTO t1 SELECT value % 40, 'L' || value FROM generate_series(1, 800);
    INSERT INTO t2 SELECT value % 20, 'R' || value FROM generate_series(1, 400);
    -- Keys 0-19: each t1 key has 20 rows, each t2 key has 20 rows -> 400 per key, 20 keys -> 8000
    -- Keys 20-39: each t1 key has 20 rows, no match -> 20 per key, 20 keys -> 400
    -- Total: 8400
    SELECT count(*) FROM t1 LEFT JOIN t2 ON t1.a = t2.c;
}
expect {
    8400
}

# =============================================================================
# 7. FULL OUTER join with grace spilling
# =============================================================================

@cross-check-integrity
test grace-full-outer-no-overlap {
    CREATE TABLE t1(a INTEGER, b TEXT);
    CREATE TABLE t2(c INTEGER, d TEXT);
    INSERT INTO t1 SELECT value, 'L' || value FROM generate_series(1, 500);
    INSERT INTO t2 SELECT value + 500, 'R' || value FROM generate_series(1, 500);
    -- No overlap: 500 unmatched from each side = 1000
    SELECT count(*) FROM t1 FULL OUTER JOIN t2 ON t1.a = t2.c;
}
expect {
    1000
}

@cross-check-integrity
test grace-full-outer-complete-overlap {
    CREATE TABLE t1(a INTEGER, b TEXT);
    CREATE TABLE t2(c INTEGER, d TEXT);
    INSERT INTO t1 SELECT value, 'L' || value FROM generate_series(1, 600);
    INSERT INTO t2 SELECT value, 'R' || value FROM generate_series(1, 600);
    SELECT count(*) FROM t1 FULL OUTER JOIN t2 ON t1.a = t2.c;
}
expect {
    600
}

@cross-check-integrity
test grace-full-outer-partial-overlap {
    CREATE TABLE t1(a INTEGER, b TEXT);
    CREATE TABLE t2(c INTEGER, d TEXT);
    -- t1: 1..600, t2: 301..900 -> overlap 301..600 (300 matched)
    -- unmatched t1: 1..300 (300), unmatched t2: 601..900 (300)
    INSERT INTO t1 SELECT value, 'L' || value FROM generate_series(1, 600);
    INSERT INTO t2 SELECT value + 300, 'R' || value FROM generate_series(1, 600);
    SELECT count(*) FROM t1 FULL OUTER JOIN t2 ON t1.a = t2.c;
}
expect {
    900
}

@cross-check-integrity
test grace-full-outer-null-counting {
    CREATE TABLE t1(a INTEGER, b TEXT);
    CREATE TABLE t2(c INTEGER, d TEXT);
    INSERT INTO t1 SELECT value, 'L' || value FROM generate_series(1, 600);
    INSERT INTO t2 SELECT value + 300, 'R' || value FROM generate_series(1, 600);
    -- count(t1.a) = 600 (matched 300 + unmatched 300), count(t2.c) = 600 (matched 300 + unmatched 300)
    SELECT count(*), count(t1.a), count(t2.c) FROM t1 FULL OUTER JOIN t2 ON t1.a = t2.c;
}
expect {
    900|600|600
}

# =============================================================================
# 8. Aggregation correctness over grace hash joins
# =============================================================================

@cross-check-integrity
test grace-agg-sum {
    CREATE TABLE t1(a INTEGER, v INTEGER);
    CREATE TABLE t2(b INTEGER, w INTEGER);
    INSERT INTO t1 SELECT value, value * 10 FROM generate_series(1, 600);
    INSERT INTO t2 SELECT value, value * 100 FROM generate_series(1, 600);
    SELECT sum(t1.v), sum(t2.w) FROM t1 JOIN t2 ON t1.a = t2.b;
}
expect {
    1803000|18030000
}

@cross-check-integrity
test grace-agg-group-by {
    CREATE TABLE t1(a INTEGER, grp INTEGER);
    CREATE TABLE t2(b INTEGER, val INTEGER);
    -- 900 rows, 3 groups (0,1,2), 300 rows each
    INSERT INTO t1 SELECT value, value % 3 FROM generate_series(1, 900);
    INSERT INTO t2 SELECT value, value FROM generate_series(1, 900);
    SELECT t1.grp, count(*), sum(t2.val) FROM t1 JOIN t2 ON t1.a = t2.b GROUP BY t1.grp ORDER BY t1.grp;
}
expect {
    0|300|135450
    1|300|134850
    2|300|135150
}

@cross-check-integrity
test grace-agg-count-distinct {
    CREATE TABLE t1(a INTEGER, b TEXT);
    CREATE TABLE t2(c INTEGER, d TEXT);
    -- 600 rows with 60 distinct keys (10 dupes each)
    INSERT INTO t1 SELECT value % 60, 'L' || value FROM generate_series(1, 600);
    INSERT INTO t2 SELECT value % 60, 'R' || value FROM generate_series(1, 600);
    SELECT count(DISTINCT t1.a) FROM t1 JOIN t2 ON t1.a = t2.c;
}
expect {
    60
}

