# =============================================================================
# 15. Asymmetric table sizes (small build, large probe)
# =============================================================================

@cross-check-integrity
test grace-asymmetric-small-build-large-probe {
    CREATE TABLE t1(a INTEGER, b TEXT);
    CREATE TABLE t2(c INTEGER, d TEXT);
    INSERT INTO t1 SELECT value, 'build' || value FROM generate_series(1, 50);
    INSERT INTO t2 SELECT value % 50 + 1, 'probe' || value FROM generate_series(1, 1000);
    -- Each build key matches 20 probe rows -> 50 * 20 = 1000
    SELECT count(*) FROM t1 JOIN t2 ON t1.a = t2.c;
}
expect {
    1000
}

@cross-check-integrity
test grace-asymmetric-large-build-small-probe {
    CREATE TABLE t1(a INTEGER, b TEXT);
    CREATE TABLE t2(c INTEGER, d TEXT);
    INSERT INTO t1 SELECT value, 'build' || value FROM generate_series(1, 1000);
    INSERT INTO t2 SELECT value * 10, 'probe' || value FROM generate_series(1, 100);
    -- Only every 10th build key matches -> 100 matches
    SELECT count(*) FROM t1 JOIN t2 ON t1.a = t2.c;
}
expect {
    100
}

