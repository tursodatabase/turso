# 14. WHERE clause filtering after grace hash join
# =============================================================================

@cross-check-integrity
test grace-post-join-filter {
    CREATE TABLE t1(a INTEGER, b INTEGER);
    CREATE TABLE t2(c INTEGER, d INTEGER);
    INSERT INTO t1 SELECT value, value * 2 FROM generate_series(1, 800);
    INSERT INTO t2 SELECT value, value * 3 FROM generate_series(1, 800);
    SELECT count(*) FROM t1 JOIN t2 ON t1.a = t2.c WHERE t1.b + t2.d > 2000;
}
