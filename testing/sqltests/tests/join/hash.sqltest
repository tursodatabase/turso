        FROM t1 JOIN t2 ON t1.a = t2.c
        WHERE t1.b > 1000
    ) sub;
}
expect {
    300
}

# =============================================================================
# 20. Verify exact row values across grace partitions
# =============================================================================
# This is the most adversarial correctness test: verify that every single
# matched pair has the correct values, not just the count.

@cross-check-integrity
test grace-exact-values-checksum {
    CREATE TABLE t1(a INTEGER, b INTEGER);
    CREATE TABLE t2(c INTEGER, d INTEGER);
    INSERT INTO t1 SELECT value, value * 7 FROM generate_series(1, 800);
    INSERT INTO t2 SELECT value, value * 11 FROM generate_series(1, 800);
    -- For each matched pair (a=c), verify a*7 = b and c*11 = d
    -- If any grace partition corruption happens, this sum will be wrong
    SELECT sum(t1.a), sum(t1.b), sum(t2.d), sum(t1.b + t2.d) FROM t1 JOIN t2 ON t1.a = t2.c;
}
expect {
    320400|2242800|3524400|5767200
}

# =============================================================================
# 21. LEFT OUTER with aggregation over grace spill
# =============================================================================

@cross-check-integrity
test grace-left-outer-agg-group {
    CREATE TABLE orders(id INTEGER PRIMARY KEY, customer_id INTEGER);
    CREATE TABLE items(id INTEGER PRIMARY KEY, order_id INTEGER, amount INTEGER);
    INSERT INTO orders SELECT value, value % 100 FROM generate_series(1, 800);
    INSERT INTO items SELECT value, ((value - 1) % 800) + 1, value * 5 FROM generate_series(1, 1600);
    -- Each order has 2 items. Left join ensures all orders appear.
    SELECT count(DISTINCT orders.id), count(items.id), sum(items.amount)
    FROM orders LEFT JOIN items ON orders.id = items.order_id;
}
expect {
    800|1600|6404000
}

# =============================================================================
# 22. HAVING clause with grace hash join
# =============================================================================

@cross-check-integrity
test grace-having {
    CREATE TABLE t1(a INTEGER, grp INTEGER);
    CREATE TABLE t2(b INTEGER, val INTEGER);
    INSERT INTO t1 SELECT value, value % 20 FROM generate_series(1, 800);
    INSERT INTO t2 SELECT value, 1 FROM generate_series(1, 800);
    SELECT t1.grp, count(*) as cnt FROM t1 JOIN t2 ON t1.a = t2.b
    GROUP BY t1.grp HAVING count(*) > 39
    ORDER BY t1.grp;
}
expect {
    0|40
    1|40
    2|40
    3|40
    4|40
    5|40
    6|40
    7|40
    8|40
    9|40
    10|40
    11|40
    12|40
    13|40
    14|40
    15|40
    16|40
    17|40
    18|40
    19|40
}

