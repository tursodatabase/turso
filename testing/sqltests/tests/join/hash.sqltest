# =============================================================================
# 12. Text join keys (tests string hashing and comparison through spill)
# =============================================================================

@cross-check-integrity
test grace-text-keys {
    CREATE TABLE t1(k TEXT, v INTEGER);
    CREATE TABLE t2(k TEXT, v INTEGER);
    INSERT INTO t1 SELECT 'key_' || printf('%04d', value), value FROM generate_series(1, 700);
    INSERT INTO t2 SELECT 'key_' || printf('%04d', value), value * 10 FROM generate_series(1, 700);
    SELECT count(*) FROM t1 JOIN t2 ON t1.k = t2.k;
}
expect {
    700
}

@cross-check-integrity
test grace-text-keys-spot-check {
    CREATE TABLE t1(k TEXT, v INTEGER);
    CREATE TABLE t2(k TEXT, v INTEGER);
    INSERT INTO t1 SELECT 'key_' || printf('%04d', value), value FROM generate_series(1, 700);
    INSERT INTO t2 SELECT 'key_' || printf('%04d', value), value * 10 FROM generate_series(1, 700);
    SELECT t1.k, t1.v, t2.v FROM t1 JOIN t2 ON t1.k = t2.k
    WHERE t1.k IN ('key_0001', 'key_0350', 'key_0700')
    ORDER BY t1.k;
}
expect {
    key_0001|1|10
    key_0350|350|3500
    key_0700|700|7000
}

