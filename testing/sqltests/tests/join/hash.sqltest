    INSERT INTO t1 SELECT value, 'L' || value FROM generate_series(1, 800);
    INSERT INTO t2 SELECT value, 'R' || value FROM generate_series(1, 800);
    SELECT count(*) FROM (SELECT t1.a FROM t1 JOIN t2 ON t1.a = t2.c LIMIT 10);
}
