# =============================================================================
# 18. DISTINCT over grace hash join
# =============================================================================

@cross-check-integrity
test grace-distinct {
    CREATE TABLE t1(a INTEGER, b TEXT);
    CREATE TABLE t2(c INTEGER, d TEXT);
    -- Heavy duplicates: 20 copies of each key on each side
    INSERT INTO t1 SELECT value % 50, 'L' || value FROM generate_series(1, 1000);
    INSERT INTO t2 SELECT value % 50, 'R' || value FROM generate_series(1, 1000);
