@database :memory:

# Tests that target the top-K heap-sort path activated for
# `ORDER BY ... LIMIT` queries. The path is selected in
# core/translate/order_by.rs when limit_ctx is set, no DISTINCT/GROUP BY,
# no explicit NULLS ordering, and no custom-comparator columns.

# ===== sanity =====

test order-by-limit-basic-asc {
    CREATE TABLE t(x);
    INSERT INTO t VALUES (3),(1),(4),(1),(5),(9),(2),(6);
    SELECT x FROM t ORDER BY x LIMIT 3;
}
expect {
    1
    1
    2
}

test order-by-limit-basic-desc {
    CREATE TABLE t(x);
    INSERT INTO t VALUES (3),(1),(4),(1),(5),(9),(2),(6);
    SELECT x FROM t ORDER BY x DESC LIMIT 3;
}
expect {
    9
    6
    5
}

# ===== boundary LIMIT values =====

test order-by-limit-zero {
    CREATE TABLE t(x);
    INSERT INTO t VALUES (3),(1),(4),(1),(5);
    SELECT x FROM t ORDER BY x LIMIT 0;
}
expect {
}

# LIMIT -1 is SQLite idiom for "no limit". Heap-sort path must not
# truncate the result set in this case.
test order-by-limit-negative-one {
    CREATE TABLE t(x);
    INSERT INTO t VALUES (3),(1),(4),(1),(5),(9),(2),(6);
    SELECT x FROM t ORDER BY x LIMIT -1;
}
expect {
    1
    1
    2
    3
    4
    5
    6
    9
}

test order-by-limit-negative-large {
    CREATE TABLE t(x);
    INSERT INTO t VALUES (3),(1),(4),(1),(5);
    SELECT x FROM t ORDER BY x LIMIT -1000;
}
expect {
    1
    1
    3
    4
    5
}

test order-by-limit-negative-with-offset {
    CREATE TABLE t(x);
    INSERT INTO t VALUES (3),(1),(4),(1),(5),(9),(2),(6);
    SELECT x FROM t ORDER BY x LIMIT -1 OFFSET 3;
}
expect {
    3
    4
    5
    6
    9
}

test order-by-limit-i64-min {
    CREATE TABLE t(x);
    INSERT INTO t VALUES (3),(1),(2);
    SELECT x FROM t ORDER BY x LIMIT -9223372036854775808;
}
expect {
    1
    2
    3
}

# ===== LIMIT + OFFSET =====

test order-by-limit-with-offset {
    CREATE TABLE t(x);
    INSERT INTO t VALUES (3),(1),(4),(1),(5),(9),(2),(6);
    SELECT x FROM t ORDER BY x LIMIT 3 OFFSET 2;
}
expect {
    2
    3
    4
}

test order-by-limit-larger-than-rows {
    CREATE TABLE t(x);
    INSERT INTO t VALUES (3),(1),(2);
    SELECT x FROM t ORDER BY x LIMIT 100;
}
expect {
    1
    2
    3
}

test order-by-limit-offset-past-end {
    CREATE TABLE t(x);
    INSERT INTO t VALUES (3),(1),(2);
    SELECT x FROM t ORDER BY x LIMIT 10 OFFSET 5;
}
expect {
}

# Large OFFSET should not cause overflow when LIMIT+OFFSET is summed in
# the eviction guard.
test order-by-limit-huge-offset {
    CREATE TABLE t(x);
    INSERT INTO t VALUES (3),(1),(2);
    SELECT x FROM t ORDER BY x LIMIT 1 OFFSET 9223372036854775000;
}
expect {
}

# ===== expression / non-literal LIMIT =====

test order-by-limit-expression {
    CREATE TABLE t(x);
    INSERT INTO t VALUES (3),(1),(4),(1),(5);
    SELECT x FROM t ORDER BY x LIMIT 1+1;
}
expect {
    1
    1
}

# A computed negative limit should also mean "no limit".
test order-by-limit-computed-negative {
    CREATE TABLE t(x);
    INSERT INTO t VALUES (3),(1),(2);
    SELECT x FROM t ORDER BY x LIMIT 1-2;
}
expect {
    1
    2
    3
}

# ===== collation =====

test order-by-limit-collate-nocase-column {
    CREATE TABLE t(x TEXT COLLATE NOCASE);
    INSERT INTO t VALUES ('Banana'),('apple'),('Cherry'),('apricot');
    SELECT x FROM t ORDER BY x LIMIT 2;
}
expect {
    apple
    apricot
}

test order-by-limit-collate-nocase-explicit {
    CREATE TABLE t(x TEXT);
    INSERT INTO t VALUES ('Banana'),('apple'),('Cherry'),('apricot');
    SELECT x FROM t ORDER BY x COLLATE NOCASE LIMIT 3;
}
expect {
    apple
    apricot
    Banana
}

test order-by-limit-binary-collation {
    CREATE TABLE t(x TEXT);
    INSERT INTO t VALUES ('Banana'),('apple'),('Cherry'),('apricot');
    SELECT x FROM t ORDER BY x LIMIT 2;
}
expect {
    Banana
    Cherry
}

# ===== multi-column ORDER BY =====

test order-by-limit-multi-col {
    CREATE TABLE t(a, b);
    INSERT INTO t VALUES (1,'b'),(1,'a'),(2,'a'),(1,'c'),(2,'b');
    SELECT a, b FROM t ORDER BY a, b LIMIT 3;
}
expect {
    1|a
    1|b
    1|c
}

test order-by-limit-multi-col-mixed-order {
    CREATE TABLE t(a, b);
    INSERT INTO t VALUES (1,'b'),(1,'a'),(2,'a'),(1,'c'),(2,'b');
    SELECT a, b FROM t ORDER BY a ASC, b DESC LIMIT 3;
}
expect {
    1|c
    1|b
    1|a
}

# ===== NULLs =====

test order-by-limit-nulls-default {
    CREATE TABLE t(x);
    INSERT INTO t VALUES (3),(NULL),(1),(NULL),(2);
    SELECT x FROM t ORDER BY x LIMIT 3;
}
expect {


    1
}

# Explicit NULLS FIRST/LAST disables heap-sort by the existing gate.
# Cover it anyway to ensure the fallback still works.
test order-by-limit-explicit-nulls-first {
    CREATE TABLE t(x);
    INSERT INTO t VALUES (3),(NULL),(1),(NULL),(2);
    SELECT x FROM t ORDER BY x NULLS FIRST LIMIT 3;
}
expect {


    1
}

test order-by-limit-explicit-nulls-last {
    CREATE TABLE t(x);
    INSERT INTO t VALUES (3),(NULL),(1),(NULL),(2);
    SELECT x FROM t ORDER BY x NULLS LAST LIMIT 3;
}
expect {
    1
    2
    3
}

# ===== DISTINCT / GROUP BY (these intentionally fall back to sorter) =====

test order-by-limit-distinct {
    CREATE TABLE t(x);
    INSERT INTO t VALUES (3),(1),(3),(1),(2),(2);
    SELECT DISTINCT x FROM t ORDER BY x LIMIT 2;
}
expect {
    1
    2
}

test order-by-limit-group-by {
    CREATE TABLE t(x, y);
    INSERT INTO t VALUES (1,'a'),(1,'b'),(2,'a'),(2,'b'),(3,'a');
    SELECT x, COUNT(*) FROM t GROUP BY x ORDER BY x LIMIT 2;
}
expect {
    1|2
    2|2
}

# ===== subquery / compound =====

test order-by-limit-in-subquery {
    CREATE TABLE t(x);
    INSERT INTO t VALUES (3),(1),(4),(1),(5);
    SELECT * FROM (SELECT x FROM t ORDER BY x LIMIT 3);
}
expect {
    1
    1
    3
}

test order-by-limit-compound-select {
    CREATE TABLE t(x);
    INSERT INTO t VALUES (3),(1),(5);
    CREATE TABLE u(x);
    INSERT INTO u VALUES (4),(2),(6);
    SELECT x FROM t UNION ALL SELECT x FROM u ORDER BY x LIMIT 4;
}
expect {
    1
    2
    3
    4
}

# ===== FLOAT LIMIT =====

test order-by-limit-float-literal {
    CREATE TABLE t(x);
    INSERT INTO t VALUES (3),(1),(2);
    SELECT x FROM t ORDER BY x LIMIT 2.0;
}
expect {
    1
    2
}

test order-by-limit-float-fractional-error {
    CREATE TABLE t(x);
    INSERT INTO t VALUES (3),(1),(2);
    SELECT x FROM t ORDER BY x LIMIT 2.5;
}
expect error {
    .*
}
