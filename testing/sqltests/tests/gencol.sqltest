@database :memory:

# =============================================================================
# 1. Basics & Syntax Variants
# =============================================================================

test gencol_virtual_basic_1 {
    CREATE TABLE t1(a INTEGER, b AS (a*2));
    INSERT INTO t1(a) VALUES(5);
    SELECT a, b FROM t1;
}
expect {
    5|10
}

test gencol_virtual_basic_2 {
    CREATE TABLE t1(a INTEGER, b AS (a*2) VIRTUAL);
    INSERT INTO t1(a) VALUES(7);
    SELECT a, b FROM t1;
}
expect {
    7|14
}

test gencol_virtual_select_star {
    CREATE TABLE t1(x, y AS (x+1), z);
    INSERT INTO t1(x, z) VALUES(10, 30);
    SELECT * FROM t1;
}
expect {
    10|11|30
}

test gencol_virtual_expression_concat {
    CREATE TABLE t1(first TEXT, last TEXT, full AS (first || ' ' || last));
    INSERT INTO t1(first, last) VALUES('John', 'Doe');
    SELECT full FROM t1;
}
expect {
    John Doe
}

test gencol_generated_always_virtual {
    CREATE TABLE t1(a INTEGER, b GENERATED ALWAYS AS (a*2));
    INSERT INTO t1(a) VALUES(5);
    SELECT b FROM t1;
}
expect {
    10
}

# Multiple generated columns
test gencol_multiple_virtual {
    CREATE TABLE t1(a INTEGER, b AS (a*2), c AS (a*3), d AS (a*4));
    INSERT INTO t1(a) VALUES(5);
    SELECT b, c, d FROM t1;
}
expect {
    10|15|20
}

# Test that INTEGER AS columns are correctly marked as VIRTUAL (hidden=2).
test gencol_pragma_table_xinfo_integer_as_virtual {
    CREATE TABLE t1(a REAL, b INTEGER AS (a), c REAL AS (b), d INTEGER AS (c + 1));
    PRAGMA table_xinfo(t1);
}
expect {
    0|a|REAL|0||0|0
    1|b|INTEGER|0||0|2
    2|c|REAL|0||0|2
    3|d|INTEGER|0||0|2
}

# =============================================================================
# 2. Expression Types
# =============================================================================

# --- Arithmetic operators ---

test gencol_arithmetic_add {
    CREATE TABLE t1(a INTEGER, b INTEGER, c AS (a+b));
    INSERT INTO t1(a, b) VALUES(3, 7);
    SELECT c FROM t1;
}
expect {
    10
}

test gencol_arithmetic_sub {
    CREATE TABLE t1(a INTEGER, b INTEGER, c AS (a-b));
    INSERT INTO t1(a, b) VALUES(10, 4);
    SELECT c FROM t1;
}
expect {
    6
}

test gencol_arithmetic_mul {
    CREATE TABLE t1(a INTEGER, b INTEGER, c AS (a*b));
    INSERT INTO t1(a, b) VALUES(3, 7);
    SELECT c FROM t1;
}
expect {
    21
}

test gencol_arithmetic_div {
    CREATE TABLE t1(a REAL, b REAL, c AS (a/b));
    INSERT INTO t1(a, b) VALUES(10.0, 4.0);
    SELECT c FROM t1;
}
expect {
    2.5
}

test gencol_arithmetic_mod {
    CREATE TABLE t1(a INTEGER, b INTEGER, c AS (a % b));
    INSERT INTO t1(a, b) VALUES(10, 3);
    SELECT c FROM t1;
}
expect {
    1
}

test gencol_unary_minus {
    CREATE TABLE t1(a INTEGER, b AS (-a));
    INSERT INTO t1(a) VALUES(42);
    SELECT b FROM t1;
}
expect {
    -42
}

# --- Comparison operators ---

test gencol_comparison_gt {
    CREATE TABLE t1(a INTEGER, b INTEGER, c AS (a > b));
    INSERT INTO t1(a, b) VALUES(5, 3);
    SELECT c FROM t1;
}
expect {
    1
}

test gencol_comparison_lt {
    CREATE TABLE t1(a INTEGER, b INTEGER, c AS (a < b));
    INSERT INTO t1(a, b) VALUES(5, 3);
    SELECT c FROM t1;
}
expect {
    0
}

test gencol_comparison_eq {
    CREATE TABLE t1(a INTEGER, b INTEGER, c AS (a = b));
    INSERT INTO t1(a, b) VALUES(5, 5);
    SELECT c FROM t1;
}
expect {
    1
}

test gencol_comparison_ne {
    CREATE TABLE t1(a INTEGER, b INTEGER, c AS (a != b));
    INSERT INTO t1(a, b) VALUES(5, 3);
    SELECT c FROM t1;
}
expect {
    1
}

test gencol_comparison_gte {
    CREATE TABLE t1(a INTEGER, b INTEGER, c AS (a >= b));
    INSERT INTO t1(a, b) VALUES(5, 5);
    SELECT c FROM t1;
}
expect {
    1
}

test gencol_comparison_lte {
    CREATE TABLE t1(a INTEGER, b INTEGER, c AS (a <= b));
    INSERT INTO t1(a, b) VALUES(5, 5);
    SELECT c FROM t1;
}
expect {
    1
}

# --- Logical operators ---

test gencol_logical_and {
    CREATE TABLE t1(a INTEGER, b INTEGER, c AS (a AND b));
    INSERT INTO t1(a, b) VALUES(1, 0);
    SELECT c FROM t1;
}
expect {
    0
}

test gencol_logical_or {
    CREATE TABLE t1(a INTEGER, b INTEGER, c AS (a OR b));
    INSERT INTO t1(a, b) VALUES(1, 0);
    SELECT c FROM t1;
}
expect {
    1
}

test gencol_logical_not {
    CREATE TABLE t1(a INTEGER, b AS (NOT a));
    INSERT INTO t1(a) VALUES(0);
    SELECT b FROM t1;
}
expect {
    1
}

# --- String operators ---

test gencol_string_concat {
    CREATE TABLE t1(a TEXT, b TEXT, c AS (a || b));
    INSERT INTO t1(a, b) VALUES('hello', 'world');
    SELECT c FROM t1;
}
expect {
    helloworld
}

test gencol_string_length {
    CREATE TABLE t1(a TEXT, b AS (length(a)));
    INSERT INTO t1(a) VALUES('hello');
    SELECT b FROM t1;
}
expect {
    5
}

test gencol_string_upper {
    CREATE TABLE t1(a TEXT, b AS (upper(a)));
    INSERT INTO t1(a) VALUES('hello');
    SELECT b FROM t1;
}
expect {
    HELLO
}

test gencol_string_lower {
    CREATE TABLE t1(a TEXT, b AS (lower(a)));
    INSERT INTO t1(a) VALUES('HELLO');
    SELECT b FROM t1;
}
expect {
    hello
}

# --- Type coercion ---

test gencol_type_coerce_int_to_text {
    CREATE TABLE t1(a INTEGER, b TEXT AS (CAST(a AS TEXT)));
    INSERT INTO t1(a) VALUES(42);
    SELECT typeof(b), b FROM t1;
}
expect {
    text|42
}

test gencol_type_coerce_text_to_real {
    CREATE TABLE t1(a TEXT, b REAL AS (CAST(a AS REAL)));
    INSERT INTO t1(a) VALUES('3.14');
    SELECT typeof(b), b FROM t1;
}
expect {
    real|3.14
}

# --- CASE expression ---

test gencol_case_expression {
    CREATE TABLE t1(a INTEGER, b AS (CASE WHEN a > 0 THEN 'positive' WHEN a < 0 THEN 'negative' ELSE 'zero' END));
    INSERT INTO t1(a) VALUES(5);
    INSERT INTO t1(a) VALUES(-3);
    INSERT INTO t1(a) VALUES(0);
    SELECT a, b FROM t1;
}
expect {
    5|positive
    -3|negative
    0|zero
}

# --- COALESCE ---

test gencol_coalesce {
    CREATE TABLE t1(a INTEGER, b INTEGER, c AS (COALESCE(a, b, 0)));
    INSERT INTO t1(a, b) VALUES(NULL, NULL);
    INSERT INTO t1(a, b) VALUES(NULL, 5);
    INSERT INTO t1(a, b) VALUES(3, 5);
    SELECT c FROM t1;
}
expect {
    0
    5
    3
}

# --- IIF ---

test gencol_iif {
    CREATE TABLE t1(a INTEGER, b AS (IIF(a > 0, 'yes', 'no')));
    INSERT INTO t1(a) VALUES(1);
    INSERT INTO t1(a) VALUES(-1);
    SELECT a, b FROM t1;
}
expect {
    1|yes
    -1|no
}

# --- NULLIF ---

test gencol_nullif {
    CREATE TABLE t1(a INTEGER, b INTEGER, c AS (NULLIF(a, b)));
    INSERT INTO t1(a, b) VALUES(5, 5);
    INSERT INTO t1(a, b) VALUES(5, 3);
    SELECT c FROM t1;
}
expect {
    (null)
    5
}

# --- IS NULL / IS NOT NULL in expressions ---

test gencol_is_null {
    CREATE TABLE t1(a INTEGER, b AS (a IS NULL));
    INSERT INTO t1(a) VALUES(NULL);
    INSERT INTO t1(a) VALUES(5);
    SELECT b FROM t1;
}
expect {
    1
    0
}

# --- BETWEEN ---

test gencol_between {
    CREATE TABLE t1(a INTEGER, b AS (a BETWEEN 1 AND 10));
    INSERT INTO t1(a) VALUES(5);
    INSERT INTO t1(a) VALUES(15);
    SELECT b FROM t1;
}
expect {
    1
    0
}

# --- IN ---

test gencol_in_list {
    CREATE TABLE t1(a INTEGER, b AS (a IN (1, 2, 3)));
    INSERT INTO t1(a) VALUES(2);
    INSERT INTO t1(a) VALUES(5);
    SELECT b FROM t1;
}
expect {
    1
    0
}

# --- ABS ---

test gencol_abs {
    CREATE TABLE t1(a INTEGER, b AS (ABS(a)));
    INSERT INTO t1(a) VALUES(-42);
    SELECT b FROM t1;
}
expect {
    42
}

# --- LIKE ---

test gencol_like {
    CREATE TABLE t1(a TEXT, b AS (a LIKE 'hello%'));
    INSERT INTO t1(a) VALUES('hello world');
    INSERT INTO t1(a) VALUES('goodbye');
    SELECT b FROM t1;
}
expect {
    1
    0
}

# --- GLOB ---

test gencol_glob {
    CREATE TABLE t1(a TEXT, b AS (a GLOB 'hello*'));
    INSERT INTO t1(a) VALUES('hello world');
    INSERT INTO t1(a) VALUES('goodbye');
    SELECT b FROM t1;
}
expect {
    1
    0
}

# --- Nested expressions ---

test gencol_nested_expr {
    CREATE TABLE t1(a INTEGER, b INTEGER, c AS ((a + b) * (a - b)));
    INSERT INTO t1(a, b) VALUES(5, 3);
    SELECT c FROM t1;
}
expect {
    16
}

# --- Math functions ---

test gencol_math_max {
    CREATE TABLE t1(a INTEGER, b INTEGER, c AS (MAX(a, b)));
    INSERT INTO t1(a, b) VALUES(3, 7);
    SELECT c FROM t1;
}
expect {
    7
}

test gencol_math_min {
    CREATE TABLE t1(a INTEGER, b INTEGER, c AS (MIN(a, b)));
    INSERT INTO t1(a, b) VALUES(3, 7);
    SELECT c FROM t1;
}
expect {
    3
}

# --- SUBSTR ---

test gencol_substr {
    CREATE TABLE t1(a TEXT, b AS (SUBSTR(a, 1, 3)));
    INSERT INTO t1(a) VALUES('hello');
    SELECT b FROM t1;
}
expect {
    hel
}

# --- REPLACE ---

test gencol_replace {
    CREATE TABLE t1(a TEXT, b AS (REPLACE(a, 'world', 'earth')));
    INSERT INTO t1(a) VALUES('hello world');
    SELECT b FROM t1;
}
expect {
    hello earth
}

# --- TRIM ---

test gencol_trim {
    CREATE TABLE t1(a TEXT, b AS (TRIM(a)));
    INSERT INTO t1(a) VALUES('  hello  ');
    SELECT b FROM t1;
}
expect {
    hello
}

# --- TYPEOF ---

test gencol_typeof {
    CREATE TABLE t1(a, b AS (typeof(a)));
    INSERT INTO t1(a) VALUES(42);
    INSERT INTO t1(a) VALUES('hello');
    INSERT INTO t1(a) VALUES(3.14);
    INSERT INTO t1(a) VALUES(NULL);
    SELECT b FROM t1;
}
expect {
    integer
    text
    real
    null
}

# --- UNICODE ---

test gencol_unicode {
    CREATE TABLE t1(a TEXT, b AS (unicode(a)));
    INSERT INTO t1(a) VALUES('A');
    SELECT b FROM t1;
}
expect {
    65
}

# --- INSTR ---

test gencol_instr {
    CREATE TABLE t1(a TEXT, b TEXT, c AS (INSTR(a, b)));
    INSERT INTO t1(a, b) VALUES('hello world', 'world');
    SELECT c FROM t1;
}
expect {
    7
}

# --- HEX ---

test gencol_hex {
    CREATE TABLE t1(a INTEGER, b AS (HEX(a)));
    INSERT INTO t1(a) VALUES(255);
    SELECT b FROM t1;
}
expect {
    323535
}

# --- QUOTE ---

test gencol_quote {
    CREATE TABLE t1(a TEXT, b AS (QUOTE(a)));
    INSERT INTO t1(a) VALUES('hello');
    SELECT b FROM t1;
}
expect {
    'hello'
}

# --- ZEROBLOB ---

test gencol_zeroblob {
    CREATE TABLE t1(a INTEGER, b AS (LENGTH(ZEROBLOB(a))));
    INSERT INTO t1(a) VALUES(10);
    SELECT b FROM t1;
}
expect {
    10
}

# =============================================================================
# 3. Generated Columns Depending on Other Generated Columns
# =============================================================================

test gencol_chain_two {
    CREATE TABLE t1(a INTEGER, b AS (a*2), c AS (b+1));
    INSERT INTO t1(a) VALUES(5);
    SELECT a, b, c FROM t1;
}
expect {
    5|10|11
}

test gencol_chain_three {
    CREATE TABLE t1(a INTEGER, b AS (a*2), c AS (b*3), d AS (c*4));
    INSERT INTO t1(a) VALUES(1);
    SELECT a, b, c, d FROM t1;
}
expect {
    1|2|6|24
}

test gencol_chain_mixed_types {
    CREATE TABLE t1(a INTEGER, b TEXT AS (CAST(a AS TEXT)), c AS (length(b)));
    INSERT INTO t1(a) VALUES(12345);
    SELECT a, b, c FROM t1;
}
expect {
    12345|12345|5
}

test gencol_chain_nonlinear {
    CREATE TABLE t1(a INTEGER, b INTEGER, c AS (a+b), d AS (a*b), e AS (c+d));
    INSERT INTO t1(a, b) VALUES(3, 4);
    SELECT c, d, e FROM t1;
}
expect {
    7|12|19
}

# =============================================================================
# 4. Multiple Rows & UPDATE / DELETE
# =============================================================================

test gencol_multi_row_insert {
    CREATE TABLE t1(a INTEGER, b AS (a*10));
    INSERT INTO t1(a) VALUES(1);
    INSERT INTO t1(a) VALUES(2);
    INSERT INTO t1(a) VALUES(3);
    SELECT a, b FROM t1;
}
expect {
    1|10
    2|20
    3|30
}

test gencol_update_base_column {
    CREATE TABLE t1(a INTEGER, b AS (a*2));
    INSERT INTO t1(a) VALUES(5);
    UPDATE t1 SET a = 10;
    SELECT a, b FROM t1;
}
expect {
    10|20
}

test gencol_delete_row {
    CREATE TABLE t1(a INTEGER, b AS (a*2));
    INSERT INTO t1(a) VALUES(1);
    INSERT INTO t1(a) VALUES(2);
    INSERT INTO t1(a) VALUES(3);
    DELETE FROM t1 WHERE a = 2;
    SELECT a, b FROM t1;
}
expect {
    1|2
    3|6
}

# =============================================================================
# 5. NULL Handling
# =============================================================================

test gencol_null_propagation {
    CREATE TABLE t1(a INTEGER, b AS (a*2));
    INSERT INTO t1(a) VALUES(NULL);
    SELECT a, b FROM t1;
}
expect {
    (null)|(null)
}

test gencol_null_coalesce {
    CREATE TABLE t1(a INTEGER, b AS (COALESCE(a, 0) * 2));
    INSERT INTO t1(a) VALUES(NULL);
    SELECT b FROM t1;
}
expect {
    0
}

test gencol_null_in_chain {
    CREATE TABLE t1(a INTEGER, b AS (a+1), c AS (b*2));
    INSERT INTO t1(a) VALUES(NULL);
    SELECT a, b, c FROM t1;
}
expect {
    (null)|(null)|(null)
}

# =============================================================================
# 6. WHERE / ORDER BY / GROUP BY with Generated Columns
# =============================================================================

test gencol_where_filter {
    CREATE TABLE t1(a INTEGER, b AS (a*2));
    INSERT INTO t1(a) VALUES(1);
    INSERT INTO t1(a) VALUES(2);
    INSERT INTO t1(a) VALUES(3);
    INSERT INTO t1(a) VALUES(4);
    INSERT INTO t1(a) VALUES(5);
    SELECT a, b FROM t1 WHERE b > 6;
}
expect {
    4|8
    5|10
}

test gencol_order_by {
    CREATE TABLE t1(a INTEGER, b AS (a*2));
    INSERT INTO t1(a) VALUES(3);
    INSERT INTO t1(a) VALUES(1);
    INSERT INTO t1(a) VALUES(2);
    SELECT a, b FROM t1 ORDER BY b DESC;
}
expect {
    3|6
    2|4
    1|2
}

test gencol_group_by {
    CREATE TABLE t1(a INTEGER, cat TEXT, b AS (a*2));
    INSERT INTO t1(a, cat) VALUES(1, 'x');
    INSERT INTO t1(a, cat) VALUES(2, 'x');
    INSERT INTO t1(a, cat) VALUES(3, 'y');
    SELECT cat, SUM(b) FROM t1 GROUP BY cat;
}
expect {
    x|6
    y|6
}

# =============================================================================
# 7. JOINs with Generated Columns
# =============================================================================

test gencol_inner_join {
    CREATE TABLE t1(id INTEGER PRIMARY KEY, a INTEGER, b AS (a*2));
    CREATE TABLE t2(id INTEGER PRIMARY KEY, t1_id INTEGER, c INTEGER);
    INSERT INTO t1(id, a) VALUES(1, 5);
    INSERT INTO t1(id, a) VALUES(2, 10);
    INSERT INTO t2(id, t1_id, c) VALUES(1, 1, 100);
    INSERT INTO t2(id, t1_id, c) VALUES(2, 2, 200);
    SELECT t1.a, t1.b, t2.c FROM t1 INNER JOIN t2 ON t1.id = t2.t1_id;
}
expect {
    5|10|100
    10|20|200
}

test gencol_left_join {
    CREATE TABLE t1(id INTEGER PRIMARY KEY, a INTEGER, b AS (a*2));
    CREATE TABLE t2(id INTEGER PRIMARY KEY, t1_id INTEGER, c INTEGER);
    INSERT INTO t1(id, a) VALUES(1, 5);
    INSERT INTO t1(id, a) VALUES(2, 10);
    INSERT INTO t2(id, t1_id, c) VALUES(1, 1, 100);
    SELECT t1.a, t1.b, t2.c FROM t1 LEFT JOIN t2 ON t1.id = t2.t1_id;
}
expect {
    5|10|100
    10|20|(null)
}

test gencol_join_on_generated_column {
    CREATE TABLE t1(id INTEGER PRIMARY KEY, a INTEGER, b AS (a*2));
    CREATE TABLE t2(id INTEGER PRIMARY KEY, val INTEGER);
    INSERT INTO t1(id, a) VALUES(1, 5);
    INSERT INTO t1(id, a) VALUES(2, 10);
    INSERT INTO t2(id, val) VALUES(10, 100);
    INSERT INTO t2(id, val) VALUES(20, 200);
    SELECT t1.a, t1.b, t2.val FROM t1 INNER JOIN t2 ON t1.b = t2.id;
}
expect {
    5|10|100
    10|20|200
}

# =============================================================================
# 8. Subqueries with Generated Columns
# =============================================================================

test gencol_subquery_in_where {
    CREATE TABLE t1(a INTEGER, b AS (a*2));
    INSERT INTO t1(a) VALUES(1);
    INSERT INTO t1(a) VALUES(2);
    INSERT INTO t1(a) VALUES(3);
    SELECT a, b FROM t1 WHERE b > (SELECT MIN(b) FROM t1);
}
expect {
    2|4
    3|6
}

test gencol_subquery_in_from {
    CREATE TABLE t1(a INTEGER, b AS (a*2));
    INSERT INTO t1(a) VALUES(1);
    INSERT INTO t1(a) VALUES(2);
    INSERT INTO t1(a) VALUES(3);
    SELECT * FROM (SELECT a, b FROM t1 WHERE b > 2);
}
expect {
    2|4
    3|6
}

test gencol_correlated_subquery {
    CREATE TABLE t1(a INTEGER, b AS (a*2));
    CREATE TABLE t2(x INTEGER);
    INSERT INTO t1(a) VALUES(1);
    INSERT INTO t1(a) VALUES(2);
    INSERT INTO t1(a) VALUES(3);
    INSERT INTO t2(x) VALUES(4);
    INSERT INTO t2(x) VALUES(6);
    SELECT a, b FROM t1 WHERE b IN (SELECT x FROM t2);
}
expect {
    2|4
    3|6
}

# =============================================================================
# 9. Type Affinity & TYPEOF
# =============================================================================

test gencol_typeof_integer {
    CREATE TABLE t1(a INTEGER, b AS (a*2));
    INSERT INTO t1(a) VALUES(5);
    SELECT typeof(b) FROM t1;
}
expect {
    integer
}

test gencol_typeof_text {
    CREATE TABLE t1(a TEXT, b AS (a || '!'));
    INSERT INTO t1(a) VALUES('hello');
    SELECT typeof(b) FROM t1;
}
expect {
    text
}

test gencol_typeof_real {
    CREATE TABLE t1(a REAL, b AS (a / 2.0));
    INSERT INTO t1(a) VALUES(5.0);
    SELECT typeof(b) FROM t1;
}
expect {
    real
}

test gencol_typeof_null {
    CREATE TABLE t1(a INTEGER, b AS (a*2));
    INSERT INTO t1(a) VALUES(NULL);
    SELECT typeof(b) FROM t1;
}
expect {
    null
}

# =============================================================================
# 10. Edge Cases & Error Handling
# =============================================================================

# Cannot INSERT into a generated column
test gencol_error_insert_into_generated {
    CREATE TABLE t1(a INTEGER, b AS (a*2));
    INSERT INTO t1(a, b) VALUES(5, 10);
}
expect_error {

}

# Cannot UPDATE a generated column
test gencol_error_update_generated {
    CREATE TABLE t1(a INTEGER, b AS (a*2));
    INSERT INTO t1(a) VALUES(5);
    UPDATE t1 SET b = 20;
}
expect_error {

}

# Empty table
test gencol_empty_table {
    CREATE TABLE t1(a INTEGER, b AS (a*2));
    SELECT * FROM t1;
}
expect {
}

# Large value
test gencol_large_value {
    CREATE TABLE t1(a INTEGER, b AS (a*a*a));
    INSERT INTO t1(a) VALUES(1000);
    SELECT b FROM t1;
}
expect {
    1000000000
}

# Negative values
test gencol_negative_values {
    CREATE TABLE t1(a INTEGER, b AS (a*2));
    INSERT INTO t1(a) VALUES(-5);
    SELECT a, b FROM t1;
}
expect {
    -5|-10
}

# Zero
test gencol_zero {
    CREATE TABLE t1(a INTEGER, b AS (a*2));
    INSERT INTO t1(a) VALUES(0);
    SELECT a, b FROM t1;
}
expect {
    0|0
}

# Boolean-like
test gencol_boolean_like {
    CREATE TABLE t1(a INTEGER, b AS (a > 0));
    INSERT INTO t1(a) VALUES(5);
    INSERT INTO t1(a) VALUES(-5);
    INSERT INTO t1(a) VALUES(0);
    SELECT a, b FROM t1;
}
expect {
    5|1
    -5|0
    0|0
}

# =============================================================================
# 11. Interactions with DISTINCT, LIMIT, OFFSET, UNION
# =============================================================================

test gencol_distinct {
    CREATE TABLE t1(a INTEGER, b AS (a % 2));
    INSERT INTO t1(a) VALUES(1);
    INSERT INTO t1(a) VALUES(2);
    INSERT INTO t1(a) VALUES(3);
    INSERT INTO t1(a) VALUES(4);
    SELECT DISTINCT b FROM t1 ORDER BY b;
}
expect {
    0
    1
}

test gencol_limit_offset {
    CREATE TABLE t1(a INTEGER, b AS (a*10));
    INSERT INTO t1(a) VALUES(1);
    INSERT INTO t1(a) VALUES(2);
    INSERT INTO t1(a) VALUES(3);
    INSERT INTO t1(a) VALUES(4);
    INSERT INTO t1(a) VALUES(5);
    SELECT a, b FROM t1 ORDER BY a LIMIT 2 OFFSET 1;
}
expect {
    2|20
    3|30
}

test gencol_union {
    CREATE TABLE t1(a INTEGER, b AS (a*2));
    CREATE TABLE t2(a INTEGER, b AS (a*3));
    INSERT INTO t1(a) VALUES(1);
    INSERT INTO t1(a) VALUES(2);
    INSERT INTO t2(a) VALUES(1);
    INSERT INTO t2(a) VALUES(2);
    SELECT a, b FROM t1 UNION ALL SELECT a, b FROM t2 ORDER BY a, b;
}
expect {
    1|2
    1|3
    2|4
    2|6
}

# =============================================================================
# 12. Aggregate Functions on Generated Columns
# =============================================================================

test gencol_agg_sum {
    CREATE TABLE t1(a INTEGER, b AS (a*2));
    INSERT INTO t1(a) VALUES(1);
    INSERT INTO t1(a) VALUES(2);
    INSERT INTO t1(a) VALUES(3);
    SELECT SUM(b) FROM t1;
}
expect {
    12
}

test gencol_agg_avg {
    CREATE TABLE t1(a INTEGER, b AS (a*2));
    INSERT INTO t1(a) VALUES(1);
    INSERT INTO t1(a) VALUES(2);
    INSERT INTO t1(a) VALUES(3);
    SELECT AVG(b) FROM t1;
}
expect {
    4.0
}

test gencol_agg_count {
    CREATE TABLE t1(a INTEGER, b AS (a*2));
    INSERT INTO t1(a) VALUES(1);
    INSERT INTO t1(a) VALUES(2);
    INSERT INTO t1(a) VALUES(3);
    SELECT COUNT(b) FROM t1;
}
expect {
    3
}

test gencol_agg_min_max {
    CREATE TABLE t1(a INTEGER, b AS (a*2));
    INSERT INTO t1(a) VALUES(1);
    INSERT INTO t1(a) VALUES(2);
    INSERT INTO t1(a) VALUES(3);
    SELECT MIN(b), MAX(b) FROM t1;
}
expect {
    2|6
}

test gencol_agg_total {
    CREATE TABLE t1(a INTEGER, b AS (a*2));
    INSERT INTO t1(a) VALUES(1);
    INSERT INTO t1(a) VALUES(2);
    INSERT INTO t1(a) VALUES(3);
    SELECT TOTAL(b) FROM t1;
}
expect {
    12.0
}

test gencol_agg_group_concat {
    CREATE TABLE t1(a INTEGER, b AS (a*2));
    INSERT INTO t1(a) VALUES(1);
    INSERT INTO t1(a) VALUES(2);
    INSERT INTO t1(a) VALUES(3);
    SELECT GROUP_CONCAT(b, ',') FROM t1;
}
expect {
    2,4,6
}

# =============================================================================
# 13. HAVING with generated columns
# =============================================================================

test gencol_having {
    CREATE TABLE t1(a INTEGER, cat TEXT, b AS (a*2));
    INSERT INTO t1(a, cat) VALUES(1, 'x');
    INSERT INTO t1(a, cat) VALUES(2, 'x');
    INSERT INTO t1(a, cat) VALUES(3, 'y');
    INSERT INTO t1(a, cat) VALUES(4, 'y');
    SELECT cat, SUM(b) AS s FROM t1 GROUP BY cat HAVING s > 10;
}
expect {
    y|14
}

# =============================================================================
# 14. Complex expressions
# =============================================================================

test gencol_complex_nested {
    CREATE TABLE t1(a INTEGER, b INTEGER, c AS (CASE WHEN a > b THEN a - b ELSE b - a END));
    INSERT INTO t1(a, b) VALUES(10, 3);
    INSERT INTO t1(a, b) VALUES(3, 10);
    SELECT a, b, c FROM t1;
}
expect {
    10|3|7
    3|10|7
}

test gencol_complex_multi_func {
    CREATE TABLE t1(a TEXT, b AS (upper(substr(a, 1, 3)) || '-' || length(a)));
    INSERT INTO t1(a) VALUES('hello');
    INSERT INTO t1(a) VALUES('world');
    SELECT b FROM t1;
}
expect {
    HEL-5
    WOR-5
}

# =============================================================================
# 15. Multiple generated columns with mixed dependencies
# =============================================================================

test gencol_multi_mixed {
    CREATE TABLE t1(
        x INTEGER,
        y INTEGER,
        sum AS (x + y),
        diff AS (x - y),
        product AS (x * y),
        ratio AS (CAST(x AS REAL) / y),
        description AS (
            CASE
                WHEN x > y THEN 'x_larger'
                WHEN x < y THEN 'y_larger'
                ELSE 'equal'
            END
        )
    );
    INSERT INTO t1(x, y) VALUES(10, 3);
    SELECT sum, diff, product, ratio, description FROM t1;
}
expect {
    13|7|30|3.33333333333333|x_larger
}

# =============================================================================
# 16. Interactions with PRIMARY KEY and ROWID
# =============================================================================

test gencol_with_rowid {
    CREATE TABLE t1(a INTEGER PRIMARY KEY, b INTEGER, c AS (b*2));
    INSERT INTO t1(a, b) VALUES(1, 5);
    INSERT INTO t1(a, b) VALUES(2, 10);
    SELECT rowid, a, b, c FROM t1;
}
expect {
    1|1|5|10
    2|2|10|20
}

test gencol_without_explicit_pk {
    CREATE TABLE t1(a INTEGER, b AS (a*2));
    INSERT INTO t1(a) VALUES(5);
    INSERT INTO t1(a) VALUES(10);
    SELECT rowid, a, b FROM t1;
}
expect {
    1|5|10
    2|10|20
}

# =============================================================================
# 17. Views over generated columns
# =============================================================================

test gencol_view {
    CREATE TABLE t1(a INTEGER, b AS (a*2));
    INSERT INTO t1(a) VALUES(1);
    INSERT INTO t1(a) VALUES(2);
    INSERT INTO t1(a) VALUES(3);
    CREATE VIEW v1 AS SELECT a, b, b+1 AS c FROM t1;
    SELECT * FROM v1;
}
expect {
    1|2|3
    2|4|5
    3|6|7
}

# =============================================================================
# 18. Generated column depending on multiple base columns
# =============================================================================

test gencol_multi_base_deps {
    CREATE TABLE t1(a INTEGER, b INTEGER, c INTEGER, d AS (a + b + c), e AS (a * b * c));
    INSERT INTO t1(a, b, c) VALUES(2, 3, 4);
    SELECT d, e FROM t1;
}
expect {
    9|24
}

# =============================================================================
# 19. Generated column with constant expression
# =============================================================================

test gencol_constant_expr {
    CREATE TABLE t1(a INTEGER, b AS (42));
    INSERT INTO t1(a) VALUES(1);
    INSERT INTO t1(a) VALUES(2);
    SELECT a, b FROM t1;
}
expect {
    1|42
    2|42
}

# =============================================================================
# 20. Multiple tables with generated columns in JOIN
# =============================================================================

test gencol_multi_table_join {
    CREATE TABLE t1(a INTEGER, b AS (a*2));
    CREATE TABLE t2(x INTEGER, y AS (x*3));
    INSERT INTO t1(a) VALUES(1);
    INSERT INTO t1(a) VALUES(2);
    INSERT INTO t2(x) VALUES(1);
    INSERT INTO t2(x) VALUES(2);
    SELECT t1.a, t1.b, t2.x, t2.y FROM t1 INNER JOIN t2 ON t1.a = t2.x;
}
expect {
    1|2|1|3
    2|4|2|6
}

# =============================================================================
# 21. Three-table INNER JOIN with generated columns (regression for
#     NULL values when the first table has virtual generated columns)
# =============================================================================

test gencol_three_table_inner_join {
    CREATE TABLE t1(a INTEGER PRIMARY KEY, b INTEGER, c AS (b + 100));
    CREATE TABLE t2(id INTEGER PRIMARY KEY, t1_a INTEGER);
    CREATE TABLE t3(id INTEGER PRIMARY KEY, t2_id INTEGER);
    INSERT INTO t1 VALUES(1, 10);
    INSERT INTO t1 VALUES(2, 20);
    INSERT INTO t2 VALUES(1, 1);
    INSERT INTO t2 VALUES(2, 2);
    INSERT INTO t3 VALUES(1, 1);
    INSERT INTO t3 VALUES(2, 2);
    SELECT t1.a, t1.b, t1.c, t2.id, t3.id
      FROM t1
      INNER JOIN t2 ON t2.t1_a = t1.a
      INNER JOIN t3 ON t3.t2_id = t2.id;
}
expect {
    1|10|110|1|1
    2|20|120|2|2
}

# Same query but selecting only the generated column
test gencol_three_table_inner_join_select_gencol {
    CREATE TABLE t1(a INTEGER PRIMARY KEY, b INTEGER, c AS (b + 100));
    CREATE TABLE t2(id INTEGER PRIMARY KEY, t1_a INTEGER);
    CREATE TABLE t3(id INTEGER PRIMARY KEY, t2_id INTEGER);
    INSERT INTO t1 VALUES(1, 10);
    INSERT INTO t1 VALUES(2, 20);
    INSERT INTO t2 VALUES(1, 1);
    INSERT INTO t2 VALUES(2, 2);
    INSERT INTO t3 VALUES(1, 1);
    INSERT INTO t3 VALUES(2, 2);
    SELECT t1.c
      FROM t1
      INNER JOIN t2 ON t2.t1_a = t1.a
      INNER JOIN t3 ON t3.t2_id = t2.id;
}
expect {
    110
    120
}

# Verify with WHERE clause on generated column
test gencol_three_table_inner_join_where_gencol {
    CREATE TABLE t1(a INTEGER PRIMARY KEY, b INTEGER, c AS (b + 100));
    CREATE TABLE t2(id INTEGER PRIMARY KEY, t1_a INTEGER);
    CREATE TABLE t3(id INTEGER PRIMARY KEY, t2_id INTEGER);
    INSERT INTO t1 VALUES(1, 10);
    INSERT INTO t1 VALUES(2, 20);
    INSERT INTO t2 VALUES(1, 1);
    INSERT INTO t2 VALUES(2, 2);
    INSERT INTO t3 VALUES(1, 1);
    INSERT INTO t3 VALUES(2, 2);
    SELECT t1.a, t1.c
      FROM t1
      INNER JOIN t2 ON t2.t1_a = t1.a
      INNER JOIN t3 ON t3.t2_id = t2.id
      WHERE t1.c > 115;
}
expect {
    2|120
}

# Four-table join variant
test gencol_four_table_inner_join {
    CREATE TABLE t1(a INTEGER PRIMARY KEY, b INTEGER, c AS (b * 2));
    CREATE TABLE t2(id INTEGER PRIMARY KEY, t1_a INTEGER);
    CREATE TABLE t3(id INTEGER PRIMARY KEY, t2_id INTEGER);
    CREATE TABLE t4(id INTEGER PRIMARY KEY, t3_id INTEGER, val TEXT);
    INSERT INTO t1 VALUES(1, 5);
    INSERT INTO t2 VALUES(1, 1);
    INSERT INTO t3 VALUES(1, 1);
    INSERT INTO t4 VALUES(1, 1, 'ok');
    SELECT t1.a, t1.b, t1.c, t4.val
      FROM t1
      INNER JOIN t2 ON t2.t1_a = t1.a
      INNER JOIN t3 ON t3.t2_id = t2.id
      INNER JOIN t4 ON t4.t3_id = t3.id;
}
expect {
    1|5|10|ok
}

# =============================================================================
# 22. Stored/virtual generated columns used with INSERT .. VALUES multiple rows
# =============================================================================

test gencol_insert_multi_values {
    CREATE TABLE t1(a INTEGER, b AS (a + 100));
    INSERT INTO t1(a) VALUES (1), (2), (3);
    SELECT a, b FROM t1;
}
expect {
    1|110
    2|210
    3|310
}
