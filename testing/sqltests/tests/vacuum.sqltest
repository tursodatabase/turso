@database :temp:

@backend rust
test vacuum-uninitialized-file-backed-db-rejected {
    VACUUM;
}
expect error {
    initialized
}

@backend rust
test vacuum-basic-success {
    CREATE TABLE t(id INTEGER PRIMARY KEY, v TEXT);
    INSERT INTO t VALUES (1, 'one'), (2, 'two'), (3, 'three');
    DELETE FROM t WHERE id = 2;
    VACUUM;
    SELECT id, v FROM t ORDER BY id;
    PRAGMA integrity_check;
}
expect {
    1|one
    3|three
    ok
}

# Adapted from SQLite e_vacuum.test: VACUUM reclaims freelist pages after
# deleted data leaves free pages behind.
test vacuum-reclaims-freelist-pages {
    PRAGMA page_size = 1024;
    CREATE TABLE vacuum_freelist_keep(x);
    CREATE TABLE vacuum_freelist_drop(x);
    INSERT INTO vacuum_freelist_drop VALUES(randomblob(2000));
    INSERT INTO vacuum_freelist_drop SELECT randomblob(2000) FROM vacuum_freelist_drop;
    INSERT INTO vacuum_freelist_drop SELECT randomblob(2000) FROM vacuum_freelist_drop;
    DROP TABLE vacuum_freelist_drop;
    PRAGMA freelist_count;
    VACUUM;
    PRAGMA freelist_count;
    PRAGMA integrity_check;
}
expect {
    9
    0
    ok
}

@backend rust
test vacuum-generated-columns {
    CREATE TABLE t1(a INTEGER, b AS (a * 2));
    INSERT INTO t1(a) VALUES(1), (2), (3), (4), (5);
    DELETE FROM t1 WHERE a IN (2, 4);
    VACUUM;
    SELECT a, b FROM t1;
}
expect {
    1|2
    3|6
    5|10
}

@backend rust
@skip-if mvcc "Expression indexes are not supported with MVCC"
test vacuum-generated-columns-with-index {
    CREATE TABLE t1(a INTEGER, b AS (a * 2));
    CREATE INDEX idx1 ON t1(b);
    INSERT INTO t1(a) VALUES(1), (2), (3), (4), (5);
    DELETE FROM t1 WHERE a IN (2, 4);
    VACUUM;
    SELECT a, b FROM t1;
    PRAGMA integrity_check;
}
expect {
    1|2
    3|6
    5|10
    ok
}

# Adapted from SQLite gencol1.test: VACUUM must preserve virtual generated
# columns that have indexes and partial indexes.
@skip-if mvcc "Expression indexes are not supported with MVCC"
test vacuum-generated-columns-with-partial-index {
    CREATE TABLE vacuum_gencol_complex(
        w INT GENERATED ALWAYS AS (a * 10),
        a INT,
        x TEXT AS (typeof(c)),
        b TEXT,
        y TEXT AS (substr(b, a, a + 2)),
        c ANY
    );
    INSERT INTO vacuum_gencol_complex(a,b,c) VALUES(1,'abcdef',5.5),(3,'cantaloupe',NULL);
    CREATE INDEX vacuum_gencol_complex_w ON vacuum_gencol_complex(w);
    CREATE INDEX vacuum_gencol_complex_x ON vacuum_gencol_complex(x) WHERE w BETWEEN 20 AND 40;
    VACUUM;
    SELECT w, x, y FROM vacuum_gencol_complex ORDER BY a;
    SELECT a FROM vacuum_gencol_complex WHERE x = 'null' AND w BETWEEN 20 AND 40;
    PRAGMA integrity_check;
}
expect {
    10|real|abc
    30|null|ntalo
    3
    ok
}

# Adapted from SQLite gencol1.test: SQLite also vacuums databases with stored
# generated columns.
@skip "missing feature: STORED generated columns are not supported; see missing_feature.txt"
test vacuum-stored-generated-columns-from-sqlite {
    CREATE TABLE vacuum_gencol_stored(
        w INT GENERATED ALWAYS AS (a * 10),
        a INT,
        x TEXT AS (typeof(c)) STORED,
        b TEXT,
        y TEXT AS (substr(b, a, a + 2)),
        c ANY
    );
    INSERT INTO vacuum_gencol_stored(a,b,c) VALUES(1,'abcdef',5.5),(3,'cantaloupe',NULL);
    VACUUM;
    PRAGMA integrity_check;
}
expect {
    ok
}

@backend rust
test vacuum-schema-qualified-rejected {
    VACUUM temp;
}
expect error {
    VACUUM is only supported for the main database; schema 'temp' is not supported yet
}

# Adapted from SQLite vacuum5.test: unknown schema-qualified VACUUM reports
# the missing database name.
test vacuum-unknown-schema-rejected {
    VACUUM olaf;
}
expect error {
    unknown database olaf
}

@backend rust
test vacuum-rejected-in-begin {
    CREATE TABLE tx_t(x);
    BEGIN;
    VACUUM;
}
expect error {
    cannot VACUUM from within a transaction
}

@backend rust
test vacuum-rejected-in-savepoint {
    CREATE TABLE sp_t(x);
    SAVEPOINT sp1;
    VACUUM;
}
expect error {
    cannot VACUUM from within a transaction
}

test vacuum-rejected-in-query-only {
    CREATE TABLE qo_t(x);
    PRAGMA query_only = 1;
    VACUUM;
}
expect error {
    Cannot execute VACUUM in query_only mode
}

# Adapted from SQLite vacuum5.test: an explicit main schema qualifier should
# behave like plain VACUUM.
test vacuum-explicit-main-schema {
    CREATE TABLE t1(a INTEGER PRIMARY KEY, b TEXT);
    INSERT INTO t1 VALUES(1, 'one'), (2, 'two'), (3, 'three');
    DELETE FROM t1 WHERE a = 2;
    VACUUM main;
    SELECT a, b FROM t1 ORDER BY a;
    PRAGMA integrity_check;
}
expect {
    1|one
    3|three
    ok
}

# Adapted from SQLite vacuum6.test: duplicate indexes on the same column remain
# valid across VACUUM.
test vacuum-duplicate-indexes-same-column {
    CREATE TABLE t1(x, b);
    CREATE INDEX x1 ON t1(x);
    CREATE INDEX x2 ON t1(x);
    CREATE INDEX x3 ON t1(x);
    INSERT INTO t1 VALUES(2, '');
    VACUUM;
    SELECT count(*) FROM t1 WHERE x = 2;
    PRAGMA integrity_check;
}
expect {
    1
    ok
}

# Adapted from SQLite pragma.test pragma-8.2.4.2: VACUUM preserves the
# user-version header field.
test vacuum-preserves-user-version {
    PRAGMA user_version = 2;
    VACUUM;
    PRAGMA user_version;
    PRAGMA integrity_check;
}
expect {
    2
    ok
}

# Adapted from SQLite pragma.test pragma-8.2.4.2: VACUUM increments the
# schema-version header field.
test vacuum-increments-schema-version {
    CREATE TABLE vacuum_schema_version(x);
    PRAGMA schema_version;
    VACUUM;
    PRAGMA schema_version;
}
expect {
    1
    2
}

# Adapted from SQLite pragma.test pragma-1.9.2: VACUUM preserves
# default_cache_size.
@skip "missing feature: PRAGMA default_cache_size is not supported; see missing_feature.txt"
test vacuum-preserves-default-cache-size-from-sqlite {
    PRAGMA default_cache_size = -123;
    VACUUM;
    PRAGMA cache_size;
    PRAGMA default_cache_size;
}
expect {
    123
    123
}

# Adapted from SQLite vacuum.test vacuum-1.4: VACUUM must preserve schema
# objects that are reloaded after the source image is rebuilt.
test vacuum-preserves-view-and-trigger {
    CREATE TABLE t1(a INTEGER PRIMARY KEY, b TEXT, c TEXT);
    CREATE TABLE vacuum_trigger_log(a INTEGER, b TEXT);
    CREATE VIEW vacuum_view AS SELECT b, c FROM t1 WHERE a > 1;
    CREATE TRIGGER vacuum_t1_ad AFTER DELETE ON t1 BEGIN
        INSERT INTO vacuum_trigger_log VALUES(old.a, old.b);
    END;
    INSERT INTO t1 VALUES(1, 'one', 'alpha'), (2, 'two', 'beta'), (3, 'three', 'gamma');
    DELETE FROM t1 WHERE a = 1;
    VACUUM;
    SELECT b, c FROM vacuum_view ORDER BY b;
    DELETE FROM t1 WHERE a = 2;
    SELECT a, b FROM vacuum_trigger_log ORDER BY a;
    PRAGMA integrity_check;
}
expect {
    three|gamma
    two|beta
    1|one
    2|two
    ok
}

# Adapted from SQLite vacuum.test ticket #515: VACUUM works after a table
# referenced by a view is dropped and recreated with a compatible shape.
test vacuum-after-recreate-view-table {
    CREATE TABLE vacuum_recreate_test(id INTEGER PRIMARY KEY, value TEXT);
    INSERT INTO vacuum_recreate_test VALUES(1, 'before');
    CREATE VIEW vacuum_recreate_view AS SELECT id, value FROM vacuum_recreate_test;
    CREATE TABLE vacuum_recreate_temp(id INTEGER PRIMARY KEY, value TEXT);
    INSERT INTO vacuum_recreate_temp SELECT id, value FROM vacuum_recreate_test;
    DROP TABLE vacuum_recreate_test;
    CREATE TABLE vacuum_recreate_test(id INTEGER PRIMARY KEY, value TEXT);
    INSERT INTO vacuum_recreate_test SELECT id, value FROM vacuum_recreate_temp;
    DROP TABLE vacuum_recreate_temp;
    VACUUM;
    SELECT id, value FROM vacuum_recreate_view;
    PRAGMA integrity_check;
}
expect {
    1|before
    ok
}

# Adapted from SQLite vacuum.test vacuum-6.*: quoted identifiers and BLOB
# literals survive VACUUM.
test vacuum-quoted-table-name-and-blob {
    CREATE TABLE "abc abc"(a, b, c);
    INSERT INTO "abc abc" VALUES(1, 2, 3);
    VACUUM;
    SELECT * FROM "abc abc";
    DELETE FROM "abc abc";
    INSERT INTO "abc abc" VALUES(X'00112233', NULL, NULL);
    VACUUM;
    SELECT count(*) FROM "abc abc" WHERE a = X'00112233';
    PRAGMA integrity_check;
}
expect {
    1|2|3
    1
    ok
}

# Adapted from SQLite vacuum.test vacuum-9.*: sqlite_sequence and
# AUTOINCREMENT state survive VACUUM.
@skip-if mvcc "AUTOINCREMENT is not supported in MVCC mode"
test vacuum-preserves-autoincrement-sequence {
    CREATE TABLE vacuum_autoinc(id INTEGER PRIMARY KEY AUTOINCREMENT, value TEXT);
    INSERT INTO vacuum_autoinc(value) VALUES('hi'), ('there');
    DELETE FROM vacuum_autoinc;
    VACUUM;
    INSERT INTO vacuum_autoinc(value) VALUES('one'), ('two');
    VACUUM;
    SELECT id, value FROM vacuum_autoinc ORDER BY id;
    SELECT name, seq FROM sqlite_sequence WHERE name = 'vacuum_autoinc';
    PRAGMA integrity_check;
}
expect {
    3|one
    4|two
    vacuum_autoinc|4
    ok
}

# Adapted from SQLite vacuum2.test ticket #1121: VACUUM works after all
# AUTOINCREMENT tables have been dropped.
@skip-if mvcc "AUTOINCREMENT is not supported in MVCC mode"
test vacuum-after-dropping-all-autoincrement-tables {
    CREATE TABLE vacuum_drop_autoinc(id INTEGER PRIMARY KEY AUTOINCREMENT, value TEXT);
    DROP TABLE vacuum_drop_autoinc;
    VACUUM;
    PRAGMA integrity_check;
    SELECT count(*) FROM sqlite_schema WHERE name = 'vacuum_drop_autoinc';
}
expect {
    ok
    0
}

# Adapted from SQLite tkt-d82e3f3721.test: VACUUM must preserve
# sqlite_sequence entries in both main and temp schemas.
@skip-if mvcc "AUTOINCREMENT is not supported with MVCC"
test vacuum-preserves-temp-autoincrement-sequence {
    CREATE TABLE vacuum_seq_main(a INTEGER PRIMARY KEY AUTOINCREMENT, b);
    INSERT INTO vacuum_seq_main VALUES(NULL,'abc');
    INSERT INTO vacuum_seq_main VALUES(NULL,'def');
    DELETE FROM vacuum_seq_main;
    INSERT INTO vacuum_seq_main VALUES(NULL,'ghi');
    CREATE TEMP TABLE vacuum_seq_temp(a INTEGER PRIMARY KEY AUTOINCREMENT, b);
    INSERT INTO vacuum_seq_temp VALUES(NULL,'jkl');
    INSERT INTO vacuum_seq_temp VALUES(NULL,'mno');
    DELETE FROM vacuum_seq_temp;
    INSERT INTO vacuum_seq_temp VALUES(NULL,'pqr');
    VACUUM;
    SELECT 'main', * FROM main.sqlite_sequence
    UNION ALL
    SELECT 'temp', * FROM temp.sqlite_sequence
    ORDER BY 2;
}
expect {
    main|vacuum_seq_main|3
    temp|vacuum_seq_temp|3
}

# Adapted from SQLite tkt-d82e3f3721.test: VACUUM must not disturb temp
# tables that shadow persistent tables.
test vacuum-preserves-temp-table-shadowing {
    CREATE TABLE vacuum_shadow(y,z);
    INSERT INTO vacuum_shadow VALUES(8,9);
    CREATE TEMP TABLE vacuum_shadow(x);
    INSERT INTO vacuum_shadow VALUES(1);
    VACUUM;
    SELECT x FROM temp.vacuum_shadow;
    SELECT y, z FROM main.vacuum_shadow;
}
expect {
    1
    8|9
}

# Adapted from SQLite fkey2.test fkey2-6.1: VACUUM must preserve foreign-key
# metadata and table content.
test vacuum-preserves-foreign-key-schema {
    PRAGMA foreign_keys = ON;
    CREATE TABLE vacuum_fk_parent(c UNIQUE, b);
    CREATE TABLE vacuum_fk_child(a REFERENCES vacuum_fk_parent(c), b);
    INSERT INTO vacuum_fk_parent VALUES(1, 2);
    INSERT INTO vacuum_fk_child VALUES(1, 2);
    VACUUM;
    SELECT a, b FROM vacuum_fk_child;
    PRAGMA integrity_check;
}
expect {
    1|2
    ok
}

# Adapted from SQLite without_rowid3.test: VACUUM must preserve a foreign-key
# schema whose child table is created before the parent table.
test vacuum-preserves-child-before-parent-foreign-key {
    PRAGMA foreign_keys = ON;
    CREATE TABLE vacuum_fk_child_first(a REFERENCES vacuum_fk_parent_later(c), b);
    CREATE TABLE vacuum_fk_parent_later(c UNIQUE, b);
    INSERT INTO vacuum_fk_parent_later VALUES(1, 2);
    INSERT INTO vacuum_fk_child_first VALUES(1, 2);
    VACUUM;
    SELECT a, b FROM vacuum_fk_child_first;
    PRAGMA integrity_check;
}
expect {
    1|2
    ok
}

# Adapted from SQLite check.test check-4.10: VACUUM must still rebuild a
# database containing rows inserted while CHECK constraints were ignored.
test vacuum-with-ignored-check-constraints {
    CREATE TABLE vacuum_invalid_check(x, y, CHECK(x + y = 11));
    INSERT INTO vacuum_invalid_check VALUES(4, 7);
    PRAGMA ignore_check_constraints = ON;
    UPDATE vacuum_invalid_check SET x = 0, y = 1;
    PRAGMA ignore_check_constraints = OFF;
    VACUUM;
    SELECT x, y FROM vacuum_invalid_check;
}
expect {
    0|1
}

# Adapted from SQLite insert4.test ticket #2291: VACUUM must preserve UNIQUE
# indexes that contain multiple rows with NULL key parts.
test vacuum-preserves-unique-null-keys {
    CREATE TABLE vacuum_unique_nulls(a, b, UNIQUE(a,b));
    INSERT INTO vacuum_unique_nulls VALUES(NULL,0);
    INSERT INTO vacuum_unique_nulls VALUES(NULL,1);
    INSERT INTO vacuum_unique_nulls VALUES(NULL,1);
    VACUUM;
    SELECT count(*), sum(b) FROM vacuum_unique_nulls;
    PRAGMA integrity_check;
}
expect {
    3|2
    ok
}

# Adapted from SQLite collateB.test: VACUUM must preserve an index on a column
# explicitly declared with the built-in binary collation.
test vacuum-preserves-binary-collation-index {
    CREATE TABLE vacuum_collate_binary(a COLLATE binary);
    CREATE INDEX vacuum_collate_binary_idx ON vacuum_collate_binary(a);
    INSERT INTO vacuum_collate_binary VALUES('one'), ('two'), ('three');
    VACUUM;
    SELECT a FROM vacuum_collate_binary ORDER BY a;
    PRAGMA integrity_check;
}
expect {
    one
    three
    two
    ok
}

# Adapted from SQLite hidden.test and e_vacuum.test: rowids are preserved by
# VACUUM for indexed rowid tables.
test vacuum-preserves-indexed-hidden-rowids {
    CREATE TABLE vacuum_hidden_rowid(a, __hidden__b, c UNIQUE);
    INSERT INTO vacuum_hidden_rowid(a, __hidden__b, c) VALUES(1, 2, 3);
    INSERT INTO vacuum_hidden_rowid(a, __hidden__b, c) VALUES(4, 5, 6);
    INSERT INTO vacuum_hidden_rowid(a, __hidden__b, c) VALUES(7, 8, 9);
    DELETE FROM vacuum_hidden_rowid WHERE __hidden__b = 5;
    VACUUM;
    SELECT rowid, a, __hidden__b, c FROM vacuum_hidden_rowid ORDER BY rowid;
    PRAGMA integrity_check;
}
expect {
    1|1|2|3
    3|7|8|9
    ok
}

# Adapted from SQLite without_rowid1.test: a supported WITHOUT ROWID table can
# be vacuumed without losing its schema or rows.
@skip-if mvcc "WITHOUT ROWID tables are not supported in MVCC mode"
test vacuum-without-rowid-basic {
    CREATE TABLE vacuum_wr(a TEXT PRIMARY KEY, b TEXT) WITHOUT ROWID;
    INSERT INTO vacuum_wr VALUES('a', 'alpha'), ('b', 'beta');
    VACUUM;
    SELECT a, b FROM vacuum_wr ORDER BY a;
    PRAGMA integrity_check;
}
expect {
    a|alpha
    b|beta
    ok
}

# Adapted from SQLite tableopts.test: VACUUM preserves composite-primary-key
# WITHOUT ROWID tables.
@skip-if mvcc "WITHOUT ROWID tables are not supported in MVCC mode"
test vacuum-without-rowid-composite-primary-key {
    CREATE TABLE vacuum_wr_composite(a, b, c, PRIMARY KEY(a,b)) WITHOUT ROWID;
    INSERT INTO vacuum_wr_composite VALUES(1,2,3),(2,3,4);
    VACUUM;
    SELECT c FROM vacuum_wr_composite WHERE a IN (1,2) ORDER BY b;
    PRAGMA integrity_check;
}
expect {
    3
    4
    ok
}

# Adapted from SQLite without_rowid1.test/index6.test/index7.test: SQLite
# vacuums WITHOUT ROWID tables with secondary indexes and UNIQUE constraints.
@skip "missing feature: secondary indexes and secondary UNIQUE constraints on WITHOUT ROWID tables are not supported; see missing_feature.txt"
test vacuum-without-rowid-secondary-indexes-from-sqlite {
    CREATE TABLE vacuum_wr_indexed(a, b UNIQUE, PRIMARY KEY(a)) WITHOUT ROWID;
    CREATE INDEX vacuum_wr_indexed_b ON vacuum_wr_indexed(b);
    INSERT INTO vacuum_wr_indexed VALUES(1, 2), (3, 4);
    VACUUM;
    PRAGMA integrity_check;
}
expect {
    ok
}

# Adapted from SQLite vacuum.test vacuum-10.*: count_changes must not make
# VACUUM return rows or corrupt subsequent execution.
@skip "missing feature: PRAGMA count_changes is not supported; see missing_feature.txt"
test vacuum-with-count-changes {
    CREATE TABLE vacuum_count_changes(a, b);
    INSERT INTO vacuum_count_changes VALUES('a', 'b'), ('c', 'd');
    PRAGMA count_changes = 1;
    VACUUM;
    SELECT count(*) FROM vacuum_count_changes;
    PRAGMA integrity_check;
}
expect {
    2
    ok
}

# Adapted from SQLite misc4.test: malformed schema SQL should surface a stable
# parse error during VACUUM.
@skip "missing feature: PRAGMA writable_schema is not supported; see missing_feature.txt"
test vacuum-malformed-schema-error-from-sqlite {
    CREATE TABLE vacuum_malformed_schema(x);
    PRAGMA writable_schema = ON;
    UPDATE sqlite_master SET sql='CREATE TABLE [M%s%s%s%s%s%s%s%s%s%s%s%s%s'
        WHERE name = 'vacuum_malformed_schema';
    VACUUM;
}
expect error {
    unrecognized token
}

# Adapted from SQLite tkt3762.test: incremental_vacuum after a plain VACUUM
# must not corrupt the database.
@skip "missing feature: PRAGMA incremental_vacuum is not supported; see missing_feature.txt"
test vacuum-before-incremental-vacuum-from-sqlite {
    CREATE TABLE vacuum_incremental_after_plain(x);
    INSERT INTO vacuum_incremental_after_plain VALUES(zeroblob(900));
    INSERT INTO vacuum_incremental_after_plain SELECT x FROM vacuum_incremental_after_plain;
    INSERT INTO vacuum_incremental_after_plain SELECT x FROM vacuum_incremental_after_plain;
    INSERT INTO vacuum_incremental_after_plain SELECT x FROM vacuum_incremental_after_plain;
    DELETE FROM vacuum_incremental_after_plain WHERE rowid > 3;
    VACUUM;
    BEGIN;
    DELETE FROM vacuum_incremental_after_plain WHERE rowid = 2;
    PRAGMA incremental_vacuum(10);
    INSERT INTO vacuum_incremental_after_plain VALUES(zeroblob(3900));
    SELECT count(*) FROM vacuum_incremental_after_plain;
    ROLLBACK;
    PRAGMA integrity_check;
}
expect {
    3
    ok
}

# Adapted from SQLite whereA.test: SQLite verifies VACUUM while
# reverse_unordered_selects is active.
@skip "missing feature: PRAGMA reverse_unordered_selects is not supported; see missing_feature.txt"
test vacuum-with-reverse-unordered-selects-from-sqlite {
    PRAGMA reverse_unordered_selects = 1;
    CREATE TABLE vacuum_reverse_scan(a,b,c);
    INSERT INTO vacuum_reverse_scan VALUES(1,2,3);
    INSERT INTO vacuum_reverse_scan VALUES(2,'hello','world');
    INSERT INTO vacuum_reverse_scan VALUES(3,4.53,NULL);
    VACUUM;
    SELECT * FROM vacuum_reverse_scan;
}
expect {
    3|4.53|
    2|hello|world
    1|2|3
}

# Adapted from SQLite vacuum4.test: a database with auto_vacuum enabled and a
# large schema can be vacuumed without corrupting sqlite_schema.
@skip "missing feature: sqltests do not enable experimental auto-vacuum; see missing_feature.txt"
test vacuum-large-schema-autovacuum {
    PRAGMA auto_vacuum = FULL;
    CREATE TABLE vacuum_large_schema_1(
        c000, c001, c002, c003, c004, c005, c006, c007, c008, c009,
        c010, c011, c012, c013, c014, c015, c016, c017, c018, c019,
        c020, c021, c022, c023, c024, c025, c026, c027, c028, c029,
        c030, c031, c032, c033, c034, c035, c036, c037, c038, c039,
        c040, c041, c042, c043, c044, c045, c046, c047, c048, c049
    );
    CREATE TABLE vacuum_large_schema_2(
        c000, c001, c002, c003, c004, c005, c006, c007, c008, c009,
        c010, c011, c012, c013, c014, c015, c016, c017, c018, c019,
        c020, c021, c022, c023, c024, c025, c026, c027, c028, c029,
        c030, c031, c032, c033, c034, c035, c036, c037, c038, c039,
        c040, c041, c042, c043, c044, c045, c046, c047, c048, c049
    );
    VACUUM;
    SELECT count(*) FROM sqlite_schema WHERE name LIKE 'vacuum_large_schema_%';
    PRAGMA integrity_check;
}
expect {
    2
    ok
}

# Adapted from SQLite vacuum6.test: VACUUM preserves larger indexed records.
test vacuum-large-indexed-records {
    CREATE TABLE vacuum_big_records(a INTEGER PRIMARY KEY, b);
    CREATE INDEX vacuum_big_records_b ON vacuum_big_records(b);
    INSERT INTO vacuum_big_records VALUES(1, randomblob(1200));
    INSERT INTO vacuum_big_records SELECT a + 1, randomblob(1200) FROM vacuum_big_records;
    INSERT INTO vacuum_big_records SELECT a + 2, randomblob(1200) FROM vacuum_big_records;
    INSERT INTO vacuum_big_records SELECT a + 4, randomblob(1200) FROM vacuum_big_records;
    INSERT INTO vacuum_big_records SELECT a + 8, randomblob(1200) FROM vacuum_big_records;
    INSERT INTO vacuum_big_records SELECT a + 16, randomblob(1200) FROM vacuum_big_records;
    INSERT INTO vacuum_big_records SELECT a + 32, randomblob(1200) FROM vacuum_big_records;
    INSERT INTO vacuum_big_records SELECT a + 64, randomblob(1200) FROM vacuum_big_records;
    VACUUM;
    SELECT count(*), sum(length(b)) FROM vacuum_big_records;
    PRAGMA integrity_check;
}
expect {
    128|153600
    ok
}

# Adapted from SQLite vacuum6.test 2.*: VACUUM preserves indexed records
# across a range of payload sizes.
test vacuum-indexed-record-size-matrix {
    CREATE TABLE vacuum_records_400(a INTEGER PRIMARY KEY, b);
    CREATE INDEX vacuum_records_400_b ON vacuum_records_400(b);
    INSERT INTO vacuum_records_400 VALUES(1, randomblob(400));
    INSERT INTO vacuum_records_400 SELECT a + 1, randomblob(400) FROM vacuum_records_400;
    INSERT INTO vacuum_records_400 SELECT a + 2, randomblob(400) FROM vacuum_records_400;
    INSERT INTO vacuum_records_400 SELECT a + 4, randomblob(400) FROM vacuum_records_400;
    INSERT INTO vacuum_records_400 SELECT a + 8, randomblob(400) FROM vacuum_records_400;
    INSERT INTO vacuum_records_400 SELECT a + 16, randomblob(400) FROM vacuum_records_400;
    INSERT INTO vacuum_records_400 SELECT a + 32, randomblob(400) FROM vacuum_records_400;
    INSERT INTO vacuum_records_400 SELECT a + 64, randomblob(400) FROM vacuum_records_400;
    DELETE FROM vacuum_records_400 WHERE a > 100;

    CREATE TABLE vacuum_records_4000(a INTEGER PRIMARY KEY, b);
    CREATE INDEX vacuum_records_4000_b ON vacuum_records_4000(b);
    INSERT INTO vacuum_records_4000 VALUES(1, randomblob(4000));
    INSERT INTO vacuum_records_4000 SELECT a + 1, randomblob(4000) FROM vacuum_records_4000;
    INSERT INTO vacuum_records_4000 SELECT a + 2, randomblob(4000) FROM vacuum_records_4000;
    INSERT INTO vacuum_records_4000 SELECT a + 4, randomblob(4000) FROM vacuum_records_4000;
    INSERT INTO vacuum_records_4000 SELECT a + 8, randomblob(4000) FROM vacuum_records_4000;
    INSERT INTO vacuum_records_4000 SELECT a + 16, randomblob(4000) FROM vacuum_records_4000;
    INSERT INTO vacuum_records_4000 SELECT a + 32, randomblob(4000) FROM vacuum_records_4000;
    INSERT INTO vacuum_records_4000 SELECT a + 64, randomblob(4000) FROM vacuum_records_4000;
    DELETE FROM vacuum_records_4000 WHERE a > 100;

    CREATE TABLE vacuum_records_9999(a INTEGER PRIMARY KEY, b);
    CREATE INDEX vacuum_records_9999_b ON vacuum_records_9999(b);
    INSERT INTO vacuum_records_9999 VALUES(1, randomblob(9999));
    INSERT INTO vacuum_records_9999 SELECT a + 1, randomblob(9999) FROM vacuum_records_9999;
    INSERT INTO vacuum_records_9999 SELECT a + 2, randomblob(9999) FROM vacuum_records_9999;
    INSERT INTO vacuum_records_9999 SELECT a + 4, randomblob(9999) FROM vacuum_records_9999;
    INSERT INTO vacuum_records_9999 SELECT a + 8, randomblob(9999) FROM vacuum_records_9999;
    INSERT INTO vacuum_records_9999 SELECT a + 16, randomblob(9999) FROM vacuum_records_9999;
    INSERT INTO vacuum_records_9999 SELECT a + 32, randomblob(9999) FROM vacuum_records_9999;
    INSERT INTO vacuum_records_9999 SELECT a + 64, randomblob(9999) FROM vacuum_records_9999;
    DELETE FROM vacuum_records_9999 WHERE a > 100;

    VACUUM;
    SELECT count(*), sum(length(b)) FROM vacuum_records_400;
    SELECT count(*), sum(length(b)) FROM vacuum_records_4000;
    SELECT count(*), sum(length(b)) FROM vacuum_records_9999;
    PRAGMA integrity_check;
}
expect {
    100|40000
    100|400000
    100|999900
    ok
}

# Adapted from SQLite vacuum.test ticket #873: a database filename containing
# an apostrophe can be vacuumed.
@backend cli
test vacuum-database-name-with-quote {
    .open a'z.db
    CREATE TABLE t1(t);
    VACUUM;
    PRAGMA integrity_check;
}
expect {
    ok
}

# Adapted from SQLite pagesize.test: an initial page size selected before
# database creation is preserved by VACUUM.
test vacuum-preserves-initial-page-size {
    PRAGMA page_size = 1024;
    CREATE TABLE vacuum_page_size_keep(x);
    INSERT INTO vacuum_page_size_keep VALUES(randomblob(1500));
    VACUUM;
    PRAGMA page_size;
    SELECT count(*), sum(length(x)) FROM vacuum_page_size_keep;
    PRAGMA integrity_check;
}
expect {
    1024
    1|1500
    ok
}

# Adapted from SQLite walbak.test/tkt-5d863f876e.test: VACUUM in WAL mode
# preserves journal mode and indexed table content.
test vacuum-preserves-wal-journal-mode {
    CREATE TABLE vacuum_wal_mode(a, b);
    CREATE INDEX vacuum_wal_mode_idx ON vacuum_wal_mode(a, b);
    INSERT INTO vacuum_wal_mode VALUES(1, 2), (3, 4);
    PRAGMA journal_mode = WAL;
    VACUUM;
    PRAGMA journal_mode;
    SELECT * FROM vacuum_wal_mode ORDER BY a;
    PRAGMA integrity_check;
}
expect {
    wal
    wal
    1|2
    3|4
    ok
}

# Regression for the currently supported WAL VACUUM behavior: pending page-size
# changes do not rewrite the source database page size.
test vacuum-preserves-wal-page-size {
    PRAGMA page_size = 1024;
    CREATE TABLE t1(a INTEGER PRIMARY KEY, b TEXT, c BLOB);
    INSERT INTO t1 VALUES(1, 'one', randomblob(1000));
    PRAGMA page_size;

    PRAGMA page_size = 2048;
    VACUUM;
    PRAGMA page_size;
    SELECT a, b, length(c) FROM t1;
    PRAGMA integrity_check;

    PRAGMA page_size = 512;
    VACUUM;
    PRAGMA page_size;
    SELECT a, b, length(c) FROM t1;
    PRAGMA integrity_check;
}
expect {
    1024
    1024
    1|one|1000
    ok
    1024
    1|one|1000
    ok
}

# Adapted from SQLite vacuum3.test: SQLite can apply pending page-size changes
# during VACUUM. Turso intentionally does not support changing page size yet.
@skip "missing feature: VACUUM does not support changing page size; see missing_feature.txt"
test vacuum-page-size-transitions-from-sqlite {
    PRAGMA page_size = 1024;
    CREATE TABLE t1(a INTEGER PRIMARY KEY, b TEXT, c BLOB);
    INSERT INTO t1 VALUES(1, 'one', randomblob(1000));
    PRAGMA page_size;

    PRAGMA page_size = 2048;
    VACUUM;
    PRAGMA page_size;
    SELECT a, b, length(c) FROM t1;
    PRAGMA integrity_check;

    PRAGMA page_size = 512;
    VACUUM;
    PRAGMA page_size;
    SELECT a, b, length(c) FROM t1;
    PRAGMA integrity_check;
}
expect {
    1024
    2048
    1|one|1000
    ok
    512
    1|one|1000
    ok
}

# Adapted from SQLite vacuum5.test/e_vacuum.test: SQLite supports schema-
# qualified VACUUM for attached databases.
@skip "missing feature: schema-qualified VACUUM is only supported for main; see missing_feature.txt"
@backend cli
test vacuum-attached-schema-from-sqlite {
    ATTACH 'vacuum_attached_schema_aux.db' AS aux;
    CREATE TABLE aux.t1(a INTEGER PRIMARY KEY, b TEXT);
    INSERT INTO aux.t1 VALUES(1, 'one'), (2, 'two'), (3, 'three');
    DELETE FROM aux.t1 WHERE a = 2;
    VACUUM aux;
    SELECT a, b FROM aux.t1 ORDER BY a;
    PRAGMA aux.integrity_check;
}
expect {
    1|one
    3|three
    ok
}

# Adapted from SQLite vacuum5.test: VACUUM temp is a no-op on the temp schema.
@skip "missing feature: schema-qualified VACUUM is only supported for main; see missing_feature.txt"
test vacuum-temp-schema-from-sqlite {
    CREATE TEMP TABLE t1(a INTEGER PRIMARY KEY, b TEXT);
    INSERT INTO temp.t1 VALUES(1, 'one'), (2, 'two');
    VACUUM temp;
    SELECT a, b FROM temp.t1 ORDER BY a;
}
expect {
    1|one
    2|two
}

# Adapted from SQLite e_vacuum.test: SQLite may renumber ordinary rowid tables
# that do not have an INTEGER PRIMARY KEY or indexes.
@skip "missing feature: plain VACUUM does not match SQLite rowid renumbering for ordinary unindexed rowid tables; see missing_feature.txt"
test vacuum-rowid-renumbering-from-sqlite {
    CREATE TABLE t4(x);
    INSERT INTO t4(x) VALUES('x'), ('y'), ('z');
    DELETE FROM t4 WHERE x = 'y';
    SELECT rowid, x FROM t4 ORDER BY rowid;
    VACUUM;
    SELECT rowid, x FROM t4 ORDER BY rowid;

    CREATE TABLE t5(x, y INTEGER PRIMARY KEY);
    INSERT INTO t5(x) VALUES('x'), ('y'), ('z');
    DELETE FROM t5 WHERE x = 'y';
    SELECT rowid, x FROM t5 ORDER BY rowid;
    VACUUM;
    SELECT rowid, x FROM t5 ORDER BY rowid;

    CREATE TABLE t6(x, y, z);
    INSERT INTO t6(x) VALUES('x'), ('y'), ('z');
    UPDATE t6 SET y = x, z = rowid * 10;
    DELETE FROM t6 WHERE x = 'y';
    CREATE INDEX t6x ON t6(x);
    CREATE UNIQUE INDEX t6y ON t6(y);
    CREATE INDEX t6zxy ON t6(z, x, y);
    SELECT rowid, x FROM t6 ORDER BY rowid;
    VACUUM;
    SELECT rowid, x FROM t6 ORDER BY rowid;
    PRAGMA integrity_check;
}
expect {
    1|x
    3|z
    1|x
    2|z
    1|x
    3|z
    1|x
    3|z
    1|x
    3|z
    1|x
    3|z
    ok
}
