@database :memory:

test vacuum-into-empty-path-rejected {
    VACUUM INTO '';
}
expect error {
    VACUUM INTO path cannot be empty
}

test vacuum-into-rejected-in-transaction {
    CREATE TABLE t(a TEXT);
    BEGIN;
    VACUUM INTO 'limbo_vacuum_into_txn_should_fail.db';
}
expect error {
    cannot VACUUM INTO from within a transaction
}
