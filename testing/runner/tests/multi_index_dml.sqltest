@database :memory:

setup multi_index_dml_schema {
    CREATE TABLE t (
        id INTEGER PRIMARY KEY,
        i1 INTEGER,
        i2 INTEGER,
        bar INTEGER
    );
    CREATE INDEX t_i1 ON t(i1);
    CREATE INDEX t_i2 ON t(i2);

    -- Row 3 matches both OR branches to validate dedup/stable-rowset behavior.
    INSERT INTO t VALUES (1, 5, 0, 10);
    INSERT INTO t VALUES (2, 0, 6, 20);
    INSERT INTO t VALUES (3, 5, 6, 30);
    INSERT INTO t VALUES (4, 0, 0, 40);
}

setup multi_index_null_residual_schema {
    CREATE TABLE t (
        id INTEGER PRIMARY KEY,
        i1 INTEGER,
        i2 INTEGER,
        bar INTEGER,
        note TEXT
    );
    CREATE INDEX t_i1 ON t(i1);
    CREATE INDEX t_i2 ON t(i2);

    INSERT INTO t VALUES
        (1, 5, 0, NULL, NULL),
        (2, 5, 6, 30, 'keep'),
        (3, 0, 6, 20, 'drop'),
        (4, 5, 6, NULL, 'keep'),
        (5, 0, 0, 40, NULL);
}

setup multi_index_fk_update_schema {
    PRAGMA foreign_keys = ON;

    CREATE TABLE parent(id INTEGER PRIMARY KEY);
    INSERT INTO parent VALUES (1), (2);

    CREATE TABLE t (
        id INTEGER PRIMARY KEY,
        i1 INTEGER,
        i2 INTEGER,
        pid INTEGER REFERENCES parent(id),
        note TEXT
    );
    CREATE INDEX t_i1 ON t(i1);
    CREATE INDEX t_i2 ON t(i2);

    CREATE TABLE audit(msg TEXT);
    CREATE TRIGGER tr_log_update
    AFTER UPDATE ON t
    BEGIN
        INSERT INTO audit VALUES ('updated=' || NEW.id || ':' || NEW.pid);
    END;

    INSERT INTO t VALUES
        (1, 5, 0, 1, 'skip'),
        (2, 5, 6, 1, 'move'),
        (3, 0, 6, 1, 'skip');
}

setup multi_index_fk_delete_schema {
    PRAGMA foreign_keys = ON;

    CREATE TABLE parent (
        id INTEGER PRIMARY KEY,
        i1 INTEGER,
        i2 INTEGER,
        tag TEXT
    );
    CREATE INDEX parent_i1 ON parent(i1);
    CREATE INDEX parent_i2 ON parent(i2);

    CREATE TABLE child (
        id INTEGER PRIMARY KEY,
        parent_id INTEGER REFERENCES parent(id) ON DELETE CASCADE,
        payload TEXT
    );

    CREATE TABLE audit(msg TEXT);
    CREATE TRIGGER tr_log_delete
    AFTER DELETE ON parent
    BEGIN
        INSERT INTO audit VALUES ('deleted=' || OLD.id);
    END;

    INSERT INTO parent VALUES
        (1, 5, 0, 'keep'),
        (2, 5, 6, 'drop'),
        (3, 0, 6, 'keep');
    INSERT INTO child VALUES
        (1, 2, 'c2'),
        (2, 3, 'c3');
}

setup multi_index_fk_chain_schema {
    PRAGMA foreign_keys = ON;

    CREATE TABLE parent (
        id INTEGER PRIMARY KEY,
        i1 INTEGER,
        i2 INTEGER,
        tag TEXT
    );
    CREATE INDEX parent_i1 ON parent(i1);
    CREATE INDEX parent_i2 ON parent(i2);

    CREATE TABLE child (
        id INTEGER PRIMARY KEY,
        parent_id INTEGER REFERENCES parent(id) ON DELETE CASCADE,
        payload TEXT
    );

    CREATE TABLE grandchild (
        id INTEGER PRIMARY KEY,
        child_id INTEGER REFERENCES child(id) ON DELETE CASCADE,
        payload TEXT
    );

    INSERT INTO parent VALUES
        (1, 5, 0, 'keep'),
        (2, 5, 6, 'drop-left'),
        (3, 0, 6, 'drop-right'),
        (4, 0, 0, 'keep');
    INSERT INTO child VALUES
        (10, 2, 'c10'),
        (11, 2, 'c11'),
        (12, 3, 'c12'),
        (13, 4, 'c13');
    INSERT INTO grandchild VALUES
        (100, 10, 'g100'),
        (101, 11, 'g101'),
        (102, 12, 'g102'),
        (103, 13, 'g103');
}

@setup multi_index_dml_schema
snapshot-eqp multi-index-or-access-shape {
    SELECT id FROM t WHERE i1 = 5 OR i2 = 6;
}

@setup multi_index_dml_schema
snapshot-eqp update-multi-index-or-access-shape {
    UPDATE t SET bar = bar + 1 WHERE i1 = 5 OR i2 = 6;
}

@setup multi_index_dml_schema
snapshot-eqp delete-multi-index-or-access-shape {
    DELETE FROM t WHERE i1 = 5 OR i2 = 6;
}

@setup multi_index_dml_schema
snapshot-eqp delete-multi-index-or-two-row-subset-access-shape {
    DELETE FROM t WHERE (i1 = 5 OR i2 = 6) AND bar <= 20;
}

@setup multi_index_dml_schema
snapshot-eqp delete-multi-index-or-one-row-subset-access-shape {
    DELETE FROM t WHERE (i1 = 5 OR i2 = 6) AND bar = 20;
}

# Prefer single index since we cannot currently estimate the predicates are uncorrelated; assuming they multiply each other's selectivities typically overestimates reality
@setup multi_index_dml_schema
snapshot-eqp update-multi-index-and-access-shape {
    UPDATE t SET bar = bar + 100 WHERE i1 = 5 AND i2 = 6;
}

# Prefer single index since we cannot currently estimate the predicates are uncorrelated; assuming they multiply each other's selectivities typically overestimates reality
@setup multi_index_dml_schema
snapshot-eqp delete-multi-index-and-access-shape {
    DELETE FROM t WHERE i1 = 5 AND i2 = 6;
}

@setup multi_index_dml_schema
snapshot-eqp delete-multi-index-compound-or-access-shape {
    DELETE FROM t
    WHERE (i1 = 5 AND bar >= 30)
       OR (i2 = 6 AND bar = 20);
}

@setup multi_index_dml_schema
test update-multi-index-or-stable-write-set {
    UPDATE t
    SET bar = bar + 1
    WHERE i1 = 5 OR i2 = 6;

    SELECT id, bar FROM t ORDER BY id;
}
expect {
    1|11
    2|21
    3|31
    4|40
}

@setup multi_index_dml_schema
test update-multi-index-or-updating-indexed-column {
    UPDATE t
    SET i1 = i1 + 100
    WHERE i1 = 5 OR i2 = 6;

    SELECT id, i1 FROM t ORDER BY id;
}
expect {
    1|105
    2|100
    3|105
    4|0
}

@setup multi_index_dml_schema
test delete-multi-index-or-safe-materialization {
    DELETE FROM t
    WHERE i1 = 5 OR i2 = 6;

    SELECT id, i1, i2, bar FROM t ORDER BY id;
}
expect {
    4|0|0|40
}

@setup multi_index_dml_schema
@requires trigger "requires trigger support"
test delete-multi-index-or-with-trigger {
    CREATE TABLE delete_log (id INTEGER);
    CREATE TRIGGER tr_log_delete BEFORE DELETE ON t BEGIN INSERT INTO delete_log VALUES (OLD.id); END;

    DELETE FROM t
    WHERE i1 = 5 OR i2 = 6;

    SELECT count(*) FROM delete_log;
    SELECT count(*) FROM t;
}
expect {
    3
    1
}

@setup multi_index_dml_schema
@requires trigger "requires trigger support"
test delete-multi-index-or-before-trigger-does-not-grow-write-set {
    CREATE TRIGGER tr_before_delete
    BEFORE DELETE ON t
    WHEN OLD.id = 1
    BEGIN
        UPDATE t SET i1 = 5 WHERE id = 4;
    END;

    DELETE FROM t
    WHERE i1 = 5 OR i2 = 6;

    SELECT id, i1, i2, bar FROM t ORDER BY id;
}
expect {
    4|5|0|40
}

@setup multi_index_dml_schema
@skip-if sqlite "SQLite build in CI does not enable DELETE ... LIMIT/OFFSET"
test delete-multi-index-or-limit-preserved {
    DELETE FROM t
    WHERE i1 = 5 OR i2 = 6
    LIMIT 2;

    SELECT count(*) FROM t;
}
expect {
    2
}

@setup multi_index_dml_schema
@skip-if sqlite "SQLite build in CI does not enable DELETE ... LIMIT/OFFSET"
test delete-multi-index-or-limit-offset-preserved {
    DELETE FROM t
    WHERE i1 = 5 OR i2 = 6
    LIMIT 1 OFFSET 1;

    SELECT count(*) FROM t;
}
expect {
    3
}

@setup multi_index_dml_schema
test delete-multi-index-or-two-row-subset-compatible {
    DELETE FROM t
    WHERE (i1 = 5 OR i2 = 6) AND bar <= 20;

    SELECT count(*) FROM t;
}
expect {
    2
}

@setup multi_index_dml_schema
test delete-multi-index-or-one-row-subset-compatible {
    DELETE FROM t
    WHERE (i1 = 5 OR i2 = 6) AND bar = 20;

    SELECT count(*) FROM t;
}
expect {
    3
}

@setup multi_index_dml_schema
test update-multi-index-and-stable-write-set {
    UPDATE t
    SET bar = bar + 100
    WHERE i1 = 5 AND i2 = 6;

    SELECT id, bar FROM t ORDER BY id;
}
expect {
    1|10
    2|20
    3|130
    4|40
}

@setup multi_index_dml_schema
@requires trigger "requires trigger support"
test update-multi-index-and-before-trigger-does-not-grow-write-set {
    CREATE TRIGGER tr_before_update
    BEFORE UPDATE ON t
    WHEN OLD.id = 3
    BEGIN
        UPDATE t SET i2 = 6 WHERE id = 1;
    END;

    UPDATE t
    SET bar = bar + 100
    WHERE i1 = 5 AND i2 = 6;

    SELECT id, i1, i2, bar FROM t ORDER BY id;
}
expect {
    1|5|6|10
    2|0|6|20
    3|5|6|130
    4|0|0|40
}

@setup multi_index_dml_schema
test delete-multi-index-and-safe-materialization {
    DELETE FROM t
    WHERE i1 = 5 AND i2 = 6;

    SELECT id, i1, i2, bar FROM t ORDER BY id;
}
expect {
    1|5|0|10
    2|0|6|20
    4|0|0|40
}

@setup multi_index_dml_schema
test delete-multi-index-compound-or-safe-materialization {
    DELETE FROM t
    WHERE (i1 = 5 AND bar >= 30)
       OR (i2 = 6 AND bar = 20);

    SELECT id, i1, i2, bar FROM t ORDER BY id;
}
expect {
    1|5|0|10
    4|0|0|40
}

@setup multi_index_dml_schema
test update-multi-index-compound-or-stable-write-set {
    UPDATE t
    SET i1 = i1 + 100
    WHERE (i1 = 5 AND bar >= 30)
       OR (i2 = 6 AND bar = 20);

    SELECT id, i1, i2, bar FROM t ORDER BY id;
}
expect {
    1|5|0|10
    2|100|6|20
    3|105|6|30
    4|0|0|40
}

@setup multi_index_dml_schema
test update-multi-index-and-returning {
    UPDATE t
    SET bar = bar + 100
    WHERE i1 = 5 AND i2 = 6
    RETURNING id, bar;
}
expect {
    3|130
}

@setup multi_index_dml_schema
test delete-multi-index-compound-or-returning {
    DELETE FROM t
    WHERE (i1 = 5 AND bar >= 30)
       OR (i2 = 999 AND bar = 20)
    RETURNING id, bar;
}
expect {
    3|30
}

@setup multi_index_dml_schema
@requires trigger "requires trigger support"
test update-multi-index-and-with-trigger {
    CREATE TABLE update_log (id INTEGER, new_bar INTEGER);
    CREATE TRIGGER tr_log_update
    AFTER UPDATE ON t
    WHEN NEW.i1 = 5 AND NEW.i2 = 6
    BEGIN
        INSERT INTO update_log VALUES (NEW.id, NEW.bar);
    END;

    UPDATE t
    SET bar = bar + 100
    WHERE i1 = 5 AND i2 = 6;

    SELECT * FROM update_log;
    SELECT id, bar FROM t ORDER BY id;
}
expect {
    3|130
    1|10
    2|20
    3|130
    4|40
}

@setup multi_index_dml_schema
@requires trigger "requires trigger support"
test delete-multi-index-compound-or-with-trigger {
    CREATE TABLE delete_log (id INTEGER, old_bar INTEGER);
    CREATE TRIGGER tr_log_delete
    BEFORE DELETE ON t
    BEGIN
        INSERT INTO delete_log VALUES (OLD.id, OLD.bar);
    END;

    DELETE FROM t
    WHERE (i1 = 5 AND bar >= 30)
       OR (i2 = 6 AND bar = 20);

    SELECT * FROM delete_log ORDER BY id;
    SELECT id, i1, i2, bar FROM t ORDER BY id;
}
expect {
    2|20
    3|30
    1|5|0|10
    4|0|0|40
}

@setup multi_index_fk_update_schema
@cross-check-integrity
@requires trigger "requires trigger support"
test update-multi-index-and-returning-with-trigger-and-fk {
    UPDATE t
    SET pid = 2
    WHERE i1 = 5 AND i2 = 6
    RETURNING id, pid;

    SELECT * FROM audit;
    SELECT id, pid FROM t ORDER BY id;
}
expect {
    2|2
    updated=2:2
    1|1
    2|2
    3|1
}

@setup multi_index_fk_delete_schema
@cross-check-integrity
@requires trigger "requires trigger support"
test delete-multi-index-compound-or-returning-with-trigger-and-fk {
    DELETE FROM parent
    WHERE (i1 = 5 AND tag = 'drop')
       OR (i2 = 999 AND tag = 'keep')
    RETURNING id, tag;

    SELECT * FROM audit ORDER BY rowid;
    SELECT id, parent_id, payload FROM child ORDER BY id;
    SELECT id, i1, i2, tag FROM parent ORDER BY id;
}
expect {
    2|drop
    deleted=2
    2|3|c3
    1|5|0|keep
    3|0|6|keep
}

@setup multi_index_fk_chain_schema
@cross-check-integrity
test delete-multi-index-compound-or-fk-cascade-chain {
    DELETE FROM parent
    WHERE (i1 = 5 AND tag = 'drop-left')
       OR (i2 = 6 AND tag = 'drop-right')
    RETURNING id, tag;

    SELECT id, parent_id, payload FROM child ORDER BY id;
    SELECT id, child_id, payload FROM grandchild ORDER BY id;
    SELECT id, i1, i2, tag FROM parent ORDER BY id;
}
expect {
    2|drop-left
    3|drop-right
    13|4|c13
    103|13|g103
    1|5|0|keep
    4|0|0|keep
}

@setup multi_index_null_residual_schema
test update-multi-index-compound-or-null-residuals {
    UPDATE t
    SET bar = coalesce(bar, 0) + 1
    WHERE (i1 = 5 AND bar IS NULL)
       OR (i2 = 6 AND note IS NOT NULL);

    SELECT id, bar FROM t ORDER BY id;
}
expect {
    1|1
    2|31
    3|21
    4|1
    5|40
}

@setup multi_index_null_residual_schema
test delete-multi-index-compound-or-not-residual {
    DELETE FROM t
    WHERE (i1 = 5 AND NOT note IS NOT NULL)
       OR (i2 = 6 AND NOT (note = 'keep'));

    SELECT id, i1, i2, bar, note FROM t ORDER BY id;
}
expect {
    2|5|6|30|keep
    4|5|6||keep
    5|0|0|40|
}
