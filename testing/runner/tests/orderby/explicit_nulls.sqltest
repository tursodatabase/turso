@database :memory:

setup indexed_nullable_values {
    CREATE TABLE t(
        id INTEGER PRIMARY KEY,
        val INTEGER
    );
    CREATE INDEX idx_t_val ON t(val);

    INSERT INTO t VALUES
        (1, NULL),
        (2, 5),
        (3, 1),
        (4, NULL),
        (5, 3),
        (6, 2);
}

@setup indexed_nullable_values
test orderby_desc_nulls_first {
    SELECT id, val FROM t
    ORDER BY val DESC NULLS FIRST, id;
}
expect {
    1|
    4|
    2|5
    5|3
    6|2
    3|1
}

@setup indexed_nullable_values
test orderby_asc_nulls_last {
    SELECT id, val FROM t
    ORDER BY val NULLS LAST, id;
}
expect {
    3|1
    6|2
    5|3
    2|5
    1|
    4|
}

# Regression: an index on val must not let ORDER BY ... NULLS LAST skip sorting,
# or LIMIT would incorrectly return the NULL rows first.
@setup indexed_nullable_values
test orderby_asc_nulls_last_limit_indexed_nullable_column {
    SELECT id, val FROM t
    ORDER BY val NULLS LAST
    LIMIT 3;
}
expect {
    3|1
    6|2
    5|3
}
