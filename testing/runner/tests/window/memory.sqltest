@database :memory:

@cross-check-integrity
test window-partition-by-duplicate-columns {
    CREATE TABLE t1 (a INTEGER, b INTEGER, c INTEGER);
    INSERT INTO t1 VALUES (1, 2, 3);
    SELECT avg(a) OVER (PARTITION BY b, b, c, c, a ORDER BY c) FROM t1;
}
expect {
    1.0
}
expect @js {
    1
}

@cross-check-integrity
test window-partition-by-duplicate-columns-multi-row {
    CREATE TABLE t2 (a INTEGER, b INTEGER, c INTEGER);
    INSERT INTO t2 VALUES (1, 10, 100), (2, 10, 100), (3, 20, 200), (4, 20, 200);
    SELECT sum(a) OVER (PARTITION BY b, b, c, c ORDER BY a) FROM t2;
}
expect {
    1
    3
    3
    7
}

@cross-check-integrity
test window-partition-by-duplicate-columns-collation {
    CREATE TABLE t3 (val INTEGER, name TEXT COLLATE NOCASE);
    INSERT INTO t3 VALUES (1, 'Apple'), (2, 'apple'), (3, 'Banana'), (4, 'banana');
    SELECT sum(val) OVER (PARTITION BY name, name ORDER BY val) FROM t3;
}
expect {
    1
    3
    3
    7
}

@cross-check-integrity
test window-collate-partition-by {
    CREATE TABLE fruits(name collate nocase);
    INSERT INTO fruits(name) VALUES ('Apple'), ('banana'), ('apple');
    SELECT
    name,
    count(*) OVER (PARTITION BY name)
    FROM fruits;
}
expect {
    Apple|2
    apple|2
    banana|1
}

@cross-check-integrity
test window-collate-order-by {
    CREATE TABLE fruits(name collate nocase);
    INSERT INTO fruits(name) VALUES ('Apple'),('banana'), ('apple');
    SELECT
    name,
    count(*) OVER (ORDER BY name)
    FROM fruits;
}
expect {
    Apple|2
    apple|2
    banana|3
}

@cross-check-integrity
test window-with-correlated-scalar-subquery {
    CREATE TABLE t(id INT, grp TEXT, val INT);
    INSERT INTO t VALUES (1,'a',10),(2,'a',20),(3,'b',30);
    SELECT t.id,
      (SELECT COUNT(*) FROM t t2 WHERE t2.grp = t.grp) as grp_cnt,
      SUM(t.val) OVER () as total
    FROM t ORDER BY t.id;
}
expect {
    1|2|60
    2|2|60
    3|1|60
}

@cross-check-integrity
test window-with-correlated-scalar-subquery-partition {
    CREATE TABLE t(id INT, grp TEXT, val INT);
    INSERT INTO t VALUES (1,'a',10),(2,'a',20),(3,'b',30),(4,'b',40);
    SELECT t.id,
      (SELECT SUM(val) FROM t t2 WHERE t2.grp = t.grp) as grp_sum,
      SUM(t.val) OVER (PARTITION BY t.grp) as part_total
    FROM t ORDER BY t.id;
}
expect {
    1|30|30
    2|30|30
    3|70|70
    4|70|70
}

@cross-check-integrity
test window-with-uncorrelated-scalar-subquery {
    CREATE TABLE t(id INT, val INT);
    INSERT INTO t VALUES (1,10),(2,20),(3,30);
    SELECT t.id,
      (SELECT MAX(val) FROM t) as max_val,
      SUM(t.val) OVER () as total
    FROM t ORDER BY t.id;
}
expect {
    1|30|60
    2|30|60
    3|30|60
}

@cross-check-integrity
test window-in-exists-subquery-referencing-outer-column {
    CREATE TABLE t1 (a);
    INSERT INTO t1 VALUES (1), (2), (3);
    SELECT * FROM (SELECT a FROM t1) as subq
    WHERE EXISTS (
      SELECT count(1) OVER (ORDER BY subq.a) FROM t1
    );
}
expect {
    1
    2
    3
}


@cross-check-integrity
test window-filter-basic {
    CREATE TABLE t_filter (grp TEXT, val INT, active INT);
    INSERT INTO t_filter VALUES ('a', 10, 1), ('a', 20, 0), ('b', 30, 1), ('b', 40, 1);
    SELECT grp, val, SUM(val) FILTER (WHERE active = 1) OVER (PARTITION BY grp) AS filtered_sum
    FROM t_filter ORDER BY grp, val;
}
expect {
    a|10|10
    a|20|10
    b|30|70
    b|40|70
}

@cross-check-integrity
test window-filter-no-partition {
    CREATE TABLE t_filter2 (val INT);
    INSERT INTO t_filter2 VALUES (1), (2), (3), (4), (5);
    SELECT val, SUM(val) FILTER (WHERE val > 2) OVER () AS filtered_sum
    FROM t_filter2 ORDER BY val;
}
expect {
    1|12
    2|12
    3|12
    4|12
    5|12
}

@cross-check-integrity
test window-filter-count-star {
    CREATE TABLE t_filter3 (grp TEXT, val INT);
    INSERT INTO t_filter3 VALUES ('a', 1), ('a', 2), ('a', 3), ('b', 1), ('b', 2);
    SELECT grp, val, COUNT(*) FILTER (WHERE val > 1) OVER (PARTITION BY grp) AS cnt
    FROM t_filter3 ORDER BY grp, val;
}
expect {
    a|1|2
    a|2|2
    a|3|2
    b|1|1
    b|2|1
}

@cross-check-integrity
test window-filter-null-treated-as-false {
    CREATE TABLE t_filter4 (val INT, cond INT);
    INSERT INTO t_filter4 VALUES (1, 1), (2, NULL), (3, 0), (4, 1);
    SELECT val, SUM(val) FILTER (WHERE cond) OVER () AS filtered_sum
    FROM t_filter4 ORDER BY val;
}
expect {
    1|5
    2|5
    3|5
    4|5
}

@cross-check-integrity
test window-filter-named-window {
    CREATE TABLE t_filter5 (grp TEXT, val INT);
    INSERT INTO t_filter5 VALUES ('a', 1), ('a', 2), ('b', 3), ('b', 4);
    SELECT grp, val, SUM(val) FILTER (WHERE val > 1) OVER w AS filtered_sum
    FROM t_filter5
    WINDOW w AS (PARTITION BY grp)
    ORDER BY grp, val;
}
expect {
    a|1|2
    a|2|2
    b|3|7
    b|4|7
}

@cross-check-integrity
test window-filter-multiple-functions {
    CREATE TABLE t_filter6 (grp TEXT, val INT);
    INSERT INTO t_filter6 VALUES ('a', 1), ('a', 2), ('a', 3), ('b', 4), ('b', 5);
    SELECT grp, val,
           SUM(val) FILTER (WHERE val > 1) OVER (PARTITION BY grp) AS filtered_sum,
           COUNT(*) FILTER (WHERE val > 2) OVER (PARTITION BY grp) AS filtered_cnt
    FROM t_filter6 ORDER BY grp, val;
}
expect {
    a|1|5|1
    a|2|5|1
    a|3|5|1
    b|4|9|2
    b|5|9|2
}
