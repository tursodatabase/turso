@database :memory:
@requires-file trigger "trigger tests require trigger support"

# =============================================================================
# Adversarial trigger tests - attempting to find bugs
# =============================================================================

# --- NEW/OLD scoping in subqueries ---

# NEW reference inside a correlated subquery in trigger body
@cross-check-integrity
test trigger-new-in-correlated-subquery {
    CREATE TABLE t1 (a INTEGER PRIMARY KEY, b TEXT);
    CREATE TABLE t2 (x INTEGER, y TEXT);
    INSERT INTO t2 VALUES (1, 'found'), (2, 'also');
    CREATE TABLE log (msg TEXT);
    CREATE TRIGGER tr1 AFTER INSERT ON t1 BEGIN
        INSERT INTO log SELECT y FROM t2 WHERE t2.x = NEW.a;
    END;
    INSERT INTO t1 VALUES (1, 'hello');
    SELECT * FROM log;
}
expect {
    found
}

# NEW reference inside EXISTS subquery in trigger WHEN clause
@cross-check-integrity
test trigger-new-in-exists-when {
    CREATE TABLE t3 (a INTEGER PRIMARY KEY, b TEXT);
    CREATE TABLE allowed (id INTEGER);
    INSERT INTO allowed VALUES (1), (3);
    CREATE TABLE log3 (msg TEXT);
    CREATE TRIGGER tr3 AFTER INSERT ON t3 WHEN EXISTS (SELECT 1 FROM allowed WHERE id = NEW.a) BEGIN
        INSERT INTO log3 VALUES ('allowed: ' || NEW.a);
    END;
    INSERT INTO t3 VALUES (1, 'yes');
    INSERT INTO t3 VALUES (2, 'no');
    INSERT INTO t3 VALUES (3, 'yes');
    SELECT * FROM log3 ORDER BY rowid;
}
expect {
    allowed: 1
    allowed: 3
}

# NEW reference inside IN subquery in trigger body
@cross-check-integrity
test trigger-new-in-in-subquery {
    CREATE TABLE t4 (a INTEGER PRIMARY KEY, b TEXT);
    CREATE TABLE valid_ids (id INTEGER);
    INSERT INTO valid_ids VALUES (10), (20), (30);
    CREATE TABLE log4 (msg TEXT);
    CREATE TRIGGER tr4 AFTER INSERT ON t4 BEGIN
        INSERT INTO log4 VALUES (CASE WHEN NEW.a IN (SELECT id FROM valid_ids) THEN 'valid' ELSE 'invalid' END);
    END;
    INSERT INTO t4 VALUES (10, 'x');
    INSERT INTO t4 VALUES (99, 'y');
    SELECT * FROM log4 ORDER BY rowid;
}
expect {
    valid
    invalid
}

# NEW inside CTE in trigger body
@cross-check-integrity
test trigger-new-in-cte {
    CREATE TABLE t5 (a INTEGER, b INTEGER);
    CREATE TABLE log5 (val INTEGER);
    CREATE TRIGGER tr5 AFTER INSERT ON t5 BEGIN
        INSERT INTO log5 WITH doubled AS (SELECT NEW.a * 2 AS v) SELECT v FROM doubled;
    END;
    INSERT INTO t5 VALUES (5, 0);
    INSERT INTO t5 VALUES (7, 0);
    SELECT * FROM log5 ORDER BY val;
}
expect {
    10
    14
}

# --- OLD in INSERT trigger / NEW in DELETE trigger (should error) ---

@cross-check-integrity
test trigger-old-in-insert-trigger-error {
    CREATE TABLE t6 (a INTEGER, b TEXT);
    CREATE TRIGGER tr6 BEFORE INSERT ON t6 BEGIN
        SELECT OLD.a;
    END;
    INSERT INTO t6 VALUES (1, 'test');
}
expect error {
    OLD references are only valid in UPDATE and DELETE triggers
}

@cross-check-integrity
test trigger-new-in-delete-trigger-error {
    CREATE TABLE t7 (a INTEGER, b TEXT);
    INSERT INTO t7 VALUES (1, 'test');
    CREATE TRIGGER tr7 BEFORE DELETE ON t7 BEGIN
        SELECT NEW.a;
    END;
    DELETE FROM t7 WHERE a = 1;
}
expect error {
    NEW references are only valid in INSERT and UPDATE triggers
}

# --- NEW/OLD with rowid aliases ---

@cross-check-integrity
test trigger-new-rowid {
    CREATE TABLE t8 (a INTEGER PRIMARY KEY, b TEXT);
    CREATE TABLE log8 (rid INTEGER);
    CREATE TRIGGER tr8 AFTER INSERT ON t8 BEGIN
        INSERT INTO log8 VALUES (NEW.rowid);
    END;
    INSERT INTO t8 VALUES (42, 'test');
    SELECT * FROM log8;
}
expect {
    42
}

@cross-check-integrity
test trigger-new-oid {
    CREATE TABLE t8b (a INTEGER PRIMARY KEY, b TEXT);
    CREATE TABLE log8b (rid INTEGER);
    CREATE TRIGGER tr8b AFTER INSERT ON t8b BEGIN
        INSERT INTO log8b VALUES (NEW._rowid_);
    END;
    INSERT INTO t8b VALUES (99, 'test');
    SELECT * FROM log8b;
}
expect {
    99
}

@cross-check-integrity
test trigger-old-rowid-on-delete {
    CREATE TABLE t8c (a INTEGER PRIMARY KEY, b TEXT);
    CREATE TABLE log8c (rid INTEGER);
    INSERT INTO t8c VALUES (55, 'del');
    CREATE TRIGGER tr8c AFTER DELETE ON t8c BEGIN
        INSERT INTO log8c VALUES (OLD.rowid);
    END;
    DELETE FROM t8c WHERE a = 55;
    SELECT * FROM log8c;
}
expect {
    55
}

# --- Trigger with typeof() on NEW/OLD ---

@cross-check-integrity
test trigger-typeof-new {
    CREATE TABLE t9 (a INTEGER, b TEXT, c REAL);
    CREATE TABLE log9 (ta TEXT, tb TEXT, tc TEXT);
    CREATE TRIGGER tr9 AFTER INSERT ON t9 BEGIN
        INSERT INTO log9 VALUES (typeof(NEW.a), typeof(NEW.b), typeof(NEW.c));
    END;
    INSERT INTO t9 VALUES (1, 'hello', 3.14);
    INSERT INTO t9 VALUES (NULL, NULL, NULL);
    SELECT * FROM log9 ORDER BY rowid;
}
expect {
    integer|text|real
    null|null|null
}

# --- Trigger with CAST on NEW ---

@cross-check-integrity
test trigger-cast-new {
    CREATE TABLE t10 (a TEXT);
    CREATE TABLE log10 (val INTEGER);
    CREATE TRIGGER tr10 AFTER INSERT ON t10 BEGIN
        INSERT INTO log10 VALUES (CAST(NEW.a AS INTEGER));
    END;
    INSERT INTO t10 VALUES ('42');
    INSERT INTO t10 VALUES ('not_a_number');
    SELECT * FROM log10 ORDER BY rowid;
}
expect {
    42
    0
}

# --- Trigger with COALESCE and IFNULL on NEW ---

@cross-check-integrity
test trigger-coalesce-new {
    CREATE TABLE t11 (a INTEGER, b INTEGER);
    CREATE TABLE log11 (val INTEGER);
    CREATE TRIGGER tr11 AFTER INSERT ON t11 BEGIN
        INSERT INTO log11 VALUES (COALESCE(NEW.a, NEW.b, -1));
    END;
    INSERT INTO t11 VALUES (NULL, NULL);
    INSERT INTO t11 VALUES (NULL, 5);
    INSERT INTO t11 VALUES (3, 7);
    SELECT * FROM log11 ORDER BY rowid;
}
expect {
    -1
    5
    3
}

# --- Trigger with BETWEEN on NEW ---

@cross-check-integrity
test trigger-between-new {
    CREATE TABLE t12 (a INTEGER);
    CREATE TABLE log12 (msg TEXT);
    CREATE TRIGGER tr12 AFTER INSERT ON t12 BEGIN
        INSERT INTO log12 VALUES (CASE WHEN NEW.a BETWEEN 1 AND 10 THEN 'in range' ELSE 'out of range' END);
    END;
    INSERT INTO t12 VALUES (5);
    INSERT INTO t12 VALUES (15);
    INSERT INTO t12 VALUES (0);
    SELECT * FROM log12 ORDER BY rowid;
}
expect {
    in range
    out of range
    out of range
}

# --- Trigger with LIKE on NEW ---

@cross-check-integrity
test trigger-like-new {
    CREATE TABLE t13 (name TEXT);
    CREATE TABLE log13 (msg TEXT);
    CREATE TRIGGER tr13 AFTER INSERT ON t13 BEGIN
        INSERT INTO log13 VALUES (CASE WHEN NEW.name LIKE 'J%' THEN 'starts with J' ELSE 'other' END);
    END;
    INSERT INTO t13 VALUES ('John');
    INSERT INTO t13 VALUES ('Alice');
    SELECT * FROM log13 ORDER BY rowid;
}
expect {
    starts with J
    other
}

# --- UPDATE that affects 0 rows - trigger should NOT fire ---

@cross-check-integrity
test trigger-update-zero-rows {
    CREATE TABLE t14 (a INTEGER PRIMARY KEY, b TEXT);
    CREATE TABLE log14 (msg TEXT);
    INSERT INTO t14 VALUES (1, 'hello');
    CREATE TRIGGER tr14 AFTER UPDATE ON t14 BEGIN
        INSERT INTO log14 VALUES ('fired');
    END;
    UPDATE t14 SET b = 'world' WHERE a = 999;
    SELECT COUNT(*) FROM log14;
}
expect {
    0
}

# --- DELETE that affects 0 rows - trigger should NOT fire ---

@cross-check-integrity
test trigger-delete-zero-rows {
    CREATE TABLE t15 (a INTEGER PRIMARY KEY, b TEXT);
    CREATE TABLE log15 (msg TEXT);
    INSERT INTO t15 VALUES (1, 'hello');
    CREATE TRIGGER tr15 AFTER DELETE ON t15 BEGIN
        INSERT INTO log15 VALUES ('fired');
    END;
    DELETE FROM t15 WHERE a = 999;
    SELECT COUNT(*) FROM log15;
}
expect {
    0
}

# --- Multi-row INSERT fires trigger for each row ---

@cross-check-integrity
test trigger-multi-row-insert {
    CREATE TABLE t16 (a INTEGER, b TEXT);
    CREATE TABLE log16 (val INTEGER);
    CREATE TRIGGER tr16 AFTER INSERT ON t16 BEGIN
        INSERT INTO log16 VALUES (NEW.a);
    END;
    INSERT INTO t16 VALUES (1, 'a'), (2, 'b'), (3, 'c');
    SELECT * FROM log16 ORDER BY val;
}
expect {
    1
    2
    3
}

# --- INSERT with partial column list ---

@cross-check-integrity
test trigger-partial-column-insert {
    CREATE TABLE t17 (a INTEGER PRIMARY KEY, b TEXT DEFAULT 'default_val', c INTEGER);
    CREATE TABLE log17 (a_val INTEGER, b_val TEXT, c_val TEXT);
    CREATE TRIGGER tr17 AFTER INSERT ON t17 BEGIN
        INSERT INTO log17 VALUES (NEW.a, NEW.b, typeof(NEW.c));
    END;
    INSERT INTO t17 (a) VALUES (1);
    SELECT * FROM log17;
}
expect {
    1|default_val|null
}

# --- Trigger with INSERT ... SELECT ---

@cross-check-integrity
test trigger-insert-select-fires {
    CREATE TABLE src (x INTEGER);
    INSERT INTO src VALUES (10), (20), (30);
    CREATE TABLE dst (y INTEGER);
    CREATE TABLE log18 (val INTEGER);
    CREATE TRIGGER tr18 AFTER INSERT ON dst BEGIN
        INSERT INTO log18 VALUES (NEW.y);
    END;
    INSERT INTO dst SELECT x FROM src;
    SELECT * FROM log18 ORDER BY val;
}
expect {
    10
    20
    30
}

# --- UPDATE OF trigger - only fires when specified column changes ---

@cross-check-integrity
test trigger-update-of-specific-column {
    CREATE TABLE t19 (a INTEGER PRIMARY KEY, b TEXT, c INTEGER);
    CREATE TABLE log19 (msg TEXT);
    INSERT INTO t19 VALUES (1, 'hello', 10);
    CREATE TRIGGER tr19 AFTER UPDATE OF b ON t19 BEGIN
        INSERT INTO log19 VALUES ('b changed to ' || NEW.b);
    END;
    UPDATE t19 SET c = 20 WHERE a = 1;
    UPDATE t19 SET b = 'world' WHERE a = 1;
    SELECT * FROM log19;
}
expect {
    b changed to world
}

# --- UPDATE OF with multiple columns ---

@cross-check-integrity
test trigger-update-of-multiple-columns {
    CREATE TABLE t20 (a INTEGER PRIMARY KEY, b TEXT, c TEXT, d TEXT);
    CREATE TABLE log20 (msg TEXT);
    INSERT INTO t20 VALUES (1, 'b1', 'c1', 'd1');
    CREATE TRIGGER tr20 AFTER UPDATE OF b, c ON t20 BEGIN
        INSERT INTO log20 VALUES ('fired');
    END;
    UPDATE t20 SET d = 'd2' WHERE a = 1;
    UPDATE t20 SET b = 'b2' WHERE a = 1;
    UPDATE t20 SET c = 'c2' WHERE a = 1;
    SELECT COUNT(*) FROM log20;
}
expect {
    2
}

# --- Multiple triggers on same event, same table ---

@cross-check-integrity
test trigger-multiple-on-same-event {
    CREATE TABLE t21 (a INTEGER);
    CREATE TABLE log21 (msg TEXT);
    CREATE TRIGGER tr21a AFTER INSERT ON t21 BEGIN
        INSERT INTO log21 VALUES ('trigger_a');
    END;
    CREATE TRIGGER tr21b AFTER INSERT ON t21 BEGIN
        INSERT INTO log21 VALUES ('trigger_b');
    END;
    INSERT INTO t21 VALUES (1);
    SELECT COUNT(*) FROM log21;
}
expect {
    2
}

# --- Nested trigger: trigger A fires trigger B ---

@cross-check-integrity
test trigger-nested-fires {
    CREATE TABLE t22a (x INTEGER);
    CREATE TABLE t22b (y INTEGER);
    CREATE TABLE log22 (msg TEXT);
    CREATE TRIGGER tr22a AFTER INSERT ON t22a BEGIN
        INSERT INTO t22b VALUES (NEW.x * 10);
    END;
    CREATE TRIGGER tr22b AFTER INSERT ON t22b BEGIN
        INSERT INTO log22 VALUES ('nested: ' || NEW.y);
    END;
    INSERT INTO t22a VALUES (5);
    SELECT * FROM log22;
}
expect {
    nested: 50
}

# --- Self-referencing trigger (trigger inserts into its own table) ---
# Should NOT recurse - SQLite prevents recursive trigger execution by default

@cross-check-integrity
test trigger-self-insert-no-recurse {
    CREATE TABLE t23 (a INTEGER, b TEXT);
    CREATE TRIGGER tr23 AFTER INSERT ON t23 BEGIN
        INSERT INTO t23 VALUES (NEW.a + 1, 'recursive');
    END;
    INSERT INTO t23 VALUES (1, 'original');
    SELECT * FROM t23 ORDER BY a;
}
expect {
    1|original
    2|recursive
}

# --- BEFORE trigger modifying the table the trigger is on ---

@cross-check-integrity
test trigger-before-insert-modify-same-table {
    CREATE TABLE t24 (a INTEGER PRIMARY KEY, b TEXT);
    INSERT INTO t24 VALUES (1, 'existing');
    CREATE TRIGGER tr24 BEFORE INSERT ON t24 BEGIN
        UPDATE t24 SET b = 'modified' WHERE a = 1;
    END;
    INSERT INTO t24 VALUES (2, 'new');
    SELECT * FROM t24 ORDER BY a;
}
expect {
    1|modified
    2|new
}

# --- Trigger with UNION in body SELECT ---

@cross-check-integrity
test trigger-union-in-body {
    CREATE TABLE t25 (a INTEGER);
    CREATE TABLE log25 (val INTEGER);
    CREATE TRIGGER tr25 AFTER INSERT ON t25 BEGIN
        INSERT INTO log25 SELECT NEW.a UNION ALL SELECT NEW.a * 2;
    END;
    INSERT INTO t25 VALUES (5);
    SELECT * FROM log25 ORDER BY val;
}
expect {
    5
    10
}

# --- Trigger with GROUP BY / aggregate in body ---

@cross-check-integrity
test trigger-aggregate-in-body {
    CREATE TABLE t26 (a INTEGER);
    CREATE TABLE data26 (category TEXT, val INTEGER);
    INSERT INTO data26 VALUES ('x', 10), ('x', 20), ('y', 30);
    CREATE TABLE log26 (category TEXT, total INTEGER);
    CREATE TRIGGER tr26 AFTER INSERT ON t26 BEGIN
        INSERT INTO log26 SELECT category, SUM(val) FROM data26 GROUP BY category;
    END;
    INSERT INTO t26 VALUES (1);
    SELECT * FROM log26 ORDER BY category;
}
expect {
    x|30
    y|30
}

# --- Trigger on table with CHECK constraint ---

@cross-check-integrity
test trigger-with-check-constraint {
    CREATE TABLE t27 (a INTEGER CHECK(a > 0), b TEXT);
    CREATE TABLE log27 (msg TEXT);
    CREATE TRIGGER tr27 BEFORE INSERT ON t27 BEGIN
        INSERT INTO log27 VALUES ('trigger fired');
    END;
    INSERT INTO t27 VALUES (-1, 'bad');
}
expect error {
    CHECK constraint failed
}

# --- Trigger body INSERT violates CHECK constraint ---

@cross-check-integrity
test trigger-body-violates-check {
    CREATE TABLE t28 (a INTEGER);
    CREATE TABLE checked28 (val INTEGER CHECK(val > 0));
    CREATE TRIGGER tr28 AFTER INSERT ON t28 BEGIN
        INSERT INTO checked28 VALUES (NEW.a);
    END;
    INSERT INTO t28 VALUES (-5);
}
expect error {
    CHECK constraint failed
}

# --- DROP TABLE with active triggers ---

@cross-check-integrity
test trigger-drop-table-with-triggers {
    CREATE TABLE t29 (a INTEGER);
    CREATE TRIGGER tr29 AFTER INSERT ON t29 BEGIN SELECT 1; END;
    DROP TABLE t29;
    SELECT name FROM sqlite_schema WHERE type='trigger' AND name='tr29';
}
expect {
}

# --- ALTER TABLE ADD COLUMN - trigger should see new column ---

@cross-check-integrity
test trigger-after-alter-add-column {
    CREATE TABLE t30 (a INTEGER);
    CREATE TABLE log30 (val TEXT);
    ALTER TABLE t30 ADD COLUMN b TEXT DEFAULT 'added';
    CREATE TRIGGER tr30 AFTER INSERT ON t30 BEGIN
        INSERT INTO log30 VALUES (NEW.b);
    END;
    INSERT INTO t30 (a) VALUES (1);
    SELECT * FROM log30;
}
expect {
    added
}

# --- WHEN clause with complex expressions ---

@cross-check-integrity
test trigger-when-complex-case {
    CREATE TABLE t31 (a INTEGER, b TEXT);
    CREATE TABLE log31 (msg TEXT);
    CREATE TRIGGER tr31 AFTER INSERT ON t31
    WHEN CASE WHEN NEW.a > 10 THEN 1 WHEN NEW.b = 'special' THEN 1 ELSE 0 END
    BEGIN
        INSERT INTO log31 VALUES (NEW.a || ':' || NEW.b);
    END;
    INSERT INTO t31 VALUES (5, 'normal');
    INSERT INTO t31 VALUES (20, 'normal');
    INSERT INTO t31 VALUES (3, 'special');
    SELECT * FROM log31 ORDER BY rowid;
}
expect {
    20:normal
    3:special
}

# --- WHEN clause with NOT ---

@cross-check-integrity
test trigger-when-not {
    CREATE TABLE t32 (a INTEGER);
    CREATE TABLE log32 (val INTEGER);
    CREATE TRIGGER tr32 AFTER INSERT ON t32 WHEN NOT (NEW.a > 5) BEGIN
        INSERT INTO log32 VALUES (NEW.a);
    END;
    INSERT INTO t32 VALUES (3);
    INSERT INTO t32 VALUES (10);
    INSERT INTO t32 VALUES (1);
    SELECT * FROM log32 ORDER BY val;
}
expect {
    1
    3
}

# --- WHEN clause with AND/OR ---

@cross-check-integrity
test trigger-when-and-or {
    CREATE TABLE t33 (a INTEGER, b INTEGER);
    CREATE TABLE log33 (msg TEXT);
    CREATE TRIGGER tr33 AFTER INSERT ON t33 WHEN NEW.a > 0 AND (NEW.b < 10 OR NEW.b > 100) BEGIN
        INSERT INTO log33 VALUES (NEW.a || ',' || NEW.b);
    END;
    INSERT INTO t33 VALUES (1, 5);
    INSERT INTO t33 VALUES (1, 50);
    INSERT INTO t33 VALUES (-1, 5);
    INSERT INTO t33 VALUES (1, 200);
    SELECT * FROM log33 ORDER BY rowid;
}
expect {
    1,5
    1,200
}

# --- WHEN clause with NULL comparison ---

@cross-check-integrity
test trigger-when-null {
    CREATE TABLE t34 (a INTEGER);
    CREATE TABLE log34 (val TEXT);
    CREATE TRIGGER tr34 AFTER INSERT ON t34 WHEN NEW.a IS NOT NULL BEGIN
        INSERT INTO log34 VALUES (CAST(NEW.a AS TEXT));
    END;
    INSERT INTO t34 VALUES (1);
    INSERT INTO t34 VALUES (NULL);
    INSERT INTO t34 VALUES (3);
    SELECT * FROM log34 ORDER BY rowid;
}
expect {
    1
    3
}

# --- RAISE(ABORT) rolls back trigger body but not prior rows in multi-row ---

@cross-check-integrity
test trigger-raise-abort-multi-row {
    CREATE TABLE t35 (a INTEGER);
    CREATE TABLE log35 (val INTEGER);
    CREATE TRIGGER tr35 BEFORE INSERT ON t35 WHEN NEW.a = 3 BEGIN
        SELECT RAISE(ABORT, 'blocked row 3');
    END;
    INSERT OR ABORT INTO t35 VALUES (1);
    INSERT OR ABORT INTO t35 VALUES (2);
    INSERT OR ABORT INTO t35 VALUES (3);
}
expect error {
    blocked row 3
}

# Verify rows 1 and 2 were committed (separate statements)
@cross-check-integrity
test trigger-raise-abort-multi-row-verify {
    CREATE TABLE t35v (a INTEGER);
    CREATE TABLE log35v (val INTEGER);
    CREATE TRIGGER tr35v BEFORE INSERT ON t35v WHEN NEW.a = 3 BEGIN
        SELECT RAISE(ABORT, 'blocked');
    END;
    INSERT INTO t35v VALUES (1);
    INSERT INTO t35v VALUES (2);
    SELECT * FROM t35v ORDER BY a;
}
expect {
    1
    2
}

# --- RAISE(FAIL) preserves prior rows in multi-row VALUES ---

@cross-check-integrity
test trigger-raise-fail-preserves-prior {
    CREATE TABLE t36 (a INTEGER);
    CREATE TRIGGER tr36 BEFORE INSERT ON t36 WHEN NEW.a = 2 BEGIN
        SELECT RAISE(FAIL, 'fail on 2');
    END;
    INSERT INTO t36 VALUES (1), (2), (3);
}
expect error {
    fail on 2
}

# --- RAISE(IGNORE) in BEFORE trigger with multiple statements in body ---
# Statements before RAISE should persist, RAISE skips the row

@cross-check-integrity
test trigger-raise-ignore-partial-body {
    CREATE TABLE t37 (a INTEGER);
    CREATE TABLE log37 (msg TEXT);
    CREATE TRIGGER tr37 BEFORE INSERT ON t37 BEGIN
        INSERT INTO log37 VALUES ('before raise for ' || NEW.a);
        SELECT RAISE(IGNORE);
    END;
    INSERT INTO t37 VALUES (1);
    SELECT * FROM t37;
}
expect {
}

@cross-check-integrity
test trigger-raise-ignore-partial-body-log {
    CREATE TABLE t37b (a INTEGER);
    CREATE TABLE log37b (msg TEXT);
    CREATE TRIGGER tr37b BEFORE INSERT ON t37b BEGIN
        INSERT INTO log37b VALUES ('logged');
        SELECT RAISE(IGNORE);
    END;
    INSERT INTO t37b VALUES (1);
    SELECT * FROM log37b;
}
expect {
    logged
}

# --- RAISE(ROLLBACK) inside explicit transaction ---

@cross-check-integrity
test trigger-raise-rollback-in-transaction {
    CREATE TABLE t38 (a INTEGER);
    CREATE TABLE log38 (msg TEXT);
    CREATE TRIGGER tr38 BEFORE INSERT ON t38 WHEN NEW.a < 0 BEGIN
        SELECT RAISE(ROLLBACK, 'negative not allowed');
    END;
    BEGIN;
    INSERT INTO t38 VALUES (1);
    INSERT INTO log38 VALUES ('committed');
    INSERT INTO t38 VALUES (-1);
}
expect error {
    negative not allowed
}

# --- Trigger with INSERT ... ON CONFLICT (UPSERT) ---

@cross-check-integrity
test trigger-body-upsert {
    CREATE TABLE t39 (a INTEGER);
    CREATE TABLE counters (key TEXT PRIMARY KEY, cnt INTEGER DEFAULT 0);
    CREATE TRIGGER tr39 AFTER INSERT ON t39 BEGIN
        INSERT INTO counters VALUES ('inserts', 1)
        ON CONFLICT(key) DO UPDATE SET cnt = cnt + 1;
    END;
    INSERT INTO t39 VALUES (1);
    INSERT INTO t39 VALUES (2);
    INSERT INTO t39 VALUES (3);
    SELECT * FROM counters;
}
expect {
    inserts|3
}

# --- Trigger with string concatenation using || ---

@cross-check-integrity
test trigger-string-concat {
    CREATE TABLE t40 (first TEXT, last TEXT);
    CREATE TABLE full_names (name TEXT);
    CREATE TRIGGER tr40 AFTER INSERT ON t40 BEGIN
        INSERT INTO full_names VALUES (NEW.first || ' ' || NEW.last);
    END;
    INSERT INTO t40 VALUES ('John', 'Doe');
    INSERT INTO t40 VALUES ('Jane', NULL);
    SELECT * FROM full_names ORDER BY rowid;
}
expect {
    John Doe

}

# --- Trigger with hex() and length() ---

@cross-check-integrity
test trigger-builtin-functions {
    CREATE TABLE t41 (data BLOB);
    CREATE TABLE log41 (hex_val TEXT, len INTEGER);
    CREATE TRIGGER tr41 AFTER INSERT ON t41 BEGIN
        INSERT INTO log41 VALUES (hex(NEW.data), length(NEW.data));
    END;
    INSERT INTO t41 VALUES (X'DEADBEEF');
    SELECT * FROM log41;
}
expect {
    DEADBEEF|4
}

# --- Trigger with abs(), min(), max() ---

@cross-check-integrity
test trigger-math-functions {
    CREATE TABLE t42 (a INTEGER, b INTEGER);
    CREATE TABLE log42 (abs_a INTEGER, min_ab INTEGER, max_ab INTEGER);
    CREATE TRIGGER tr42 AFTER INSERT ON t42 BEGIN
        INSERT INTO log42 VALUES (abs(NEW.a), min(NEW.a, NEW.b), max(NEW.a, NEW.b));
    END;
    INSERT INTO t42 VALUES (-5, 3);
    SELECT * FROM log42;
}
expect {
    5|-5|3
}

# --- Trigger with date/time functions ---

@cross-check-integrity
test trigger-datetime-functions {
    CREATE TABLE t43 (a INTEGER);
    CREATE TABLE log43 (d TEXT);
    CREATE TRIGGER tr43 AFTER INSERT ON t43 BEGIN
        INSERT INTO log43 VALUES (date('2024-01-15', '+' || NEW.a || ' days'));
    END;
    INSERT INTO t43 VALUES (5);
    SELECT * FROM log43;
}
expect {
    2024-01-20
}

# --- Trigger with zeroblob ---

@cross-check-integrity
test trigger-zeroblob {
    CREATE TABLE t44 (size INTEGER);
    CREATE TABLE log44 (data BLOB);
    CREATE TRIGGER tr44 AFTER INSERT ON t44 BEGIN
        INSERT INTO log44 VALUES (zeroblob(NEW.size));
    END;
    INSERT INTO t44 VALUES (4);
    SELECT hex(data), length(data) FROM log44;
}
expect {
    00000000|4
}

# --- Trigger with quote() ---

@cross-check-integrity
test trigger-quote-function {
    CREATE TABLE t45 (a TEXT, b INTEGER, c REAL, d BLOB);
    CREATE TABLE log45 (qa TEXT, qb TEXT, qc TEXT, qd TEXT);
    CREATE TRIGGER tr45 AFTER INSERT ON t45 BEGIN
        INSERT INTO log45 VALUES (quote(NEW.a), quote(NEW.b), quote(NEW.c), quote(NEW.d));
    END;
    INSERT INTO t45 VALUES ('hello', 42, 3.14, X'FF');
    SELECT * FROM log45;
}
expect {
    'hello'|42|3.14|X'FF'
}

# --- Trigger with REPLACE() string function ---

@cross-check-integrity
test trigger-replace-function {
    CREATE TABLE t46 (msg TEXT);
    CREATE TABLE log46 (cleaned TEXT);
    CREATE TRIGGER tr46 AFTER INSERT ON t46 BEGIN
        INSERT INTO log46 VALUES (REPLACE(NEW.msg, 'bad', '***'));
    END;
    INSERT INTO t46 VALUES ('this is bad word');
    SELECT * FROM log46;
}
expect {
    this is *** word
}

# --- Trigger with substr() ---

@cross-check-integrity
test trigger-substr {
    CREATE TABLE t47 (code TEXT);
    CREATE TABLE log47 (prefix TEXT);
    CREATE TRIGGER tr47 AFTER INSERT ON t47 BEGIN
        INSERT INTO log47 VALUES (substr(NEW.code, 1, 3));
    END;
    INSERT INTO t47 VALUES ('ABCDEF');
    SELECT * FROM log47;
}
expect {
    ABC
}

# --- WITHOUT ROWID table with trigger ---
# Skipped: WITHOUT ROWID tables not yet supported (not a trigger bug)

# --- STRICT table with trigger ---

@cross-check-integrity
test trigger-strict-table {
    CREATE TABLE t51 (a INTEGER, b TEXT) STRICT;
    CREATE TABLE log51 (val INTEGER);
    CREATE TRIGGER tr51 AFTER INSERT ON t51 BEGIN
        INSERT INTO log51 VALUES (NEW.a);
    END;
    INSERT INTO t51 VALUES (42, 'hello');
    SELECT * FROM log51;
}
expect {
    42
}

# --- Trigger on table with UNIQUE constraint, INSERT OR REPLACE fires DELETE + INSERT triggers ---

@cross-check-integrity
test trigger-replace-fires-delete-and-insert {
    CREATE TABLE t52 (a INTEGER PRIMARY KEY, b TEXT);
    CREATE TABLE log52 (event TEXT, val TEXT);
    INSERT INTO t52 VALUES (1, 'original');
    CREATE TRIGGER tr52_del BEFORE DELETE ON t52 BEGIN
        INSERT INTO log52 VALUES ('delete', OLD.b);
    END;
    CREATE TRIGGER tr52_ins BEFORE INSERT ON t52 BEGIN
        INSERT INTO log52 VALUES ('insert', NEW.b);
    END;
    INSERT OR REPLACE INTO t52 VALUES (1, 'replaced');
    SELECT * FROM log52 ORDER BY rowid;
}
expect {
    delete|original
    insert|replaced
}

# --- Trigger with multiple statements in body ---

