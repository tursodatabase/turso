# --- Trigger with CASE WHEN on OLD and NEW ---

@cross-check-integrity
test trigger-case-old-new {
    CREATE TABLE t57 (a INTEGER PRIMARY KEY, status TEXT);
    CREATE TABLE log57 (msg TEXT);
    INSERT INTO t57 VALUES (1, 'active');
    CREATE TRIGGER tr57 AFTER UPDATE ON t57 BEGIN
        INSERT INTO log57 VALUES (
            CASE
                WHEN OLD.status = 'active' AND NEW.status = 'inactive' THEN 'deactivated'
                WHEN OLD.status = 'inactive' AND NEW.status = 'active' THEN 'activated'
                ELSE 'status changed'
            END
        );
    END;
    UPDATE t57 SET status = 'inactive' WHERE a = 1;
    UPDATE t57 SET status = 'active' WHERE a = 1;
    SELECT * FROM log57 ORDER BY rowid;
}
expect {
    deactivated
    activated
}

