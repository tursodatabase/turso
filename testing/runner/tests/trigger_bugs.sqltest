}
expect {
    HEL
}

# --- Trigger with modulo operator ---

@cross-check-integrity
test trigger-modulo {
    CREATE TABLE t110 (a INTEGER);
    CREATE TABLE log110 (mod_val INTEGER);
    CREATE TRIGGER tr110 AFTER INSERT ON t110 BEGIN
        INSERT INTO log110 VALUES (NEW.a % 7);
    END;
    INSERT INTO t110 VALUES (15);
    INSERT INTO t110 VALUES (21);
    SELECT * FROM log110 ORDER BY rowid;
}
expect {
    1
    0
}

# --- Trigger with complex WHERE in UPDATE body ---

@cross-check-integrity
test trigger-complex-where-update {
    CREATE TABLE t111 (id INTEGER PRIMARY KEY, val INTEGER);
    CREATE TABLE scores (player TEXT, score INTEGER);
    INSERT INTO scores VALUES ('alice', 100), ('bob', 200), ('carol', 150);
    CREATE TRIGGER tr111 AFTER INSERT ON t111 BEGIN
        UPDATE scores SET score = score + NEW.val WHERE score > 100 AND player != 'bob';
    END;
    INSERT INTO t111 VALUES (1, 50);
    SELECT * FROM scores ORDER BY player;
}
expect {
    alice|100
    bob|200
    carol|200
}

# --- Trigger with RETURNING clause should error ---
# SQLite does not support RETURNING in trigger body statements

# --- Trigger body with ORDER BY in DELETE ---

@cross-check-integrity
test trigger-delete-order-by-limit {
    CREATE TABLE t112 (a INTEGER);
    CREATE TABLE queue (priority INTEGER, msg TEXT);
    INSERT INTO queue VALUES (1, 'low'), (2, 'medium'), (3, 'high');
    CREATE TRIGGER tr112 AFTER INSERT ON t112 BEGIN
        DELETE FROM queue ORDER BY priority ASC LIMIT NEW.a;
    END;
    INSERT INTO t112 VALUES (1);
    SELECT * FROM queue ORDER BY priority;
}
expect {
    2|medium
    3|high
}

# --- Trigger on table with AUTOINCREMENT ---

