    55
}

# --- Trigger with LIKE in WHEN clause ---

@cross-check-integrity
test trigger-when-like {
    CREATE TABLE t123 (name TEXT);
    CREATE TABLE log123 (msg TEXT);
    CREATE TRIGGER tr123 AFTER INSERT ON t123 WHEN NEW.name LIKE 'admin%' BEGIN
        INSERT INTO log123 VALUES ('admin action: ' || NEW.name);
    END;
    INSERT INTO t123 VALUES ('user_john');
    INSERT INTO t123 VALUES ('admin_create');
    INSERT INTO t123 VALUES ('admin_delete');
    SELECT * FROM log123 ORDER BY rowid;
}
expect {
    admin action: admin_create
    admin action: admin_delete
}

# --- UPDATE trigger with SET column = column (no actual change) ---
# Trigger should still fire since the column is in the SET clause

@cross-check-integrity
test trigger-update-no-actual-change {
    CREATE TABLE t124 (a INTEGER PRIMARY KEY, b INTEGER);
    CREATE TABLE log124 (msg TEXT);
    INSERT INTO t124 VALUES (1, 10);
    CREATE TRIGGER tr124 AFTER UPDATE ON t124 BEGIN
        INSERT INTO log124 VALUES ('updated');
    END;
    UPDATE t124 SET b = b WHERE a = 1;
    SELECT * FROM log124;
}
expect {
    updated
}

# --- Trigger that does INSERT ... SELECT with JOIN ---

@cross-check-integrity
test trigger-insert-select-join {
    CREATE TABLE t125 (a INTEGER);
    CREATE TABLE orders (oid INTEGER, pid INTEGER);
    CREATE TABLE products (pid INTEGER PRIMARY KEY, name TEXT);
    INSERT INTO orders VALUES (1, 10), (2, 20);
    INSERT INTO products VALUES (10, 'Widget'), (20, 'Gadget');
    CREATE TABLE log125 (order_detail TEXT);
    CREATE TRIGGER tr125 AFTER INSERT ON t125 BEGIN
        INSERT INTO log125 SELECT 'order ' || o.oid || ': ' || p.name
        FROM orders o JOIN products p ON o.pid = p.pid
        WHERE o.oid = NEW.a;
    END;
    INSERT INTO t125 VALUES (1);
    SELECT * FROM log125;
}
expect {
    order 1: Widget
}

# --- Trigger with LEFT JOIN in body ---

@cross-check-integrity
test trigger-left-join {
    CREATE TABLE t126 (a INTEGER);
    CREATE TABLE base126 (id INTEGER PRIMARY KEY, val TEXT);
    CREATE TABLE ext126 (id INTEGER PRIMARY KEY, extra TEXT);
    INSERT INTO base126 VALUES (1, 'one'), (2, 'two');
    INSERT INTO ext126 VALUES (1, 'has extra');
    CREATE TABLE log126 (result TEXT);
    CREATE TRIGGER tr126 AFTER INSERT ON t126 BEGIN
        INSERT INTO log126 SELECT b.val || ':' || COALESCE(e.extra, 'none')
        FROM base126 b LEFT JOIN ext126 e ON b.id = e.id
        WHERE b.id = NEW.a;
    END;
    INSERT INTO t126 VALUES (1);
    INSERT INTO t126 VALUES (2);
    SELECT * FROM log126 ORDER BY rowid;
}
expect {
    one:has extra
    two:none
}

# --- BEFORE UPDATE can see OLD.rowid ---

@cross-check-integrity
test trigger-old-rowid-in-update {
    CREATE TABLE t127 (a INTEGER PRIMARY KEY, b TEXT);
    CREATE TABLE log127 (old_rid INTEGER, new_rid INTEGER);
    INSERT INTO t127 VALUES (10, 'hello');
    CREATE TRIGGER tr127 BEFORE UPDATE ON t127 BEGIN
        INSERT INTO log127 VALUES (OLD.rowid, NEW.rowid);
    END;
    UPDATE t127 SET b = 'world' WHERE a = 10;
    SELECT * FROM log127;
}
expect {
    10|10
}

