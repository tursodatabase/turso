# --- Trigger with printf ---

@cross-check-integrity
test trigger-printf {
    CREATE TABLE t96 (a REAL);
    CREATE TABLE log96 (formatted TEXT);
    CREATE TRIGGER tr96 AFTER INSERT ON t96 BEGIN
        INSERT INTO log96 VALUES (printf('%.2f', NEW.a));
    END;
    INSERT INTO t96 VALUES (3.14159);
    SELECT * FROM log96;
}
expect {
    3.14
}

# --- Trigger body with LIMIT (SQLite allows this in trigger DELETE) ---

@cross-check-integrity
test trigger-delete-with-limit-in-body {
    CREATE TABLE t97 (a INTEGER);
    CREATE TABLE overflow97 (x INTEGER);
    INSERT INTO overflow97 VALUES (1), (2), (3), (4), (5);
    CREATE TRIGGER tr97 AFTER INSERT ON t97 BEGIN
        DELETE FROM overflow97 ORDER BY x ASC LIMIT 2;
    END;
    INSERT INTO t97 VALUES (1);
    SELECT * FROM overflow97 ORDER BY x;
}
expect {
    3
    4
    5
}

# --- Trigger with multiple RAISE in different branches ---

@cross-check-integrity
test trigger-multiple-raise-branches {
    CREATE TABLE t98 (a INTEGER);
    CREATE TRIGGER tr98 BEFORE INSERT ON t98 BEGIN
        SELECT CASE
            WHEN NEW.a < 0 THEN RAISE(ABORT, 'negative')
            WHEN NEW.a > 100 THEN RAISE(ABORT, 'too large')
            ELSE NEW.a
        END;
    END;
    INSERT INTO t98 VALUES (50);
    SELECT * FROM t98;
}
expect {
    50
}

@cross-check-integrity
test trigger-multiple-raise-negative {
    CREATE TABLE t98b (a INTEGER);
    CREATE TRIGGER tr98b BEFORE INSERT ON t98b BEGIN
        SELECT CASE
            WHEN NEW.a < 0 THEN RAISE(ABORT, 'negative')
            WHEN NEW.a > 100 THEN RAISE(ABORT, 'too large')
            ELSE NEW.a
        END;
    END;
    INSERT INTO t98b VALUES (-5);
}
expect error {
    negative
}

@cross-check-integrity
test trigger-multiple-raise-too-large {
    CREATE TABLE t98c (a INTEGER);
    CREATE TRIGGER tr98c BEFORE INSERT ON t98c BEGIN
        SELECT CASE
            WHEN NEW.a < 0 THEN RAISE(ABORT, 'negative')
            WHEN NEW.a > 100 THEN RAISE(ABORT, 'too large')
            ELSE NEW.a
        END;
    END;
    INSERT INTO t98c VALUES (200);
}
expect error {
    too large
}

# --- BEFORE INSERT trigger that references same table (should see pre-insert state) ---

@cross-check-integrity
test trigger-before-insert-sees-pre-state {
    CREATE TABLE t99 (a INTEGER PRIMARY KEY);
    CREATE TABLE log99 (cnt INTEGER);
    INSERT INTO t99 VALUES (1), (2);
    CREATE TRIGGER tr99 BEFORE INSERT ON t99 BEGIN
        INSERT INTO log99 SELECT COUNT(*) FROM t99;
    END;
    INSERT INTO t99 VALUES (3);
    SELECT * FROM log99;
}
expect {
    2
}

# --- AFTER INSERT trigger that references same table (should see post-insert state) ---

@cross-check-integrity
test trigger-after-insert-sees-post-state {
    CREATE TABLE t100 (a INTEGER PRIMARY KEY);
    CREATE TABLE log100 (cnt INTEGER);
    INSERT INTO t100 VALUES (1), (2);
    CREATE TRIGGER tr100 AFTER INSERT ON t100 BEGIN
        INSERT INTO log100 SELECT COUNT(*) FROM t100;
    END;
    INSERT INTO t100 VALUES (3);
    SELECT * FROM log100;
}
expect {
    3
}

# --- Trigger with unary minus ---

@cross-check-integrity
test trigger-unary-minus {
    CREATE TABLE t101 (a INTEGER);
    CREATE TABLE log101 (neg INTEGER);
    CREATE TRIGGER tr101 AFTER INSERT ON t101 BEGIN
        INSERT INTO log101 VALUES (-NEW.a);
    END;
    INSERT INTO t101 VALUES (42);
    SELECT * FROM log101;
}
expect {
    -42
}

# --- Trigger with bitwise operations ---

@cross-check-integrity
test trigger-bitwise {
    CREATE TABLE t102 (a INTEGER, b INTEGER);
    CREATE TABLE log102 (and_val INTEGER, or_val INTEGER);
    CREATE TRIGGER tr102 AFTER INSERT ON t102 BEGIN
        INSERT INTO log102 VALUES (NEW.a & NEW.b, NEW.a | NEW.b);
    END;
    INSERT INTO t102 VALUES (12, 10);
    SELECT * FROM log102;
}
expect {
    8|14
}

# --- Trigger fires on INSERT OR REPLACE when replacing ---

@cross-check-integrity
test trigger-fires-on-replace {
    CREATE TABLE t103 (a INTEGER PRIMARY KEY, b TEXT);
    CREATE TABLE log103 (event TEXT);
    INSERT INTO t103 VALUES (1, 'original');
    CREATE TRIGGER tr103_ins AFTER INSERT ON t103 BEGIN
        INSERT INTO log103 VALUES ('insert:' || NEW.b);
    END;
    INSERT OR REPLACE INTO t103 VALUES (1, 'replaced');
    SELECT * FROM log103 ORDER BY rowid;
}
expect {
    insert:replaced
}

# --- Trigger with GROUP_CONCAT ---

@cross-check-integrity
test trigger-group-concat {
    CREATE TABLE t104 (a INTEGER);
    CREATE TABLE items104 (grp INTEGER, val TEXT);
    INSERT INTO items104 VALUES (1, 'a'), (1, 'b'), (1, 'c'), (2, 'x');
    CREATE TABLE log104 (result TEXT);
    CREATE TRIGGER tr104 AFTER INSERT ON t104 BEGIN
        INSERT INTO log104 SELECT group_concat(val, ',') FROM items104 WHERE grp = NEW.a;
    END;
    INSERT INTO t104 VALUES (1);
    SELECT * FROM log104;
}
expect {
    a,b,c
}

# --- Trigger with TOTAL and AVG ---

@cross-check-integrity
test trigger-aggregate-total-avg {
    CREATE TABLE t105 (a INTEGER);
    CREATE TABLE nums105 (val REAL);
    INSERT INTO nums105 VALUES (10.0), (20.0), (30.0);
    CREATE TABLE log105 (t REAL, a REAL);
    CREATE TRIGGER tr105 AFTER INSERT ON t105 BEGIN
        INSERT INTO log105 SELECT total(val), avg(val) FROM nums105;
    END;
    INSERT INTO t105 VALUES (1);
    SELECT * FROM log105;
}
expect {
    60.0|20.0
}

# --- Trigger that creates a cascading delete ---

@cross-check-integrity
test trigger-cascading-delete {
    CREATE TABLE parent106 (id INTEGER PRIMARY KEY, name TEXT);
    CREATE TABLE child106 (id INTEGER PRIMARY KEY, pid INTEGER, data TEXT);
    INSERT INTO parent106 VALUES (1, 'parent');
    INSERT INTO child106 VALUES (10, 1, 'child_a'), (11, 1, 'child_b'), (12, 2, 'other');
    CREATE TRIGGER tr106 AFTER DELETE ON parent106 BEGIN
        DELETE FROM child106 WHERE pid = OLD.id;
    END;
    DELETE FROM parent106 WHERE id = 1;
    SELECT * FROM child106 ORDER BY id;
}
expect {
    12|2|other
}

# --- Trigger with DISTINCT in aggregate ---

@cross-check-integrity
test trigger-distinct-aggregate {
    CREATE TABLE t107 (a INTEGER);
    CREATE TABLE vals107 (x INTEGER);
    INSERT INTO vals107 VALUES (1), (2), (2), (3), (3), (3);
    CREATE TABLE log107 (cnt INTEGER, cnt_distinct INTEGER);
    CREATE TRIGGER tr107 AFTER INSERT ON t107 BEGIN
        INSERT INTO log107 SELECT COUNT(x), COUNT(DISTINCT x) FROM vals107;
    END;
    INSERT INTO t107 VALUES (1);
    SELECT * FROM log107;
}
expect {
    6|3
}

# --- Trigger with VALUES clause in INSERT ---

@cross-check-integrity
