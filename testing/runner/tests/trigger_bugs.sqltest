    END;
    CREATE TRIGGER tr_b AFTER INSERT ON chain_b BEGIN
        INSERT INTO chain_c VALUES (NEW.y * 3);
    END;
    CREATE TRIGGER tr_c AFTER INSERT ON chain_c BEGIN
