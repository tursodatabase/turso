# --- Trigger created after data exists, fires only on new operations ---

@cross-check-integrity
test trigger-created-after-data {
    CREATE TABLE t117 (a INTEGER);
    CREATE TABLE log117 (val INTEGER);
    INSERT INTO t117 VALUES (1), (2), (3);
    CREATE TRIGGER tr117 AFTER INSERT ON t117 BEGIN
        INSERT INTO log117 VALUES (NEW.a);
    END;
    INSERT INTO t117 VALUES (4);
    SELECT * FROM log117;
}
expect {
    4
}

# --- Multiple triggers, drop one, other still works ---

@cross-check-integrity
test trigger-drop-one-keep-other {
    CREATE TABLE t118 (a INTEGER);
    CREATE TABLE log118 (source TEXT);
    CREATE TRIGGER tr118a AFTER INSERT ON t118 BEGIN
        INSERT INTO log118 VALUES ('a');
    END;
    CREATE TRIGGER tr118b AFTER INSERT ON t118 BEGIN
        INSERT INTO log118 VALUES ('b');
    END;
    DROP TRIGGER tr118a;
    INSERT INTO t118 VALUES (1);
    SELECT * FROM log118;
}
expect {
    b
}

# --- Trigger with EXISTS in body ---

@cross-check-integrity
test trigger-exists-in-body {
    CREATE TABLE t119 (a INTEGER);
    CREATE TABLE lookup119 (id INTEGER PRIMARY KEY);
    INSERT INTO lookup119 VALUES (1), (3), (5);
    CREATE TABLE log119 (found INTEGER);
    CREATE TRIGGER tr119 AFTER INSERT ON t119 BEGIN
        INSERT INTO log119 VALUES (EXISTS(SELECT 1 FROM lookup119 WHERE id = NEW.a));
    END;
    INSERT INTO t119 VALUES (1);
    INSERT INTO t119 VALUES (2);
    SELECT * FROM log119 ORDER BY rowid;
}
expect {
    1
    0
}

# --- Trigger with NOT EXISTS ---

@cross-check-integrity
test trigger-not-exists {
    CREATE TABLE t120 (a INTEGER);
    CREATE TABLE blocklist (id INTEGER);
    INSERT INTO blocklist VALUES (5), (10);
    CREATE TABLE log120 (val INTEGER);
    CREATE TRIGGER tr120 AFTER INSERT ON t120
    WHEN NOT EXISTS (SELECT 1 FROM blocklist WHERE id = NEW.a) BEGIN
        INSERT INTO log120 VALUES (NEW.a);
    END;
    INSERT INTO t120 VALUES (1);
    INSERT INTO t120 VALUES (5);
    INSERT INTO t120 VALUES (7);
    SELECT * FROM log120 ORDER BY val;
}
expect {
    1
    7
}

