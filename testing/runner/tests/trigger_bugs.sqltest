# --- Trigger with nested CASE ---

@cross-check-integrity
test trigger-nested-case {
    CREATE TABLE t59 (a INTEGER, b INTEGER);
    CREATE TABLE log59 (msg TEXT);
    CREATE TRIGGER tr59 AFTER INSERT ON t59 BEGIN
        INSERT INTO log59 VALUES (
            CASE
                WHEN NEW.a > 0 THEN
                    CASE WHEN NEW.b > 0 THEN 'both positive'
                         ELSE 'a positive only'
                    END
                ELSE 'a not positive'
            END
        );
    END;
    INSERT INTO t59 VALUES (1, 1);
    INSERT INTO t59 VALUES (1, -1);
    INSERT INTO t59 VALUES (-1, 1);
    SELECT * FROM log59 ORDER BY rowid;
}
expect {
    both positive
    a positive only
    a not positive
}

