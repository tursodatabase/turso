---
source: setops.sqltest
expression: |-
  SELECT * FROM (
          SELECT name, department FROM current_employees
          UNION
          SELECT name, department FROM former_employees
      ) AS all_employees
      WHERE department = 'Engineering';
info:
  statement_type: SELECT
  tables:
  - current_employees
  - former_employees
  setup_blocks:
  - schema
  database: ':memory:'
