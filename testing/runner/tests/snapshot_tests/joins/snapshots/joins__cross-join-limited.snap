---
source: joins.sqltest
expression: |-
  SELECT
          c.name AS customer_name,
          p.name AS product_name
      FROM
          customers c
      CROSS JOIN products p
      LIMIT 10;
info:
  statement_type: SELECT
  tables:
  - customers
  - products
  setup_blocks:
  - schema
  database: ':memory:'
---
QUERY PLAN
|--SCAN customers AS c
`--SCAN products AS p

