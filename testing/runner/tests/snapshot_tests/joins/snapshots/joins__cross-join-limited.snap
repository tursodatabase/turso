   4  OpenRead           1   3   0  k(5,B,B,B,B,B)   0  table=products, root=3, iDb=0
   5  Rewind             0  13   0                   0  Rewind table customers
   6    Rewind           1  12   0                   0  Rewind table products
   7      Column         0   1   1                   0  r[1]=customers.name
   8      Column         1   1   2                   0  r[2]=products.name
   9      ResultRow      1   2   0                   0  output=r[1..2]
  10      DecrJumpZero   3  13   0                   0  if (--r[3]==0) goto 13
