---
source: joins.sqltest
expression: |-
  SELECT
          c.name AS customer_name,
          p.name AS product_name,
          p.price
      FROM
          customers c
      CROSS JOIN products p
      WHERE
          c.city = 'Boston'
          AND p.category = 'Books';
info:
  statement_type: SELECT
  tables:
  - customers
  - products
  setup_blocks:
  - schema
  database: ':memory:'
---
