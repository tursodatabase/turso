---
source: joins.sqltest
expression: |-
  SELECT h.customer_name, count(*) as item_count, sum(i.quantity) as total_qty
      FROM h_orders h
      JOIN h_items i ON h.customer_name = i.order_name
      GROUP BY h.customer_name;
info:
  statement_type: SELECT
  tables:
  - h.customer_name
  - h_items
  - h_orders
  setup_blocks:
  - hash_schema
  database: ':memory:'
---
