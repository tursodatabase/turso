---
source: windows.sqltest
expression: |-
  SELECT
          emp_id,
          name,
          department,
          salary,
          dept_avg,
          salary - dept_avg AS diff_from_avg,
          ROW_NUMBER() OVER (ORDER BY salary - dept_avg DESC) AS rank_by_diff
      FROM (
          SELECT
              emp_id,
              name,
              department,
              salary,
              AVG(salary) OVER (PARTITION BY department) AS dept_avg
          FROM employees
      );
info:
  statement_type: SELECT
  tables:
  - employees
  setup_blocks:
  - schema
  database: ':memory:'
