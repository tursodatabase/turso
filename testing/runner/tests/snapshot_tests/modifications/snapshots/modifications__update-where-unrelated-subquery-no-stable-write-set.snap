---
source: modifications.sqltest
expression: |-
  UPDATE products
      SET quantity = quantity + 1
      WHERE EXISTS (
          SELECT 1
          FROM users
          WHERE users.id = products.id
      );
info:
  statement_type: UPDATE
  tables:
  - products
  - users
  setup_blocks:
  - schema
  database: ':memory:'
---
