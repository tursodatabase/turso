---
source: subqueries.sqltest
expression: |-
  WITH dept_avg AS (
          SELECT department, avg(salary) AS avg_salary
          FROM employees
          GROUP BY department
      )
      SELECT e.name, e.department, e.salary
      FROM employees e
      WHERE e.salary > (
          SELECT da.avg_salary
          FROM dept_avg da
          WHERE da.department = e.department
      );
info:
  statement_type: WITH (CTE)
  tables:
  - dept_avg
  - employees
  setup_blocks:
  - schema
  database: ':memory:'
---
QUERY PLAN
|--SCAN employees AS e
`--CORRELATED SCALAR SUBQUERY 1
   `--SEARCH da USING INDEX ephemeral_subquery_t6 (department=?)
      |--SCAN employees
      `--USE SORTER FOR GROUP BY

