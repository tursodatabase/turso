|  |--SCAN orders USING INDEX idx_orders_customer
|  `--SCAN order_totals
|--SCALAR SUBQUERY 2
|  `--SCAN order_totals
|--SCAN order_totals AS ot
`--SEARCH c USING INTEGER PRIMARY KEY (rowid=?)

