|--SCAN orders
|--SCAN vip_customers AS v
|  |--LIST SUBQUERY 1
|  |  `--SCAN large_orders
|  `--SEARCH customers USING INTEGER PRIMARY KEY (rowid=?)
`--SEARCH l USING INDEX ephemeral_subquery_t8 (customer_id=?)

