---
source: subqueries.sqltest
expression: |-
  SELECT gv.grp, SUM(gv.val) AS total
      FROM grouped_values gv
      GROUP BY gv.grp
      ORDER BY (
          SELECT MAX(gv2.val)
          FROM grouped_values gv2
          WHERE gv2.grp = gv.grp
      ) DESC;
info:
  statement_type: SELECT
  tables:
  - grouped_values
  setup_blocks:
  - grouped_subquery_schema
  database: ':memory:'
---
