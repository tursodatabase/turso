    INSERT INTO csq1 VALUES (1, '{1,2,3}');
    INSERT INTO csq1 VALUES (2, '{4,5}');
    INSERT INTO csq1 VALUES (3, '{6,7,8,9}');
    SELECT id FROM csq1 WHERE array_length(vals) = (SELECT MAX(array_length(vals)) FROM csq1);
}
