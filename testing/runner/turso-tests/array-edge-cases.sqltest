test union-all-with-arrays {
    CREATE TABLE ua1 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO ua1 VALUES (1, '{1,2,3}');
    INSERT INTO ua1 VALUES (2, '{4,5,6}');
    SELECT vals FROM ua1 WHERE id = 1 UNION ALL SELECT vals FROM ua1 WHERE id = 2;
}
expect {
    {1,2,3}
    {4,5,6}
}

test union-dedup-with-arrays {
    CREATE TABLE ud1 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO ud1 VALUES (1, '{1,2,3}');
    INSERT INTO ud1 VALUES (2, '{4,5,6}');
    INSERT INTO ud1 VALUES (3, '{1,2,3}');
    SELECT COUNT(*) FROM (SELECT DISTINCT vals FROM ud1);
}
expect {
    2
}

test intersect-with-arrays {
    CREATE TABLE it1 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO it1 VALUES (1, '{1,2,3}');
    INSERT INTO it1 VALUES (2, '{4,5,6}');
    SELECT vals FROM it1 INTERSECT SELECT vals FROM it1 WHERE id = 1;
}
expect {
    {1,2,3}
}

test except-with-arrays {
    CREATE TABLE et1 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO et1 VALUES (1, '{1,2,3}');
    INSERT INTO et1 VALUES (2, '{4,5,6}');
    SELECT vals FROM et1 EXCEPT SELECT vals FROM et1 WHERE id = 1;
}
expect {
    {4,5,6}
}

test cte-with-arrays {
    CREATE TABLE cte1 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO cte1 VALUES (1, '{1,2,3}');
    INSERT INTO cte1 VALUES (2, '{4,5,6}');
    WITH arr_cte AS (SELECT id, vals FROM cte1) SELECT id, vals FROM arr_cte ORDER BY id;
}
expect {
    1|{1,2,3}
    2|{4,5,6}
}

test returning-insert-array {
    CREATE TABLE ri1 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO ri1 VALUES (1, '{1,2,3}') RETURNING id, vals;
}
expect {
    1|{1,2,3}
}

test returning-update-array {
    CREATE TABLE ru1 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO ru1 VALUES (1, '{1,2,3}');
    UPDATE ru1 SET vals = '{4,5,6}' WHERE id = 1 RETURNING vals;
}
expect {
    {4,5,6}
}

test returning-delete-array {
    CREATE TABLE rd1 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO rd1 VALUES (1, '{1,2,3}');
    DELETE FROM rd1 WHERE id = 1 RETURNING vals;
}
expect {
    {1,2,3}
}

test insert-or-replace-array {
    CREATE TABLE ior1 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO ior1 VALUES (1, '{1,2,3}');
    INSERT OR REPLACE INTO ior1 VALUES (1, '{4,5,6}');
    SELECT * FROM ior1;
}
expect {
    1|{4,5,6}
}

test between-with-arrays {
    CREATE TABLE bw1 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO bw1 VALUES (1, '{1,0}');
    INSERT INTO bw1 VALUES (2, '{1,5}');
    INSERT INTO bw1 VALUES (3, '{2,0}');
    SELECT id FROM bw1 WHERE vals BETWEEN ARRAY[1,0] AND ARRAY[1,5] ORDER BY id;
}
expect {
    1
    2
}

test in-clause-with-arrays {
    CREATE TABLE ic1 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO ic1 VALUES (1, '{1,2,3}');
    INSERT INTO ic1 VALUES (2, '{4,5,6}');
    INSERT INTO ic1 VALUES (3, '{7,8,9}');
    SELECT id FROM ic1 WHERE vals IN (ARRAY[1,2,3], ARRAY[7,8,9]) ORDER BY id;
}
expect {
    1
    3
}

test concat-operator-display {
    CREATE TABLE co1 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO co1 VALUES (1, ARRAY[1,2]);
    SELECT vals || ARRAY[3,4] FROM co1;
}
expect {
    {1,2,3,4}
}

test delete-where-array {
    CREATE TABLE dw1 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO dw1 VALUES (1, '{1,2,3}');
    INSERT INTO dw1 VALUES (2, '{4,5,6}');
    DELETE FROM dw1 WHERE vals = ARRAY[1,2,3];
    SELECT * FROM dw1;
}
expect {
    2|{4,5,6}
}

test update-array-reject-non-array {
    CREATE TABLE ur1 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO ur1 VALUES (1, '{1,2,3}');
    UPDATE ur1 SET vals = 42 WHERE id = 1;
}
expect error {
    cannot store non-array value in INTEGER column ur1.vals
}

test mixed-type-order-by {
    CREATE TABLE mto1 (id INTEGER PRIMARY KEY, vals any[]) STRICT;
    INSERT INTO mto1 VALUES (1, ARRAY[1, 'hello']);
    INSERT INTO mto1 VALUES (2, ARRAY[1, 2]);
    INSERT INTO mto1 VALUES (3, ARRAY[NULL, 1]);
    SELECT id, vals FROM mto1 ORDER BY vals;
}
expect {
    3|{NULL,1}
    2|{1,2}
    1|{1,hello}
}

test order-by-null-elements {
    CREATE TABLE one1 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO one1 VALUES (1, ARRAY[1,2,3]);
    INSERT INTO one1 VALUES (2, ARRAY[1,NULL,3]);
    INSERT INTO one1 VALUES (3, ARRAY[1,2]);
    SELECT id, vals FROM one1 ORDER BY vals;
}
expect {
    2|{1,NULL,3}
    3|{1,2}
    1|{1,2,3}
}

test order-by-empty-and-null-arrays {
    CREATE TABLE oena1 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO oena1 VALUES (1, ARRAY[NULL]);
    INSERT INTO oena1 VALUES (2, ARRAY[0]);
    INSERT INTO oena1 VALUES (3, ARRAY[]);
    INSERT INTO oena1 VALUES (4, ARRAY[NULL, NULL]);
    SELECT id, vals FROM oena1 ORDER BY vals;
}
expect {
    3|{}
    1|{NULL}
    4|{NULL,NULL}
    2|{0}
}

test chained-array-functions {
    CREATE TABLE caf1 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO caf1 VALUES (1, '{1,2,3}');
    SELECT array_to_string(array_append(array_prepend(0, vals), 4), ',') FROM caf1;
}
expect {
    0,1,2,3,4
}

test chained-array-remove {
    CREATE TABLE car1 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO car1 VALUES (1, '{1,2,3}');
    SELECT array_to_string(array_remove(array_remove(vals, 1), 3), ',') FROM car1;
}
expect {
    2
}

