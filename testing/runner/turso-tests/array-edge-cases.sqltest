@database :memory:
@requires-file custom_types "array tests require custom types support"

test null-element-contains {
    SELECT array_contains(ARRAY[1, NULL, 3], NULL);
}
expect {
    1
}

test null-element-contains-int {
    SELECT array_contains(ARRAY[1, NULL, 3], 2);
}
expect {
    0
}

test null-element-position {
    SELECT array_position(ARRAY[1, NULL, 3], NULL);
}
expect {
    2
}

test null-element-remove {
    SELECT array_to_string(array_remove(ARRAY[1, NULL, 3], NULL), ',');
}
expect {
    1,3
}

test null-element-overlap {
    SELECT array_overlap(ARRAY[NULL, 1], ARRAY[NULL, 2]);
}
expect {
    1
}

test null-element-contains-all {
    SELECT array_contains_all(ARRAY[1, NULL, 3], ARRAY[NULL, 1]);
}
expect {
    1
}

test empty-array-contains {
    SELECT array_contains(ARRAY[], 1);
}
expect {
    0
}

test empty-array-length {
    SELECT array_length(ARRAY[]);
}
expect {
    0
}

test empty-array-append {
    SELECT array_to_string(array_append(ARRAY[], 42), ',');
}
expect {
    42
}

test empty-array-cat {
    SELECT array_to_string(array_cat(ARRAY[], ARRAY[1,2]), ',');
}
expect {
    1,2
}

test empty-array-comparison-eq {
    SELECT ARRAY[] = ARRAY[];
}
expect {
    1
}

test empty-array-comparison-lt {
    SELECT ARRAY[] < ARRAY[1];
}
expect {
    1
}

test single-element-array {
    SELECT array_length(ARRAY[42]);
}
expect {
    1
}

test array-comparison-equal {
    SELECT ARRAY[1,2,3] = ARRAY[1,2,3];
}
expect {
    1
}

test array-comparison-not-equal {
    SELECT ARRAY[1,2,3] != ARRAY[1,2,4];
}
expect {
    1
}

test array-comparison-less {
    SELECT ARRAY[1,2] < ARRAY[1,2,3];
}
expect {
    1
}

test array-comparison-greater {
    SELECT ARRAY[1,3] > ARRAY[1,2];
}
expect {
    1
}

test array-comparison-null-element-eq {
    CREATE TABLE cmp1 (id INTEGER PRIMARY KEY, a integer[], b integer[]) STRICT;
    INSERT INTO cmp1 VALUES (1, ARRAY[1, NULL, 3], ARRAY[1, NULL, 3]);
    SELECT a = b FROM cmp1;
}
expect {
    1
}

test array-slice-empty-range {
    SELECT array_length(array_slice(ARRAY[1,2,3], 3, 2));
}
expect {
    0
}

test array-slice-beyond-end {
    SELECT array_to_string(array_slice(ARRAY[1,2,3], 1, 100), ',');
}
expect {
    1,2,3
}

test array-slice-zero-zero {
    SELECT array_length(array_slice(ARRAY[1,2,3], 0, 0));
}
expect {
    0
}

test array-position-not-found-is-null {
    SELECT COALESCE(array_position(ARRAY[1,2,3], 99), -1);
}
expect {
    -1
}

test array-length-null-is-null {
    SELECT COALESCE(array_length(NULL), -1);
}
expect {
    -1
}

test string-to-array-empty-string {
    SELECT array_length(string_to_array('', ','));
}
expect {
    1
}

test string-to-array-empty-delimiter {
    SELECT array_to_string(string_to_array('hello', ''), ',');
}
expect {
    hello
}

test string-to-array-null-replacement {
    SELECT array_to_string(string_to_array('a,,b', ',', ''), ',', 'NULL');
}
expect {
    a,NULL,b
}

test array-to-string-null-elements {
    SELECT array_to_string(ARRAY[1, NULL, 3], ',');
}
expect {
    1,3
}

test array-to-string-null-replacement {
    SELECT array_to_string(ARRAY[1, NULL, 3], ',', 'N/A');
}
expect {
    1,N/A,3
}

test array-append-null-element {
    SELECT array_to_string(array_append(ARRAY[1,2], NULL), ',', 'N');
}
expect {
    1,2,N
}

test array-prepend-null-element {
    SELECT array_to_string(array_prepend(NULL, ARRAY[1,2]), ',', 'N');
}
expect {
    N,1,2
}

test array-cat-both-empty {
    SELECT array_length(array_cat(ARRAY[], ARRAY[]));
}
expect {
    0
}

test array-cat-null-left-is-null {
    SELECT COALESCE(array_length(array_cat(NULL, ARRAY[1,2])), -1);
}
expect {
    -1
}

test array-cat-null-right-is-null {
    SELECT COALESCE(array_length(array_cat(ARRAY[1,2], NULL)), -1);
}
expect {
    -1
}

test array-remove-not-found {
    SELECT array_to_string(array_remove(ARRAY[1,2,3], 99), ',');
}
expect {
    1,2,3
}

test array-remove-all-elements {
    SELECT array_length(array_remove(ARRAY[1,1,1], 1));
}
expect {
    0
}

test upsert-array-basic {
    CREATE TABLE ups1 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO ups1 VALUES (1, '{1,2,3}');
    INSERT INTO ups1 VALUES (1, '{4,5,6}') ON CONFLICT(id) DO UPDATE SET vals = excluded.vals;
    SELECT id, vals FROM ups1;
}
expect {
    1|{4,5,6}
}

test upsert-array-append {
    CREATE TABLE ups2 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO ups2 VALUES (1, ARRAY[1,2]);
    INSERT INTO ups2 VALUES (1, ARRAY[3]) ON CONFLICT(id) DO UPDATE SET vals = array_cat(ups2.vals, excluded.vals);
    SELECT id, vals FROM ups2;
}
expect {
    1|{1,2,3}
}

test upsert-array-do-nothing {
    CREATE TABLE ups3 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO ups3 VALUES (1, '{1,2,3}');
    INSERT INTO ups3 VALUES (1, '{4,5,6}') ON CONFLICT DO NOTHING;
    SELECT id, vals FROM ups3;
}
expect {
    1|{1,2,3}
}

test array-in-subquery {
    CREATE TABLE sq1 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO sq1 VALUES (1, '{10,20}');
    INSERT INTO sq1 VALUES (2, '{30,40}');
    SELECT vals FROM sq1 WHERE id = (SELECT MAX(id) FROM sq1);
}
expect {
    {30,40}
}

test array-in-where-comparison {
    CREATE TABLE wh1 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO wh1 VALUES (1, '{1,2,3}');
    INSERT INTO wh1 VALUES (2, '{4,5,6}');
    SELECT id FROM wh1 WHERE vals = ARRAY[1,2,3];
}
expect {
    1
}

test array-group-by-with-array-agg {
    CREATE TABLE gb1 (cat TEXT, val INTEGER) STRICT;
    INSERT INTO gb1 VALUES ('a', 1);
    INSERT INTO gb1 VALUES ('a', 2);
    INSERT INTO gb1 VALUES ('b', 3);
    SELECT cat, array_agg(val) FROM gb1 GROUP BY cat ORDER BY cat;
}
expect {
    a|{1,2}
    b|{3}
}

test array-distinct {
    CREATE TABLE dist1 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO dist1 VALUES (1, '{1,2}');
    INSERT INTO dist1 VALUES (2, '{1,2}');
    INSERT INTO dist1 VALUES (3, '{3,4}');
    SELECT DISTINCT vals FROM dist1 ORDER BY vals;
}
expect {
    {1,2}
    {3,4}
}

test array-concat-two-arrays {
    CREATE TABLE cc1 (id INTEGER PRIMARY KEY, a integer[], b integer[]) STRICT;
    INSERT INTO cc1 VALUES (1, ARRAY[1,2], ARRAY[3,4]);
    SELECT a || b FROM cc1;
}
expect {
    {1,2,3,4}
}

test array-length-with-dimension {
    SELECT array_length(ARRAY[1,2,3], 1);
}
expect {
    3
}

test array-insert-select {
    CREATE TABLE is1 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    CREATE TABLE is2 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO is1 VALUES (1, '{1,2,3}');
    INSERT INTO is1 VALUES (2, '{4,5,6}');
    INSERT INTO is2 SELECT * FROM is1;
    SELECT id, vals FROM is2 ORDER BY id;
}
expect {
    1|{1,2,3}
    2|{4,5,6}
}

test array-update-to-null-then-check {
    CREATE TABLE un1 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO un1 VALUES (1, '{1,2,3}');
    UPDATE un1 SET vals = NULL WHERE id = 1;
    SELECT id, COALESCE(array_length(vals), -1) FROM un1;
}
expect {
    1|-1
}

test array-update-with-function {
    CREATE TABLE uf1 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO uf1 VALUES (1, '{1,2,3}');
    UPDATE uf1 SET vals = array_append(vals, 4) WHERE id = 1;
    SELECT id, vals FROM uf1;
}
expect {
    1|{1,2,3,4}
}

test array-contains-operator {
    CREATE TABLE co1 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO co1 VALUES (1, '{1,2,3,4,5}');
    INSERT INTO co1 VALUES (2, '{10,20,30}');
    SELECT id FROM co1 WHERE vals @> ARRAY[1,3];
}
expect {
    1
}

test array-overlap-operator {
    CREATE TABLE oo1 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO oo1 VALUES (1, '{1,2,3}');
    INSERT INTO oo1 VALUES (2, '{4,5,6}');
    SELECT id FROM oo1 WHERE vals && ARRAY[2,5];
}
expect {
    1
    2
}

test array-pg-parse-nested-strings {
    CREATE TABLE jp1 (id INTEGER PRIMARY KEY, vals text[]) STRICT;
    INSERT INTO jp1 VALUES (1, '{"hello \"world\"", "foo\\nbar"}');
    SELECT vals FROM jp1;
}
expect {
    {"hello \"world\"","foo\nbar"}
}

test array-pg-parse-booleans {
    CREATE TABLE jp2 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO jp2 VALUES (1, '{1, 0, 1}');
    SELECT vals FROM jp2;
}
expect {
    {1,0,1}
}

test array-pg-parse-mixed-whitespace {
    CREATE TABLE jp3 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO jp3 VALUES (1, '{  1 ,  2  , 3  }');
    SELECT vals FROM jp3;
}
expect {
    {1,2,3}
}

test array-pg-parse-scientific-notation {
    CREATE TABLE jp4 (id INTEGER PRIMARY KEY, vals real[]) STRICT;
    INSERT INTO jp4 VALUES (1, '{1.5e2, 2.0e-1}');
    SELECT vals FROM jp4;
}
expect {
    {150.0,0.2}
}

test array-invalid-json-no-brackets {
    CREATE TABLE ij1 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO ij1 VALUES (1, 'not an array');
}
expect error {
    cannot store non-array value in INTEGER column ij1.vals
}

test array-invalid-json-object {
    CREATE TABLE ij2 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO ij2 VALUES (1, '{"key": "value"}');
}
expect error {
    cannot store non-array value in INTEGER column ij2.vals
}

test array-invalid-type-mismatch {
    CREATE TABLE ij3 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO ij3 VALUES (1, '{"not", "integers"}');
}
expect error {
    cannot store TEXT value in INTEGER
}

test array-real-type-accepts-integers {
    CREATE TABLE rt1 (id INTEGER PRIMARY KEY, vals real[]) STRICT;
    INSERT INTO rt1 VALUES (1, '{1, 2, 3}');
    SELECT vals FROM rt1;
}
expect {
    {1.0,2.0,3.0}
}

test array-order-by-with-nulls {
    CREATE TABLE obn1 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO obn1 VALUES (1, '{1,2,3}');
    INSERT INTO obn1 VALUES (2, NULL);
    INSERT INTO obn1 VALUES (3, '{1,2}');
    SELECT id, COALESCE(array_to_string(vals, ','), 'NULL') FROM obn1 ORDER BY vals;
}
expect {
    2|NULL
    3|1,2
    1|1,2,3
}

test array-order-by-limit {
    CREATE TABLE obl1 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO obl1 VALUES (1, '{3,2,1}');
    INSERT INTO obl1 VALUES (2, '{1,2,3}');
    INSERT INTO obl1 VALUES (3, '{1,2}');
    INSERT INTO obl1 VALUES (4, '{1,2,4}');
    SELECT id, vals FROM obl1 ORDER BY vals LIMIT 2;
}
expect {
    3|{1,2}
    2|{1,2,3}
}

test array-count-aggregate {
    CREATE TABLE ca1 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO ca1 VALUES (1, '{1,2,3}');
    INSERT INTO ca1 VALUES (2, NULL);
    INSERT INTO ca1 VALUES (3, '{4,5}');
    SELECT COUNT(vals), COUNT(*) FROM ca1;
}
expect {
    2|3
}

test array-multiple-array-columns {
    CREATE TABLE mc1 (id INTEGER PRIMARY KEY, a integer[], b text[]) STRICT;
    INSERT INTO mc1 VALUES (1, '{1,2}', '{"x","y"}');
    SELECT id, a, b FROM mc1;
}
expect {
    1|{1,2}|{x,y}
}

test array-subscript-basic {
    CREATE TABLE sb1 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO sb1 VALUES (1, '{10,20,30}');
    SELECT vals[1], vals[2], vals[3] FROM sb1;
}
expect {
    10|20|30
}

test array-subscript-out-of-bounds-is-null {
    CREATE TABLE sb2 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO sb2 VALUES (1, '{10,20,30}');
    SELECT COALESCE(vals[99], -1) FROM sb2;
}
expect {
    -1
}

test array-subscript-in-where {
    CREATE TABLE sb3 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO sb3 VALUES (1, '{10,20,30}');
    INSERT INTO sb3 VALUES (2, '{40,50,60}');
    SELECT id FROM sb3 WHERE vals[1] > 30;
}
expect {
    2
}

test array-with-join {
    CREATE TABLE j1 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    CREATE TABLE j2 (id INTEGER PRIMARY KEY, name TEXT) STRICT;
    INSERT INTO j1 VALUES (1, '{1,2,3}');
    INSERT INTO j2 VALUES (1, 'one');
    SELECT j2.name, j1.vals FROM j1 JOIN j2 ON j1.id = j2.id;
}
expect {
    one|{1,2,3}
}

test array-max-element-type-coercion {
    CREATE TABLE tc1 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO tc1 VALUES (1, '{1, 2.0, 3}');
    SELECT vals FROM tc1;
}
expect {
    {1,2,3}
}

test array-leading-comma-rejected {
    CREATE TABLE lc1 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO lc1 VALUES (1, '{,1,2}');
}
expect error {
    cannot store TEXT value in INTEGER
}

test array-double-comma-rejected {
    CREATE TABLE dc1 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO dc1 VALUES (1, '{1,,2}');
}
expect error {
    cannot store TEXT value in INTEGER
}

test array-nested-array-rejected-for-1d {
    CREATE TABLE na1 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO na1 VALUES (1, '{[1,2],[3,4]}');
}
expect error {
    cannot store TEXT value in INTEGER
}

test array-order-by-multiple-keys {
    CREATE TABLE omk1 (id INTEGER PRIMARY KEY, name TEXT, vals integer[]) STRICT;
    INSERT INTO omk1 VALUES (1, 'a', '{2,1}');
    INSERT INTO omk1 VALUES (2, 'b', '{1,2}');
    INSERT INTO omk1 VALUES (3, 'c', '{1,2}');
    SELECT id, name, vals FROM omk1 ORDER BY vals, name;
}
expect {
    2|b|{1,2}
    3|c|{1,2}
    1|a|{2,1}
}

test array-agg-empty-group {
    CREATE TABLE aeg1 (cat TEXT, val INTEGER) STRICT;
    INSERT INTO aeg1 VALUES ('a', 1);
    SELECT cat, array_agg(val) FROM aeg1 WHERE cat = 'nonexistent' GROUP BY cat;
}
expect {
}

test array-where-with-function {
    CREATE TABLE wf1 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO wf1 VALUES (1, '{1,2,3}');
    INSERT INTO wf1 VALUES (2, '{4,5,6}');
    SELECT id FROM wf1 WHERE array_length(vals) = 3;
}
expect {
    1
    2
}

test array-where-contains-function {
    CREATE TABLE wf2 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO wf2 VALUES (1, '{1,2,3}');
    INSERT INTO wf2 VALUES (2, '{4,5,6}');
    SELECT id FROM wf2 WHERE array_contains(vals, 2) = 1;
}
expect {
    1
}

test array-select-star-display {
    CREATE TABLE sd1 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO sd1 VALUES (1, '{1,2,3}');
    SELECT * FROM sd1;
}
expect {
    1|{1,2,3}
}

test array-left-join-null {
    CREATE TABLE lj1 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    CREATE TABLE lj2 (id INTEGER PRIMARY KEY, name TEXT) STRICT;
    INSERT INTO lj2 VALUES (1, 'one');
    INSERT INTO lj2 VALUES (2, 'two');
    INSERT INTO lj1 VALUES (1, '{10,20}');
    SELECT lj2.name, COALESCE(array_to_string(lj1.vals, ','), 'NONE') FROM lj2 LEFT JOIN lj1 ON lj2.id = lj1.id ORDER BY lj2.id;
}
expect {
    one|10,20
    two|NONE
}

test array-case-when-subscript {
    CREATE TABLE cws1 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO cws1 VALUES (1, '{10,20,30}');
    SELECT CASE WHEN vals[1] > 5 THEN 'big' ELSE 'small' END FROM cws1;
}
expect {
    big
}

test array-between-comparison {
    CREATE TABLE bc1 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO bc1 VALUES (1, '{1,0}');
    INSERT INTO bc1 VALUES (2, '{1,5}');
    INSERT INTO bc1 VALUES (3, '{2,0}');
    SELECT id FROM bc1 WHERE vals >= ARRAY[1,0] AND vals <= ARRAY[1,5];
}
expect {
    1
    2
}

test array-text-type-empty-strings {
    CREATE TABLE es1 (id INTEGER PRIMARY KEY, vals text[]) STRICT;
    INSERT INTO es1 VALUES (1, '{"", "hello", ""}');
    SELECT vals FROM es1;
}
expect {
    {"",hello,""}
}

test array-real-precision {
    CREATE TABLE rp1 (id INTEGER PRIMARY KEY, vals real[]) STRICT;
    INSERT INTO rp1 VALUES (1, '{0.1, 0.2, 0.3}');
    SELECT vals FROM rp1;
}
expect {
    {0.1,0.2,0.3}
}

test array-integer-max-values {
    CREATE TABLE imv1 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO imv1 VALUES (1, '{9223372036854775807, -9223372036854775808, 0}');
    SELECT vals FROM imv1;
}
expect {
    {9223372036854775807,-9223372036854775808,0}
}

test array-any-type-mixed {
    CREATE TABLE any1 (id INTEGER PRIMARY KEY, vals any[]) STRICT;
    INSERT INTO any1 VALUES (1, ARRAY[1, 'hello', 3.14, NULL]);
    SELECT vals FROM any1;
}
expect {
    {1,hello,3.14,NULL}
}

test array-order-by-real {
    CREATE TABLE obr1 (id INTEGER PRIMARY KEY, vals real[]) STRICT;
    INSERT INTO obr1 VALUES (1, '{2.5, 1.0}');
    INSERT INTO obr1 VALUES (2, '{1.5, 2.0}');
    INSERT INTO obr1 VALUES (3, '{1.5, 1.0}');
    SELECT id, vals FROM obr1 ORDER BY vals;
}
expect {
    3|{1.5,1.0}
    2|{1.5,2.0}
    1|{2.5,1.0}
}

test array-min-max-display {
    CREATE TABLE mm1 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO mm1 VALUES (1, '{3,2,1}');
    INSERT INTO mm1 VALUES (2, '{1,2,3}');
    INSERT INTO mm1 VALUES (3, '{1,2}');
    SELECT MIN(vals), MAX(vals) FROM mm1;
}
expect {
    {1,2}|{3,2,1}
}

test array-min-max-group-by {
    CREATE TABLE mm2 (cat TEXT, vals integer[]) STRICT;
    INSERT INTO mm2 VALUES ('a', '{3,2}');
    INSERT INTO mm2 VALUES ('a', '{1,2}');
    INSERT INTO mm2 VALUES ('b', '{5,6}');
    SELECT cat, MIN(vals), MAX(vals) FROM mm2 GROUP BY cat ORDER BY cat;
}
expect {
    a|{1,2}|{3,2}
    b|{5,6}|{5,6}
}

test array-scalar-max-display {
    SELECT MAX(ARRAY[1,2], ARRAY[1,2,3]);
}
expect {
    {1,2,3}
}

test array-order-by-text-arrays {
    CREATE TABLE obt1 (id INTEGER PRIMARY KEY, vals text[]) STRICT;
    INSERT INTO obt1 VALUES (1, '{"banana"}');
    INSERT INTO obt1 VALUES (2, '{"apple"}');
    INSERT INTO obt1 VALUES (3, '{"cherry"}');
    SELECT id, vals FROM obt1 ORDER BY vals;
}
expect {
    2|{apple}
    1|{banana}
    3|{cherry}
}
