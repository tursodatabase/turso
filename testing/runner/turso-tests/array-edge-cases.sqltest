    SELECT array_to_string(array_remove(ARRAY[1, NULL, 3], NULL), ',');
}
expect {
    1,3
}

test array-remove-preserves-duplicates {
    SELECT array_to_string(array_remove(ARRAY[1,2,1,3,1], 1), ',');
}
expect {
    2,3
}


test string-to-array-null-delimiter-splits-chars {
    SELECT array_to_string(string_to_array('abc', NULL), ',');
}
expect {
    a,b,c
}

test string-to-array-multichar-delimiter {
    SELECT array_to_string(string_to_array('a::b::c', '::'), ',');
}
expect {
    a,b,c
}

test string-to-array-delimiter-at-boundaries {
    SELECT array_to_string(string_to_array(',a,b,', ','), '|');
}
expect {
    |a|b|
}


test array-eq-different-lengths-not-equal {
    SELECT ARRAY[1,2] = ARRAY[1,2,3];
}
expect {
    0
}

test array-lt-prefix-shorter {
    SELECT ARRAY[1,2] < ARRAY[1,2,0];
}
expect {
    1
}

test array-gt-first-element-wins {
    SELECT ARRAY[2] > ARRAY[1,999,999];
}
expect {
    1
}

test array-eq-empty-arrays {
    SELECT ARRAY[] = ARRAY[];
}
expect {
    1
}

test array-neq-empty-vs-nonempty {
    SELECT ARRAY[] != ARRAY[1];
}
expect {
    1
}


test returning-update-with-append {
    CREATE TABLE rua1 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO rua1 VALUES (1, '{1,2}');
    UPDATE rua1 SET vals = array_append(vals, 3) WHERE id = 1 RETURNING vals;
}
expect {
    {1,2,3}
}

test returning-insert-array-literal {
    CREATE TABLE ril1 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO ril1 VALUES (1, ARRAY[10,20,30]) RETURNING array_length(vals);
}
expect {
    3
}


test array-insert-rollback {
    CREATE TABLE air1 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO air1 VALUES (1, '{1,2,3}');
    BEGIN;
    UPDATE air1 SET vals = '{4,5,6}' WHERE id = 1;
    ROLLBACK;
    SELECT vals FROM air1;
}
expect {
    {1,2,3}
}

test array-delete-rollback {
    CREATE TABLE adr1 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO adr1 VALUES (1, '{1,2,3}');
    BEGIN;
    DELETE FROM adr1 WHERE id = 1;
    ROLLBACK;
    SELECT vals FROM adr1;
}
expect {
    {1,2,3}
}


test distinct-order-by-desc-arrays {
    CREATE TABLE dod1 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO dod1 VALUES (1, '{1,2}');
    INSERT INTO dod1 VALUES (2, '{3,4}');
    INSERT INTO dod1 VALUES (3, '{1,2}');
    SELECT DISTINCT vals FROM dod1 ORDER BY vals DESC;
}
expect {
    {3,4}
    {1,2}
}


test append-to-null-array {
    SELECT COALESCE(array_length(array_append(NULL, 1)), -1);
}
expect {
    1
}

test prepend-to-null-array {
    SELECT COALESCE(array_length(array_prepend(1, NULL)), -1);
}
expect {
    1
}


test deeply-chained-operations {
    SELECT array_to_string(
        array_remove(
            array_append(
                array_prepend(0,
                    array_cat(ARRAY[1,2], ARRAY[3,4])
                ),
                5
            ),
            3
        ),
        ','
    );
}
expect {
    0,1,2,4,5
}


test case-array-vs-null {
    CREATE TABLE can1 (id INTEGER PRIMARY KEY, flag INTEGER, vals integer[]) STRICT;
    INSERT INTO can1 VALUES (1, 1, '{1,2,3}');
    INSERT INTO can1 VALUES (2, 0, '{4,5,6}');
    SELECT id, CASE WHEN flag = 1 THEN vals ELSE NULL END FROM can1 ORDER BY id;
}
expect {
    1|{1,2,3}
    2|
}


test array-position-returns-first {
    SELECT array_position(ARRAY[1,2,1,2,1], 1);
}
expect {
    1
}

test array-position-second-element {
    SELECT array_position(ARRAY[1,2,1,2,1], 2);
}
expect {
    2
}


test true-false-as-text-in-integer-rejected {
    CREATE TABLE tf1 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO tf1 VALUES (1, '{true}');
}
expect error {
    cannot store TEXT value in INTEGER
}


test empty-string-element-round-trip {
    CREATE TABLE esr1 (id INTEGER PRIMARY KEY, vals text[]) STRICT;
    INSERT INTO esr1 VALUES (1, '{"", "a", ""}');
    SELECT vals[1], length(vals[1]), vals[2], vals[3], length(vals[3]) FROM esr1;
}
expect {
    |0|a||0
}


test array-contains-int-in-real-array {
    CREATE TABLE acir1 (id INTEGER PRIMARY KEY, vals real[]) STRICT;
    INSERT INTO acir1 VALUES (1, '{1.0, 2.0, 3.0}');
    SELECT array_contains(vals, 2) FROM acir1;
}
expect {
    1
}


test order-by-array-limit-offset {
    CREATE TABLE oalo1 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO oalo1 VALUES (1, '{5}');
    INSERT INTO oalo1 VALUES (2, '{2}');
    INSERT INTO oalo1 VALUES (3, '{4}');
    INSERT INTO oalo1 VALUES (4, '{1}');
    INSERT INTO oalo1 VALUES (5, '{3}');
    SELECT id, vals FROM oalo1 ORDER BY vals LIMIT 2 OFFSET 1;
}
expect {
    2|{2}
    5|{3}
}


test aliased-array-expr {
    CREATE TABLE aae1 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    INSERT INTO aae1 VALUES (1, '{1,2,3}');
    SELECT array_length(vals) AS len, vals[1] AS first_elem FROM aae1;
}
expect {
    3|1
}


test group-by-array-column {
    CREATE TABLE gba1 (vals integer[], cnt INTEGER) STRICT;
    INSERT INTO gba1 VALUES ('{1,2}', 1);
    INSERT INTO gba1 VALUES ('{1,2}', 2);
    INSERT INTO gba1 VALUES ('{3,4}', 3);
    SELECT vals, SUM(cnt) FROM gba1 GROUP BY vals ORDER BY vals;
}
expect {
    {1,2}|3
    {3,4}|3
}
