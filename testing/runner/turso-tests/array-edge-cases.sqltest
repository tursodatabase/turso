    3
}

test correlated-subquery-contains {
    CREATE TABLE csq2 (id INTEGER PRIMARY KEY, vals integer[]) STRICT;
    CREATE TABLE csq3 (id INTEGER PRIMARY KEY, target INTEGER) STRICT;
    INSERT INTO csq2 VALUES (1, '{10,20,30}');
    INSERT INTO csq2 VALUES (2, '{40,50,60}');
    INSERT INTO csq3 VALUES (1, 20);
    SELECT csq2.id FROM csq2 WHERE array_contains(csq2.vals, (SELECT target FROM csq3 WHERE csq3.id = 1)) = 1;
}
expect {
    1
}


