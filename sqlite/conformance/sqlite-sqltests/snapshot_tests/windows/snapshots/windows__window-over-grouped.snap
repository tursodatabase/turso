---
source: windows.sqltest
expression: |-
  SELECT
          department,
          COUNT(*) AS emp_count,
          SUM(salary) AS total_salary,
          ROW_NUMBER() OVER (ORDER BY SUM(salary) DESC) AS dept_salary_rank
      FROM employees
      GROUP BY department;
info:
  statement_type: SELECT
  tables:
  - employees
  setup_blocks:
  - schema
  database: ':memory:'
---
