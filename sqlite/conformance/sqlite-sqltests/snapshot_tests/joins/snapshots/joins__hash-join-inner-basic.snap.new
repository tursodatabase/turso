---
source: joins.sqltest
expression: |-
  SELECT h.order_id, h.customer_name, i.product, i.quantity
      FROM h_orders h
      JOIN h_items i ON h.customer_name = i.order_name;
info:
  statement_type: SELECT
  tables:
  - h.customer_name
  - h_items
  - h_orders
  setup_blocks:
  - hash_schema
  database: ':memory:'
---
