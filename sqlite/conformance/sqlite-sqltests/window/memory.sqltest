setup named_window_sub_data {
    CREATE TABLE t_nw_sub (a INTEGER, b TEXT);
    INSERT INTO t_nw_sub VALUES (1, 'x'), (2, 'x'), (3, 'y'), (4, 'y');
}

@setup named_window_sub_data
test named-window-in-subquery {
    SELECT * FROM (
        SELECT a, sum(a) OVER w1 AS s
        FROM t_nw_sub
        WINDOW w1 AS (PARTITION BY b)
    ) ORDER BY a;
}
expect {
    1|3
    2|3
    3|7
