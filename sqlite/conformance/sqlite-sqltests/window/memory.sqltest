setup named_window_case_data {
    CREATE TABLE t_nw_case (a INTEGER, b TEXT);
    INSERT INTO t_nw_case VALUES (1, 'x'), (2, 'x'), (3, 'y');
}

@setup named_window_case_data
test named-window-case-insensitive {
    SELECT a, count(*) OVER W1
    FROM t_nw_case
    WINDOW w1 AS (PARTITION BY b)
    ORDER BY a;
}
expect {
    1|2
    2|2
    3|1
