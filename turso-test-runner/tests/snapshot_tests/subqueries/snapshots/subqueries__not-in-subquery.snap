---
source: subqueries.sqltest
expression: |-
  SELECT id, name, department
      FROM employees
      WHERE id NOT IN (
          SELECT DISTINCT manager_id
          FROM employees
          WHERE manager_id IS NOT NULL
      );
info:
  statement_type: SELECT
  tables:
  - employees
  setup_blocks:
