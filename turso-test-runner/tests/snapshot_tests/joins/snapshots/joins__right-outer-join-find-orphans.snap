---
source: joins.sqltest
expression: |-
  SELECT
          o.order_id,
          o.order_date,
          o.customer_id
      FROM
          customers c
      RIGHT OUTER JOIN orders o ON c.customer_id = o.customer_id
      WHERE
          c.customer_id IS NULL;
info:
  statement_type: SELECT
  tables:
  - c.customer_id
  - customers
  - orders
  setup_blocks:
  - schema
  database: ':memory:'
---
