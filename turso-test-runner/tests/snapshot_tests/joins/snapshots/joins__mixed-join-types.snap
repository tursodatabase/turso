   3  OpenRead             2   5   0  k(5,B,B,B,B,B)   0  table=order_items, root=5, iDb=0
   4  OpenRead             3   9   0  k(2,B)           0  index=idx_order_items_order_id, root=9, iDb=0
   5  OpenRead             4   3   0  k(5,B,B,B,B,B)   0  table=products, root=3, iDb=0
   6  Rewind               0  24   0                   0  Rewind table customers
   7    RowId              0   5   0                   0  r[5]=customers.rowid
   8    SeekGE             1  23   5                   0  key=[5..5]
   9      IdxGT            1  23   5                   0  key=[5..5]
  10      IdxRowId         1   6   0                   0  r[6]=cursor 1 for index idx_orders_customer_id.rowid
  11      SeekGE           3  22   6                   0  key=[6..6]
  12        IdxGT          3  22   6                   0  key=[6..6]
  13        DeferredSeek   3   2   0                   0
  14        Column         2   2   7                   0  r[7]=order_items.product_id
  15        SeekRowid      4   7  21                   0  if (r[7]!=cursor 4 for table products.rowid) goto 21
  16        Column         0   1   1                   0  r[1]=customers.name
  17        IdxRowId       1   2   0                   0  r[2]=cursor 1 for index idx_orders_customer_id.rowid
  18        Column         2   3   3                   0  r[3]=order_items.quantity
  19        Column         4   1   4                   0  r[4]=products.name
  20        ResultRow      1   4   0                   0  output=r[1..4]
