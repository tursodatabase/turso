@database :memory:

setup orderby_temp_btree {
    CREATE TABLE t(a);
}

@setup orderby_temp_btree
test orderby_a_uses_temp_btree {
    EXPLAIN QUERY PLAN SELECT * FROM t ORDER BY a;
}
expect pattern {
    (?s)SCAN t.*TEMP B-TREE FOR ORDER BY
}

@setup orderby_temp_btree
test orderby_a_desc_uses_temp_btree {
    EXPLAIN QUERY PLAN SELECT * FROM t ORDER BY a DESC;
}
expect pattern {
    (?s)SCAN t.*TEMP B-TREE FOR ORDER BY
}

@setup orderby_temp_btree
test orderby_rowid_no_temp_btree {
    EXPLAIN QUERY PLAN SELECT * FROM t ORDER BY rowid;
}
expect pattern {
    (?s)^(\\d+\\|\\d+\\|\\d+\\|SCAN t.*|QUERY PLAN\\n`--SCAN t\\s*)$
}

@setup orderby_temp_btree
test orderby_rowid_desc_no_temp_btree {
    EXPLAIN QUERY PLAN SELECT * FROM t ORDER BY rowid DESC;
}
expect pattern {
    (?s)^(\\d+\\|\\d+\\|\\d+\\|SCAN t.*|QUERY PLAN\\n`--SCAN t\\s*)$
}
